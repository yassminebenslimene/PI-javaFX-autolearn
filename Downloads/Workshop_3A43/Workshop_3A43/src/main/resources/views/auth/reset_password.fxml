<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.ResetPasswordController"
      prefWidth="860" prefHeight="520">

    <!-- LEFT -->
    <VBox prefWidth="340" alignment="CENTER" spacing="16"
          style="-fx-background-color:#1a1a2e;">
        <padding><Insets top="60" right="50" bottom="60" left="50"/></padding>
        <Label text="🔒" style="-fx-font-size:52;"/>
        <Label text="Réinitialisation" style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:white;"/>
        <Label text="Entrez votre email et définissez un nouveau mot de passe sécurisé."
               style="-fx-font-size:12; -fx-text-fill:#8892b0;" wrapText="true" textAlignment="CENTER"/>
    </VBox>

    <!-- RIGHT -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
          style="-fx-background-color:#f8f9fa;">
        <padding><Insets top="0" right="60" bottom="0" left="60"/></padding>

        <VBox spacing="6" maxWidth="360">
            <Label text="Nouveau mot de passe"
                   style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
            <Region prefHeight="16"/>

            <Label text="Email *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#495057;"/>
            <TextField fx:id="fieldEmail" promptText="votre@email.com"
                       style="-fx-background-color:white; -fx-border-color:#dee2e6; -fx-border-radius:8;
                              -fx-background-radius:8; -fx-padding:9 14 9 14; -fx-font-size:13;"/>
            <Label fx:id="errorEmail" style="-fx-text-fill:#e74c3c; -fx-font-size:11;" minHeight="14"/>

            <Label text="Nouveau mot de passe *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#495057;"/>
            <PasswordField fx:id="fieldNewPassword" promptText="Min 6 car. — Maj+min+chiffre+spécial"
                           style="-fx-background-color:white; -fx-border-color:#dee2e6; -fx-border-radius:8;
                                  -fx-background-radius:8; -fx-padding:9 14 9 14; -fx-font-size:13;"/>
            <Label fx:id="errorPassword" style="-fx-text-fill:#e74c3c; -fx-font-size:11;" minHeight="14"/>

            <Label text="Confirmer *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#495057;"/>
            <PasswordField fx:id="fieldConfirmPassword" promptText="Répétez le mot de passe"
                           style="-fx-background-color:white; -fx-border-color:#dee2e6; -fx-border-radius:8;
                                  -fx-background-radius:8; -fx-padding:9 14 9 14; -fx-font-size:13;"/>
            <Label fx:id="errorConfirm" style="-fx-text-fill:#e74c3c; -fx-font-size:11;" minHeight="14"/>

            <Label fx:id="successLabel" text="" style="-fx-font-size:12;" minHeight="14"/>

            <Region prefHeight="8"/>
            <Button text="Réinitialiser →" onAction="#onReset" maxWidth="Infinity"
                    style="-fx-background-color:#1a1a2e; -fx-text-fill:white; -fx-font-size:14;
                           -fx-font-weight:bold; -fx-padding:12 0 12 0; -fx-background-radius:8; -fx-cursor:hand;"/>
            <Region prefHeight="12"/>
            <HBox alignment="CENTER">
                <Button text="← Retour à la connexion" onAction="#onBackToLogin"
                        style="-fx-background-color:transparent; -fx-text-fill:#1a1a2e; -fx-font-size:12;
                               -fx-font-weight:bold; -fx-cursor:hand; -fx-padding:0;
                               -fx-border-width:0; -fx-underline:true;"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
