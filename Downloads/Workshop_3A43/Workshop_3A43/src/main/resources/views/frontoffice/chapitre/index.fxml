<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color:transparent; -fx-background:#f1f5f9;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.FrontChapitreController">
    <content>
        <VBox spacing="18" style="-fx-background-color:#f1f5f9;">
            <padding><Insets top="24" right="24" bottom="32" left="24"/></padding>

            <!-- Header -->
            <VBox spacing="6"
                  style="-fx-background-color:white; -fx-background-radius:16;
                         -fx-border-color:#e2e8f0; -fx-border-radius:16; -fx-padding:20 24 20 24;
                         -fx-effect:dropshadow(gaussian,rgba(15,23,42,0.07),12,0,0,3);">
                <Label fx:id="labelCourseTitle" text="Chapitres"
                       style="-fx-text-fill:#0f172a; -fx-font-size:26; -fx-font-weight:900;"/>
                <Label fx:id="labelCourseMeta"
                       style="-fx-text-fill:#64748b; -fx-font-size:13; -fx-font-weight:600;"/>
            </VBox>

            <!-- Empty state -->
            <Label fx:id="labelEmpty" text="Aucun chapitre disponible pour ce cours."
                   visible="false" managed="false"
                   style="-fx-text-fill:#94a3b8; -fx-font-size:14; -fx-padding:20 0 0 4;"/>

            <!-- Cards grid (populated by controller) -->
            <VBox fx:id="chaptersContainer" spacing="0"/>

        </VBox>
    </content>
</ScrollPane>
