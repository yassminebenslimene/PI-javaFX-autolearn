<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.SuspendController"
      spacing="0" prefWidth="480"
      style="-fx-background-color:#0d1a14;">

    <!-- Header -->
    <VBox spacing="6" style="-fx-background-color:rgba(220,38,38,0.12); -fx-padding:24 28 20 28;
                              -fx-border-color:transparent transparent rgba(255,255,255,0.1) transparent; -fx-border-width:0 0 1 0;">
        <Label fx:id="labelTitle" text="Suspendre l'étudiant"
               style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:white;"/>
        <Label fx:id="labelSubtitle" text=""
               style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.5);"/>
        <Label fx:id="labelCurrentStatus" text=""
               style="-fx-font-size:13; -fx-font-weight:bold;"/>
    </VBox>

    <!-- Body -->
    <VBox spacing="8" style="-fx-padding:24 28 16 28;">
        <Label text="Raison de la suspension *"
               style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
        <ComboBox fx:id="comboReason" maxWidth="Infinity" promptText="Sélectionner une raison..."
                  style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                         -fx-border-radius:8; -fx-background-radius:8; -fx-font-size:13;"/>

        <Label fx:id="labelCustomReason" text="Préciser la raison *"
               style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"
               visible="false" managed="false"/>
        <TextField fx:id="fieldCustomReason" promptText="Décrivez la raison..."
                   style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                          -fx-font-size:13; -fx-text-fill:white;"
                   visible="false" managed="false"/>

        <Label fx:id="errorReason" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>
    </VBox>

    <!-- Footer -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding:8 28 24 28;">
        <Button text="Annuler" onAction="#onCancel"
                style="-fx-background-color:rgba(255,255,255,0.1); -fx-text-fill:white; -fx-font-size:13;
                       -fx-padding:10 22 10 22; -fx-background-radius:8; -fx-cursor:hand; -fx-border-width:0;"/>
        <Button fx:id="btnAction" text="⚠  Suspendre" onAction="#onAction"
                style="-fx-background-color:#dc2626; -fx-text-fill:white; -fx-font-weight:bold;
                       -fx-padding:10 22 10 22; -fx-background-radius:8; -fx-cursor:hand; -fx-border-width:0;"/>
    </HBox>
</VBox>
