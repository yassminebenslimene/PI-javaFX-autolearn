<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.LandingController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:white;">

    <!-- ── NAVBAR ── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.97); -fx-min-height:64; -fx-max-height:64;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),10,0,0,3);">
            <padding><Insets left="80" right="80"/></padding>
            <Label text="AutoLearn"
                   style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="12" alignment="CENTER">
                <Button text="Se connecter" onAction="#onLogin"
                        style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                               -fx-font-size:13; -fx-font-weight:700; -fx-cursor:hand;
                               -fx-border-width:1.5; -fx-border-color:rgba(255,255,255,0.5);
                               -fx-border-radius:8; -fx-padding:9 22 9 22; -fx-background-radius:8;"/>
                <Button text="S'inscrire gratuitement" onAction="#onRegister"
                        style="-fx-background-color:white; -fx-text-fill:#7a6ad8;
                               -fx-font-size:13; -fx-font-weight:700; -fx-cursor:hand;
                               -fx-border-width:0; -fx-padding:10 24 10 24; -fx-background-radius:8;
                               -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),6,0,0,2);"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:white; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0">

                <!-- ── HERO ── -->
                <HBox alignment="CENTER" spacing="0" prefHeight="520"
                      style="-fx-background-color:white; -fx-padding:0 80 0 80;">

                    <!-- Left: text -->
                    <VBox spacing="24" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="560">
                        <Label text="Des competences d'aujourd'hui"
                               style="-fx-font-size:42; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"
                               wrapText="true"/>
                        <Label text="qui ont de l'avenir"
                               style="-fx-font-size:42; -fx-font-weight:900; -fx-text-fill:#7a6ad8;"
                               wrapText="true"/>
                        <Label text="Apprenez la programmation, relevez des challenges corriges par IA et participez a des evenements tech en Tunisie."
                               wrapText="true"
                               style="-fx-font-size:16; -fx-text-fill:#666; -fx-line-spacing:5; -fx-max-width:480;"/>
                        <HBox spacing="16">
                            <Button text="Commencer gratuitement" onAction="#onRegister"
                                    style="-fx-background-color:#7a6ad8; -fx-text-fill:white;
                                           -fx-font-size:15; -fx-font-weight:700; -fx-cursor:hand;
                                           -fx-border-width:0; -fx-padding:14 32 14 32; -fx-background-radius:10;
                                           -fx-effect:dropshadow(gaussian,rgba(122,106,216,0.35),12,0,0,4);"/>
                            <Button text="Se connecter" onAction="#onLogin"
                                    style="-fx-background-color:transparent; -fx-text-fill:#7a6ad8;
                                           -fx-font-size:15; -fx-font-weight:700; -fx-cursor:hand;
                                           -fx-border-width:1.5; -fx-border-color:#7a6ad8;
                                           -fx-border-radius:10; -fx-padding:14 32 14 32; -fx-background-radius:10;"/>
                        </HBox>
                        <!-- Social proof -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="&#9733;&#9733;&#9733;&#9733;&#9733;"
                                   style="-fx-font-size:14; -fx-text-fill:#f59e0b;"/>
                            <Label text="Rejoignez des milliers d'etudiants en Tunisie"
                                   style="-fx-font-size:12; -fx-text-fill:#999;"/>
                        </HBox>
                    </VBox>

                    <!-- Right: visual card stack -->
                    <StackPane prefWidth="460" HBox.hgrow="NEVER">
                        <!-- Background circle -->
                        <Circle radius="200"
                                style="-fx-fill:#f8f7ff;"
                                mouseTransparent="true"/>
                        <!-- Floating cards -->
                        <VBox spacing="12" alignment="CENTER" mouseTransparent="true">
                            <!-- Card 1 -->
                            <HBox spacing="14" alignment="CENTER_LEFT"
                                  style="-fx-background-color:white; -fx-background-radius:14;
                                         -fx-border-color:#eeeeee; -fx-border-radius:14;
                                         -fx-padding:16 20 16 20;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);"
                                  maxWidth="300">
                                <Label text="&#128218;"
                                       style="-fx-font-size:28; -fx-background-color:#f8f7ff;
                                              -fx-background-radius:10; -fx-padding:8 10 8 10;"/>
                                <VBox spacing="3">
                                    <Label text="Cours Python"
                                           style="-fx-font-size:14; -fx-font-weight:800; -fx-text-fill:#1a1a2e;"/>
                                    <Label text="Debutant · 12 chapitres"
                                           style="-fx-font-size:11; -fx-text-fill:#999;"/>
                                </VBox>
                            </HBox>
                            <!-- Card 2 -->
                            <HBox spacing="14" alignment="CENTER_LEFT"
                                  style="-fx-background-color:#7a6ad8; -fx-background-radius:14;
                                         -fx-padding:16 20 16 20;
                                         -fx-effect:dropshadow(gaussian,rgba(122,106,216,0.3),12,0,0,4);"
                                  maxWidth="300" translateX="40">
                                <Label text="&#127942;"
                                       style="-fx-font-size:28; -fx-background-color:rgba(255,255,255,0.15);
                                              -fx-background-radius:10; -fx-padding:8 10 8 10;"/>
                                <VBox spacing="3">
                                    <Label text="Challenge IA"
                                           style="-fx-font-size:14; -fx-font-weight:800; -fx-text-fill:white;"/>
                                    <Label text="Correction automatique"
                                           style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.7);"/>
                                </VBox>
                            </HBox>
                            <!-- Card 3 -->
                            <HBox spacing="14" alignment="CENTER_LEFT"
                                  style="-fx-background-color:white; -fx-background-radius:14;
                                         -fx-border-color:#eeeeee; -fx-border-radius:14;
                                         -fx-padding:16 20 16 20;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);"
                                  maxWidth="300">
                                <Label text="&#128197;"
                                       style="-fx-font-size:28; -fx-background-color:#dcfce7;
                                              -fx-background-radius:10; -fx-padding:8 10 8 10;"/>
                                <VBox spacing="3">
                                    <Label text="Hackathon Tunis"
                                           style="-fx-font-size:14; -fx-font-weight:800; -fx-text-fill:#1a1a2e;"/>
                                    <Label text="2 Mai 2026 · Cite des Sciences"
                                           style="-fx-font-size:11; -fx-text-fill:#999;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </StackPane>
                </HBox>

                <!-- ── STATS BAR ── -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color:#f8f7ff;
                             -fx-border-color:#eeeeee transparent #eeeeee transparent;
                             -fx-border-width:1 0 1 0;">
                    <VBox alignment="CENTER" spacing="4" prefWidth="280" prefHeight="80"
                          style="-fx-border-color:transparent #eeeeee transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label text="500+"
                               style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Etudiants inscrits"
                               style="-fx-font-size:12; -fx-text-fill:#888;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="280" prefHeight="80"
                          style="-fx-border-color:transparent #eeeeee transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label text="50+"
                               style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:#10b981;"/>
                        <Label text="Cours disponibles"
                               style="-fx-font-size:12; -fx-text-fill:#888;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="280" prefHeight="80"
                          style="-fx-border-color:transparent #eeeeee transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label text="20+"
                               style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:#f59e0b;"/>
                        <Label text="Challenges actifs"
                               style="-fx-font-size:12; -fx-text-fill:#888;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="280" prefHeight="80">
                        <Label text="100%"
                               style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Gratuit pour commencer"
                               style="-fx-font-size:12; -fx-text-fill:#888;"/>
                    </VBox>
                </HBox>

                <!-- ── FEATURES ── -->
                <VBox spacing="40" alignment="CENTER"
                      style="-fx-padding:72 80 72 80; -fx-background-color:white;">
                    <VBox alignment="CENTER" spacing="10">
                        <Label text="Apprendre autrement"
                               style="-fx-font-size:30; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"/>
                        <Label text="AutoLearn combine theorie, pratique et IA pour vous faire progresser plus vite."
                               style="-fx-font-size:14; -fx-text-fill:#888;"/>
                    </VBox>
                    <HBox spacing="28" alignment="CENTER">
                        <!-- Feature 1 -->
                        <VBox spacing="16" alignment="TOP_CENTER" prefWidth="280"
                              style="-fx-background-color:white; -fx-background-radius:16;
                                     -fx-border-color:#f0f0f0; -fx-border-radius:16;
                                     -fx-padding:32 24 32 24;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,4);">
                            <StackPane prefWidth="100" prefHeight="100">
                                <Circle radius="50" style="-fx-fill:#ede9ff;"/>
                                <Label text="&#128218;" style="-fx-font-size:44;"/>
                            </StackPane>
                            <Label text="Apprenez a votre rythme"
                                   style="-fx-font-size:16; -fx-font-weight:800; -fx-text-fill:#1a1a2e;"
                                   wrapText="true" maxWidth="240"/>
                            <Label text="Acces illimite a tous les cours, chapitres et quiz. Progressez quand vous voulez."
                                   style="-fx-font-size:13; -fx-text-fill:#666; -fx-line-spacing:3;"
                                   wrapText="true" maxWidth="240"/>
                        </VBox>
                        <!-- Feature 2 -->
                        <VBox spacing="16" alignment="TOP_CENTER" prefWidth="280"
                              style="-fx-background-color:white; -fx-background-radius:16;
                                     -fx-border-color:#f0f0f0; -fx-border-radius:16;
                                     -fx-padding:32 24 32 24;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,4);">
                            <StackPane prefWidth="100" prefHeight="100">
                                <Circle radius="50" style="-fx-fill:#dcfce7;"/>
                                <Label text="&#129302;" style="-fx-font-size:44;"/>
                            </StackPane>
                            <Label text="Correction par IA"
                                   style="-fx-font-size:16; -fx-font-weight:800; -fx-text-fill:#1a1a2e;"
                                   wrapText="true" maxWidth="240"/>
                            <Label text="Soumettez vos exercices et obtenez un feedback instantane et personnalise."
                                   style="-fx-font-size:13; -fx-text-fill:#666; -fx-line-spacing:3;"
                                   wrapText="true" maxWidth="240"/>
                        </VBox>
                        <!-- Feature 3 -->
                        <VBox spacing="16" alignment="TOP_CENTER" prefWidth="280"
                              style="-fx-background-color:white; -fx-background-radius:16;
                                     -fx-border-color:#f0f0f0; -fx-border-radius:16;
                                     -fx-padding:32 24 32 24;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,4);">
                            <StackPane prefWidth="100" prefHeight="100">
                                <Circle radius="50" style="-fx-fill:#fef3c7;"/>
                                <Label text="&#127942;" style="-fx-font-size:44;"/>
                            </StackPane>
                            <Label text="Challenges et Badges"
                                   style="-fx-font-size:16; -fx-font-weight:800; -fx-text-fill:#1a1a2e;"
                                   wrapText="true" maxWidth="240"/>
                            <Label text="Relevez des defis, grimpez dans le classement et collectionnez des badges."
                                   style="-fx-font-size:13; -fx-text-fill:#666; -fx-line-spacing:3;"
                                   wrapText="true" maxWidth="240"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── CTA BANNER ── -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color:#7a6ad8; -fx-padding:56 80 56 80;">
                    <VBox spacing="16" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                        <Label text="Pret a commencer ?"
                               style="-fx-font-size:28; -fx-font-weight:900; -fx-text-fill:white;"/>
                        <Label text="Rejoignez des milliers d'etudiants et commencez a apprendre aujourd'hui. C'est gratuit."
                               wrapText="true"
                               style="-fx-font-size:14; -fx-text-fill:rgba(255,255,255,0.8); -fx-max-width:500;"/>
                    </VBox>
                    <HBox spacing="14" alignment="CENTER">
                        <Button text="Creer mon compte" onAction="#onRegister"
                                style="-fx-background-color:white; -fx-text-fill:#7a6ad8;
                                       -fx-font-size:14; -fx-font-weight:700; -fx-cursor:hand;
                                       -fx-border-width:0; -fx-padding:13 28 13 28; -fx-background-radius:8;"/>
                        <Button text="Se connecter" onAction="#onLogin"
                                style="-fx-background-color:transparent; -fx-text-fill:white;
                                       -fx-font-size:14; -fx-font-weight:700; -fx-cursor:hand;
                                       -fx-border-width:1.5; -fx-border-color:rgba(255,255,255,0.6);
                                       -fx-border-radius:8; -fx-padding:13 28 13 28; -fx-background-radius:8;"/>
                    </HBox>
                </HBox>

                <!-- ── FOOTER ── -->
                <VBox alignment="CENTER" spacing="8" prefHeight="64"
                      style="-fx-background-color:#7a6ad8; -fx-padding:20 80 20 80;">
                    <Label text="&#169; 2026 AutoLearn — Tous droits reserves — Tunisie"
                           style="-fx-text-fill:rgba(255,255,255,0.7); -fx-font-size:12;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

