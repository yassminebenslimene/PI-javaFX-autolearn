<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.NavbarController"
      alignment="CENTER_LEFT" spacing="0"
      style="-fx-background-color:rgba(122,106,216,0.96);
             -fx-min-height:68; -fx-max-height:68;
             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),10,0,0,3);">
    <padding><Insets left="36" right="36"/></padding>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="&#127891;" style="-fx-font-size:24;"/>
        <Label text="AutoLearn" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:white;"/>
    </HBox>
    <HBox spacing="0" alignment="CENTER" style="-fx-padding:0 0 0 36;">
        <Button fx:id="btnAccueil" text="Accueil" onAction="#onAccueil"
                style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                       -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
        <Button fx:id="btnCours" text="Cours" onAction="#onCours"
                style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                       -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
        <Button fx:id="btnEvenements" text="Evenements" onAction="#onEvenements"
                style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                       -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
        <Button fx:id="btnCommunaute" text="Communaute" onAction="#onCommunaute"
                style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                       -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
        <Button fx:id="btnChallenges" text="Challenges" onAction="#onChallenges"
                style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                       -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
    </HBox>
    <Region HBox.hgrow="ALWAYS"/>
    <HBox alignment="CENTER" spacing="14">
        <Label fx:id="labelAvatarNav"
               style="-fx-background-color:rgba(255,255,255,0.25); -fx-text-fill:white;
                      -fx-font-weight:700; -fx-font-size:14; -fx-background-radius:50%;
                      -fx-padding:8 11 8 11;"/>
        <VBox alignment="CENTER_RIGHT" spacing="1">
            <Label fx:id="labelCurrentUser" text=""
                   style="-fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;"/>
            <Label fx:id="labelNiveauUser" text=""
                   style="-fx-text-fill:rgba(255,255,255,0.65); -fx-font-size:11;"/>
        </VBox>
        <Separator orientation="VERTICAL"
                   style="-fx-background-color:rgba(255,255,255,0.3); -fx-pref-height:28;"/>
        <MenuButton fx:id="menuUser" text="Mon compte"
                    style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                           -fx-font-size:12; -fx-font-weight:600; -fx-padding:7 14 7 14;
                           -fx-background-radius:20; -fx-cursor:hand; -fx-border-width:0;">
            <items>
                <MenuItem text="Mon Profil" onAction="#onProfile"/>
                <MenuItem text="Mes Participations" onAction="#onMesParticipations"/>
                <MenuItem text="Mes Equipes" onAction="#onMesEquipes"/>
                <SeparatorMenuItem/>
                <MenuItem text="Deconnexion" onAction="#onLogout"/>
            </items>
        </MenuButton>
    </HBox>
</HBox>
