<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<DialogPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ChallengeFormController"
            prefWidth="650"
            prefHeight="650"
            style="-fx-background-color:#0a0f0d; -fx-background-radius:16; -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:16;">

    <header>
        <Label fx:id="dialogTitle" text="Ajouter un challenge"
               style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:white; -fx-padding:24 0 16 0;"/>
    </header>

    <content>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color:transparent; -fx-background:transparent; -fx-padding:0;"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox spacing="0" style="-fx-background-color:#0a0f0d; -fx-padding:0 0 20 0;">

                <!-- Form card -->
                <VBox spacing="0"
                      style="-fx-background-color:rgba(255,255,255,0.05); -fx-background-radius:16;
                             -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:16;">

                    <Label text="Informations Challenge"
                           style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:white;
                                  -fx-padding:20 24 16 24; -fx-border-color:transparent transparent rgba(255,255,255,0.1) transparent; -fx-border-width:0 0 1 0;"/>

                    <VBox spacing="8" style="-fx-padding:20 24 24 24;">

                        <!-- Champ ID caché -->
                        <TextField fx:id="txtId" visible="false" managed="false"/>

                        <!-- Titre -->
                        <Label text="Titre *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                        <TextField fx:id="txtTitre" promptText="Entrez le titre"
                                   style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                          -fx-font-size:13; -fx-text-fill:white;"/>
                        <Label fx:id="errorTitre" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

                        <!-- Description -->
                        <Label text="Description *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                        <TextField fx:id="txtDescription" promptText="Entrez la description"
                                   style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                          -fx-font-size:13; -fx-text-fill:white;"/>
                        <Label fx:id="errorDescription" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

                        <!-- Dates -->
                        <HBox spacing="16">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Date début *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                                <DatePicker fx:id="dateDebut" promptText="Sélectionnez la date de début"
                                            style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                                   -fx-border-radius:8; -fx-background-radius:8; -fx-padding:5 10 5 10;
                                                   -fx-font-size:13; -fx-text-fill:white;"/>
                                <Label fx:id="errorDateDebut" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>
                            </VBox>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Date fin *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                                <DatePicker fx:id="dateFin" promptText="Sélectionnez la date de fin"
                                            style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                                   -fx-border-radius:8; -fx-background-radius:8; -fx-padding:5 10 5 10;
                                                   -fx-font-size:13; -fx-text-fill:white;"/>
                                <Label fx:id="errorDateFin" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>
                            </VBox>
                        </HBox>

                        <!-- Niveau et Durée -->
                        <HBox spacing="16">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Niveau *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                                <ComboBox fx:id="comboNiveau" promptText="Sélectionnez le niveau"
                                          style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                                 -fx-border-radius:8; -fx-background-radius:8; -fx-padding:5 10 5 10;
                                                 -fx-font-size:13; -fx-text-fill:white;"/>
                                <Label fx:id="errorNiveau" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>
                            </VBox>

                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Durée (minutes) *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                                <TextField fx:id="txtDuree" promptText="Entrez la durée en minutes"
                                           style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                                  -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                                  -fx-font-size:13; -fx-text-fill:white;"/>
                                <Label fx:id="errorDuree" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>
                            </VBox>
                        </HBox>

                        <!-- Séparateur -->
                        <Separator style="-fx-background-color:rgba(255,255,255,0.1); -fx-padding:10 0 10 0;"/>

                        <!-- Section Exercices -->
                        <Label text="📋 Exercices (optionnel)"
                               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>

                        <Label text="Cliquez sur un exercice pour le sélectionner/désélectionner"
                               style="-fx-font-size:11; -fx-text-fill:rgba(245,245,244,0.4);"/>

                        <FlowPane fx:id="exercicesContainer" hgap="10" vgap="10"
                                  style="-fx-padding:10; -fx-background-color:rgba(255,255,255,0.03); -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:8;"/>

                        <!-- Section Quiz -->
                        <Label text="📚 Quiz (optionnel)"
                               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7); -fx-margin-top:10;"/>

                        <Label text="Cliquez sur un quiz pour le sélectionner/désélectionner"
                               style="-fx-font-size:11; -fx-text-fill:rgba(245,245,244,0.4);"/>

                        <FlowPane fx:id="quizsContainer" hgap="10" vgap="10"
                                  style="-fx-padding:10; -fx-background-color:rgba(255,255,255,0.03); -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:8;"/>

                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </content>

</DialogPane>