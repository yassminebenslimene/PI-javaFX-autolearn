<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ProfileController"
            fitToWidth="true"
            style="-fx-background-color:#0a0f0d; -fx-background:transparent;">

    <VBox spacing="24" style="-fx-background-color:#0a0f0d; -fx-padding:28;">

        <!-- Profile header card -->
        <HBox spacing="24" alignment="CENTER_LEFT"
              style="-fx-background-color:rgba(255,255,255,0.05); -fx-background-radius:16;
                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:16; -fx-padding:24;">
            <Label fx:id="labelInitials"
                   style="-fx-background-color:#059669; -fx-text-fill:white; -fx-font-size:32; -fx-font-weight:bold;
                          -fx-background-radius:50%; -fx-padding:18 22 18 22;"/>
            <VBox spacing="4">
                <Label fx:id="labelFullName" text=""
                       style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:white;"/>
                <Label fx:id="labelEmailHeader" text=""
                       style="-fx-font-size:13; -fx-text-fill:rgba(245,245,244,0.5);"/>
                <HBox spacing="8">
                    <Label fx:id="labelRole" text=""
                           style="-fx-background-color:rgba(5,150,105,0.2); -fx-text-fill:#34d399;
                                  -fx-background-radius:20; -fx-padding:3 12 3 12; -fx-font-size:12; -fx-font-weight:bold;"/>
                    <Label fx:id="labelNiveauBadge" text=""
                           style="-fx-background-color:rgba(251,191,36,0.2); -fx-text-fill:#fbbf24;
                                  -fx-background-radius:20; -fx-padding:3 12 3 12; -fx-font-size:12; -fx-font-weight:bold;"
                           visible="false" managed="false"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- Success message -->
        <Label fx:id="successLabel" text="" wrapText="true"
               style="-fx-background-color:rgba(5,150,105,0.2); -fx-text-fill:#34d399; -fx-font-size:13;
                      -fx-background-radius:8; -fx-padding:12 16 12 16; -fx-font-weight:bold;"
               visible="false" managed="false"/>

        <!-- Form card -->
        <VBox spacing="0"
              style="-fx-background-color:rgba(255,255,255,0.05); -fx-background-radius:16;
                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:16;">

            <Label text="Informations Personnelles"
                   style="-fx-font-size:15; -fx-font-weight:bold; -fx-text-fill:white;
                          -fx-padding:20 24 16 24; -fx-border-color:transparent transparent rgba(255,255,255,0.1) transparent; -fx-border-width:0 0 1 0;"/>

            <VBox spacing="8" style="-fx-padding:20 24 24 24;">

                <HBox spacing="16">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Nom *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                        <TextField fx:id="fieldNom"
                                   style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                          -fx-font-size:13; -fx-text-fill:white;"/>
                        <Label fx:id="errorNom" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Prénom *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                        <TextField fx:id="fieldPrenom"
                                   style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                          -fx-font-size:13; -fx-text-fill:white;"/>
                        <Label fx:id="errorPrenom" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>
                    </VBox>
                </HBox>

                <Label text="Email *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                <TextField fx:id="fieldEmail"
                           style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                  -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                  -fx-font-size:13; -fx-text-fill:white;"/>
                <Label fx:id="errorEmail" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

                <!-- Rôle (read-only) -->
                <Label text="Rôle" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color:rgba(255,255,255,0.04); -fx-border-color:rgba(255,255,255,0.1);
                             -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;">
                    <Label fx:id="labelRoleDisplay" text=""
                           style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#34d399;"/>
                    <Label text="(non modifiable)" style="-fx-font-size:11; -fx-text-fill:rgba(245,245,244,0.35);"/>
                </HBox>

                <!-- Niveau (Etudiant only) -->
                <VBox fx:id="labelNiveauRow" spacing="4" visible="false" managed="false">
                    <Label text="Niveau" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                    <ComboBox fx:id="comboNiveau" maxWidth="Infinity"
                              style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                     -fx-border-radius:8; -fx-background-radius:8; -fx-font-size:13;"/>
                </VBox>

                <Label text="Nouveau mot de passe"
                       style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                <PasswordField fx:id="fieldPassword" promptText="Laisser vide pour ne pas changer"
                               style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                      -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                      -fx-font-size:13; -fx-text-fill:white;"/>
                <Label fx:id="errorPassword" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

                <Label text="Confirmer le mot de passe"
                       style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
                <PasswordField fx:id="fieldConfirmPassword" promptText="Répéter le nouveau mot de passe"
                               style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                      -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                      -fx-font-size:13; -fx-text-fill:white;"/>
                <Label fx:id="errorConfirmPassword" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

                <Region prefHeight="8"/>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="✔  Sauvegarder" onAction="#onSave"
                            style="-fx-background-color:#059669; -fx-text-fill:white; -fx-font-size:13;
                                   -fx-font-weight:bold; -fx-padding:11 24 11 24; -fx-background-radius:8;
                                   -fx-cursor:hand; -fx-border-width:0;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
