<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.BackofficeController"
            prefWidth="1280" prefHeight="760"
            style="-fx-background-color:#0a0f0d;">

    <center>
        <HBox>
            <!-- ══ SHARED SIDEBAR ══ -->
            <fx:include source="../components/sidebar_back.fxml" fx:id="sidebar"/>

            <!-- ══ MAIN CONTENT ══ -->
            <VBox HBox.hgrow="ALWAYS" spacing="0">
                <!-- Topbar -->
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color:rgba(255,255,255,0.03); -fx-min-height:70; -fx-max-height:70;
                             -fx-border-color:transparent transparent rgba(255,255,255,0.1) transparent;
                             -fx-border-width:0 0 1 0;">
                    <padding><Insets left="28" right="28"/></padding>
                    <Label fx:id="labelPageTitle" text="Dashboard"
                           style="-fx-text-fill:white; -fx-font-size:20; -fx-font-weight:bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Content area -->
                <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS"
                           style="-fx-background-color:#0a0f0d;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
