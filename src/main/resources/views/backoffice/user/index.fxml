<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.UserController"
      spacing="0" style="-fx-background-color:#0f1a14;">
    <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

    <!-- ══ STATS GRID (4 cards like Symfony) ══ -->
    <HBox spacing="18">

        <!-- Total Users -->
        <VBox spacing="10" prefWidth="210" prefHeight="110"
              style="-fx-background-color:rgba(255,255,255,0.06);
                     -fx-background-radius:18;
                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:18;
                     -fx-padding:20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),12,0,0,4);">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Total Users"
                           style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.55); -fx-font-weight:600;"/>
                    <Label fx:id="labelTotalUsers" text="0"
                           style="-fx-font-size:34; -fx-font-weight:700; -fx-text-fill:#34d399;"/>
                    <Label text="▲ utilisateurs actifs"
                           style="-fx-font-size:11; -fx-text-fill:rgba(52,211,153,0.7);"/>
                </VBox>
                <Label text="👥"
                       style="-fx-font-size:28; -fx-background-color:rgba(52,211,153,0.12);
                              -fx-background-radius:14; -fx-padding:10 12 10 12;"/>
            </HBox>
        </VBox>

        <!-- Students -->
        <VBox spacing="10" prefWidth="210" prefHeight="110"
              style="-fx-background-color:rgba(255,255,255,0.06);
                     -fx-background-radius:18;
                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:18;
                     -fx-padding:20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),12,0,0,4);">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Étudiants"
                           style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.55); -fx-font-weight:600;"/>
                    <Label fx:id="labelTotalEtudiants" text="0"
                           style="-fx-font-size:34; -fx-font-weight:700; -fx-text-fill:#fbbf24;"/>
                    <Label text="▲ +12.5%"
                           style="-fx-font-size:11; -fx-text-fill:rgba(251,191,36,0.7);"/>
                </VBox>
                <Label text="🎓"
                       style="-fx-font-size:28; -fx-background-color:rgba(251,191,36,0.12);
                              -fx-background-radius:14; -fx-padding:10 12 10 12;"/>
            </HBox>
        </VBox>

        <!-- Admins -->
        <VBox spacing="10" prefWidth="210" prefHeight="110"
              style="-fx-background-color:rgba(255,255,255,0.06);
                     -fx-background-radius:18;
                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:18;
                     -fx-padding:20; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),12,0,0,4);">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Administrateurs"
                           style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.55); -fx-font-weight:600;"/>
                    <Label fx:id="labelTotalAdmins" text="0"
                           style="-fx-font-size:34; -fx-font-weight:700; -fx-text-fill:#f87171;"/>
                    <Label text="▲ +5.2%"
                           style="-fx-font-size:11; -fx-text-fill:rgba(248,113,113,0.7);"/>
                </VBox>
                <Label text="🛡"
                       style="-fx-font-size:28; -fx-background-color:rgba(248,113,113,0.12);
                              -fx-background-radius:14; -fx-padding:10 12 10 12;"/>
            </HBox>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Add button -->
        <HBox fx:id="adminToolbarNew" alignment="CENTER">
            <Button text="＋  Add Student" onAction="#onNewUser"
                    style="-fx-background-color:linear-gradient(to bottom right, #34d399, #059669);
                           -fx-text-fill:white; -fx-font-weight:700; -fx-font-size:13;
                           -fx-padding:14 26 14 26; -fx-background-radius:14; -fx-cursor:hand;
                           -fx-border-width:0;
                           -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.5),14,0,0,4);"/>
        </HBox>
    </HBox>

    <Region prefHeight="24"/>

    <!-- ══ TABLE CARD ══ -->
    <VBox VBox.vgrow="ALWAYS" spacing="0"
          style="-fx-background-color:rgba(255,255,255,0.05);
                 -fx-background-radius:20;
                 -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:20;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.25),16,0,0,6);">

        <!-- Card header -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-padding:20 24 16 24;
                     -fx-border-color:transparent transparent rgba(255,255,255,0.08) transparent;
                     -fx-border-width:0 0 1 0;">
            <VBox spacing="2">
                <Label text="All Users"
                       style="-fx-font-size:16; -fx-font-weight:700; -fx-text-fill:white;"/>
                <Label text="Manage your user base"
                       style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.45);"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Search -->
            <HBox spacing="8" alignment="CENTER"
                  style="-fx-background-color:rgba(255,255,255,0.07);
                         -fx-background-radius:10; -fx-border-color:rgba(255,255,255,0.12);
                         -fx-border-radius:10; -fx-padding:8 14 8 14;">
                <Label text="🔍" style="-fx-font-size:13; -fx-text-fill:rgba(245,245,244,0.4);"/>
                <TextField fx:id="searchField"
                           promptText="Search users..."
                           prefWidth="220" onKeyReleased="#onSearch"
                           style="-fx-background-color:transparent; -fx-border-width:0;
                                  -fx-font-size:13; -fx-text-fill:white;
                                  -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>
                <Button text="✕" onAction="#onClearSearch"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(245,245,244,0.4);
                               -fx-padding:0 4 0 4; -fx-cursor:hand; -fx-border-width:0; -fx-font-size:12;"/>
            </HBox>
        </HBox>

        <!-- Table -->
        <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS"
                   style="-fx-background-color:transparent; -fx-border-width:0;
                          -fx-table-cell-border-color:rgba(255,255,255,0.06);
                          -fx-background-radius:0 0 20 20;">
            <columns>
                <TableColumn fx:id="colUser"    text="User"    prefWidth="260"/>
                <TableColumn fx:id="colNiveau"  text="Level"   prefWidth="130" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colCreated" text="Joined"  prefWidth="120" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colStatut"  text="Status"  prefWidth="110" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="200" style="-fx-alignment:CENTER;" sortable="false"/>
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="12" style="-fx-padding:60;">
                    <Label text="📭" style="-fx-font-size:44;"/>
                    <Label text="No users found."
                           style="-fx-text-fill:rgba(245,245,244,0.35); -fx-font-size:14;"/>
                </VBox>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
