<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.UserController"
      spacing="0" prefWidth="520"
      style="-fx-background-color:#0d1a14;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:rgba(5,150,105,0.15); -fx-padding:20 24 18 24;
                 -fx-border-color:transparent transparent rgba(255,255,255,0.1) transparent; -fx-border-width:0 0 1 0;">
        <Label text="🎓" style="-fx-font-size:20;"/>
        <VBox spacing="2">
            <Label fx:id="formTitle" text="Nouvel étudiant"
                   style="-fx-text-fill:white; -fx-font-size:16; -fx-font-weight:bold;"/>
            <Label fx:id="formSubtitle" text="Remplissez les informations ci-dessous"
                   style="-fx-text-fill:rgba(245,245,244,0.5); -fx-font-size:11;"/>
        </VBox>
    </HBox>

    <!-- Form -->
    <ScrollPane fitToWidth="true" style="-fx-background-color:#0d1a14; -fx-background:transparent;">
        <VBox spacing="8" style="-fx-padding:20 28 20 28;">

            <Label text="Nom *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
            <TextField fx:id="fieldNom" promptText="Ex: Ben Ali"
                       style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                              -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                              -fx-font-size:13; -fx-text-fill:white;"/>
            <Label fx:id="errorNom" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

            <Label text="Prénom *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
            <TextField fx:id="fieldPrenom" promptText="Ex: Mohamed"
                       style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                              -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                              -fx-font-size:13; -fx-text-fill:white;"/>
            <Label fx:id="errorPrenom" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

            <Label text="Email *" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
            <TextField fx:id="fieldEmail" promptText="votre@email.com"
                       style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                              -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                              -fx-font-size:13; -fx-text-fill:white;"/>
            <Label fx:id="errorEmail" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

            <Label text="Mot de passe" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
            <PasswordField fx:id="fieldPassword"
                           style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                  -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                  -fx-font-size:13; -fx-text-fill:white;"/>
            <Label fx:id="labelPasswordHint" text="Min 6 car. — Maj + min + chiffre + spécial"
                   style="-fx-text-fill:rgba(245,245,244,0.4); -fx-font-size:11;"/>
            <Label fx:id="errorPassword" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

            <Label fx:id="labelNiveau" text="Niveau *"
                   style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);"/>
            <ComboBox fx:id="comboNiveau" promptText="Choisir un niveau" maxWidth="Infinity"
                      style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                             -fx-border-radius:8; -fx-background-radius:8; -fx-font-size:13;"/>
            <Label fx:id="errorNiveau" style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="14"/>

            <!-- hidden role/errorRole stubs so controller fields don't NPE -->
            <ComboBox fx:id="comboRole" visible="false" managed="false"/>
            <Label fx:id="errorRole" visible="false" managed="false"/>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-background-color:rgba(255,255,255,0.03); -fx-padding:14 24 18 24;
                 -fx-border-color:rgba(255,255,255,0.1) transparent transparent transparent; -fx-border-width:1 0 0 0;">
        <Button text="Annuler" onAction="#onCancel"
                style="-fx-background-color:rgba(255,255,255,0.1); -fx-text-fill:white; -fx-font-size:13;
                       -fx-padding:10 22 10 22; -fx-background-radius:8; -fx-cursor:hand; -fx-border-width:0;"/>
        <Button text="✔  Enregistrer" onAction="#onSave"
                style="-fx-background-color:#059669; -fx-text-fill:white; -fx-font-size:13;
                       -fx-font-weight:bold; -fx-padding:10 22 10 22; -fx-background-radius:8;
                       -fx-cursor:hand; -fx-border-width:0;"/>
    </HBox>
</VBox>
