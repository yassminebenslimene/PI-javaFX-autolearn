<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="520" spacing="0" style="-fx-background-color:#0d1a14;"
      xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17"
      fx:controller="tn.esprit.controllers.ChapitreController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:rgba(37,99,235,0.15); -fx-padding:20 24 18 24;
                 -fx-border-color:transparent transparent rgba(255,255,255,0.1) transparent;
                 -fx-border-width:0 0 1 0;">
        <Label style="-fx-font-size:20;" text="📖" textFill="WHITE"/>
        <VBox spacing="2">
            <Label fx:id="formTitle" style="-fx-text-fill:white; -fx-font-size:16; -fx-font-weight:bold;" text="Nouveau chapitre"/>
            <Label fx:id="labelFormCourse" style="-fx-text-fill:rgba(96,165,250,0.8); -fx-font-size:11;"/>
        </VBox>
    </HBox>

    <!-- Form -->
    <ScrollPane fitToWidth="true" style="-fx-background-color:#0d1a14; -fx-background:transparent;">
        <VBox spacing="8" style="-fx-padding:20 28 20 28;">

            <Label style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);" text="Titre *"/>
            <TextField fx:id="fieldTitre" promptText="Ex: Introduction"
                       style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                              -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                              -fx-font-size:13; -fx-text-fill:white;"/>
            <Label fx:id="errorTitre" minHeight="14" style="-fx-text-fill:#f87171; -fx-font-size:11;"/>

            <Label style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);" text="Contenu *"/>
            <TextArea fx:id="areaContenu" prefHeight="110" wrapText="true"
                      promptText="Description du chapitre..."
                      style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                             -fx-border-radius:8; -fx-background-radius:8;
                             -fx-font-size:13; -fx-text-fill:white; -fx-control-inner-background:#1a2e20;
                             -fx-highlight-fill:#60a5fa; -fx-highlight-text-fill:white;"/>
            <Label fx:id="errorContenu" minHeight="14" style="-fx-text-fill:#f87171; -fx-font-size:11;"/>

            <HBox spacing="14">
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <Label style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);" text="Ordre *"/>
                    <TextField fx:id="fieldOrdre" promptText="Ex: 1"
                               style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                      -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                                      -fx-font-size:13; -fx-text-fill:white;"/>
                    <Label fx:id="errorOrdre" minHeight="14" style="-fx-text-fill:#f87171; -fx-font-size:11;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="6">
                    <Label style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);" text="Type ressource"/>
                    <ComboBox fx:id="comboRessourceType" maxWidth="Infinity" promptText="Choisir un type"
                              style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                                     -fx-border-radius:8; -fx-background-radius:8; -fx-font-size:13;"/>
                </VBox>
            </HBox>

            <Label style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);" text="Ressources (lien)"/>
            <TextField fx:id="fieldRessources" promptText="https://exemple.com/ressource"
                       style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                              -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                              -fx-font-size:13; -fx-text-fill:white;"/>
            <Label fx:id="errorRessources" minHeight="14" style="-fx-text-fill:#f87171; -fx-font-size:11;"/>

            <Label style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:rgba(245,245,244,0.7);" text="Fichier ressource"/>
            <TextField fx:id="fieldRessourceFichier" promptText="Ex: cours.pdf, video.mp4"
                       style="-fx-background-color:rgba(255,255,255,0.08); -fx-border-color:rgba(255,255,255,0.15);
                              -fx-border-radius:8; -fx-background-radius:8; -fx-padding:10 14 10 14;
                              -fx-font-size:13; -fx-text-fill:white;"/>
            <Label fx:id="errorFichier" minHeight="14" style="-fx-text-fill:#f87171; -fx-font-size:11;"/>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT" spacing="10"
          style="-fx-background-color:rgba(255,255,255,0.03); -fx-padding:14 24 18 24;
                 -fx-border-color:rgba(255,255,255,0.1) transparent transparent transparent;
                 -fx-border-width:1 0 0 0;">
        <Button onAction="#onCancel"
                style="-fx-background-color:rgba(255,255,255,0.1); -fx-text-fill:white; -fx-font-size:13;
                       -fx-padding:10 22 10 22; -fx-background-radius:8; -fx-cursor:hand; -fx-border-width:0;"
                text="Annuler"/>
        <Button onAction="#onSave"
                style="-fx-background-color:linear-gradient(to bottom right,#3b82f6,#1d4ed8); -fx-text-fill:white;
                       -fx-font-size:13; -fx-font-weight:bold; -fx-padding:10 22 10 22;
                       -fx-background-radius:8; -fx-cursor:hand; -fx-border-width:0;"
                text="✔  Enregistrer"/>
    </HBox>
</VBox>

