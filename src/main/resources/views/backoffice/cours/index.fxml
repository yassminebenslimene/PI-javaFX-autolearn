<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" style="-fx-background-color:#0f1a14;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.CoursController">
    <padding><Insets bottom="20" left="28" right="28" top="20"/></padding>

    <!-- ══ STATS ══ -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox prefHeight="80" prefWidth="190" spacing="6"
              style="-fx-background-color:rgba(255,255,255,0.06); -fx-background-radius:14;
                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:14;
                     -fx-padding:14 16 14 16; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),10,0,0,3);">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size:11; -fx-text-fill:rgba(245,245,244,0.55); -fx-font-weight:600;" text="Total Cours"/>
                    <Label fx:id="labelTotalCours" style="-fx-font-size:26; -fx-font-weight:700; -fx-text-fill:#34d399;" text="0"/>
                    <Label style="-fx-font-size:10; -fx-text-fill:rgba(52,211,153,0.7);" text="cours actifs"/>
                </VBox>
                <Label style="-fx-font-size:22; -fx-background-color:rgba(52,211,153,0.12);
                              -fx-background-radius:10; -fx-padding:7 9 7 9;" text="🎓" textFill="WHITE"/>
            </HBox>
        </VBox>

        <VBox prefHeight="80" prefWidth="190" spacing="6"
              style="-fx-background-color:rgba(255,255,255,0.06); -fx-background-radius:14;
                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:14;
                     -fx-padding:14 16 14 16; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),10,0,0,3);">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size:11; -fx-text-fill:rgba(245,245,244,0.55); -fx-font-weight:600;" text="Total Chapitres"/>
                    <Label fx:id="labelTotalChapitres" style="-fx-font-size:26; -fx-font-weight:700; -fx-text-fill:#60a5fa;" text="0"/>
                    <Label style="-fx-font-size:10; -fx-text-fill:rgba(96,165,250,0.7);" text="chapitres au total"/>
                </VBox>
                <Label style="-fx-font-size:22; -fx-background-color:rgba(96,165,250,0.12);
                              -fx-background-radius:10; -fx-padding:7 9 7 9;" text="📚" textFill="WHITE"/>
            </HBox>
        </VBox>
    </HBox>

    <Region prefHeight="16"/>

    <!-- ══ TABLE CARD ══ -->
    <VBox spacing="0"
          style="-fx-background-color:rgba(255,255,255,0.05); -fx-background-radius:20;
                 -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:20;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.25),16,0,0,6);"
          VBox.vgrow="ALWAYS">

        <!-- Card header -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-padding:16 20 14 20;
                     -fx-border-color:transparent transparent rgba(255,255,255,0.08) transparent;
                     -fx-border-width:0 0 1 0;">
            <VBox spacing="2">
                <Label style="-fx-font-size:15; -fx-font-weight:700; -fx-text-fill:white;" text="Gestion des Cours"/>
                <Label style="-fx-font-size:11; -fx-text-fill:rgba(245,245,244,0.45);" text="Gérez votre catalogue de cours"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#onNewCours"
                    style="-fx-background-color:linear-gradient(to bottom right,#34d399,#059669);
                           -fx-text-fill:white; -fx-font-weight:700; -fx-font-size:12;
                           -fx-padding:10 20 10 20; -fx-background-radius:12; -fx-cursor:hand;
                           -fx-border-width:0;
                           -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.5),10,0,0,3);"
                    text="＋  Nouveau cours"/>
            <HBox alignment="CENTER" spacing="8"
                  style="-fx-background-color:rgba(255,255,255,0.07);
                         -fx-background-radius:10; -fx-border-color:rgba(255,255,255,0.12);
                         -fx-border-radius:10; -fx-padding:7 12 7 12;">
                <Label style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.4);" text="🔍"/>
                <TextField fx:id="searchField" onKeyReleased="#onSearch" prefWidth="200"
                           promptText="Rechercher cours..."
                           style="-fx-background-color:transparent; -fx-border-width:0;
                                  -fx-font-size:13; -fx-text-fill:white;
                                  -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>
                <Button onAction="#onClearSearch"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(245,245,244,0.4);
                               -fx-padding:0 4 0 4; -fx-cursor:hand; -fx-border-width:0; -fx-font-size:12;"
                        text="✕"/>
            </HBox>
        </HBox>

        <!-- Table -->
        <TableView fx:id="tableCours"
                   style="-fx-background-color:#0f1a14; -fx-border-width:0;
                          -fx-table-cell-border-color:rgba(255,255,255,0.06);
                          -fx-background-radius:0 0 20 20;"
                   VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colTitre"     minWidth="220" text="Titre"/>
                <TableColumn fx:id="colMatiere"   minWidth="120" style="-fx-alignment:CENTER;" text="Matiere"/>
                <TableColumn fx:id="colNiveau"    minWidth="120" style="-fx-alignment:CENTER;" text="Niveau"/>
                <TableColumn fx:id="colDuree"     minWidth="100" style="-fx-alignment:CENTER;" text="Duree (h)"/>
                <TableColumn fx:id="colChapitres" minWidth="110" style="-fx-alignment:CENTER;" text="Nb chapitres"/>
                <TableColumn fx:id="colActions"   minWidth="260" sortable="false" style="-fx-alignment:CENTER;" text="Actions"/>
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="12" style="-fx-padding:60;">
                    <Label style="-fx-font-size:44;" text="📭"/>
                    <Label style="-fx-text-fill:rgba(245,245,244,0.35); -fx-font-size:14;" text="Aucun cours trouvé."/>
                </VBox>
            </placeholder>
        </TableView>
    </VBox>
</VBox>

