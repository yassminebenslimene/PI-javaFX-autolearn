<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.QuizShowController"
            stylesheets="@style.css"
            style="-fx-background-color:#0a0f0d;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-padding:20 28 0 28;">
            <Label text="Détails du Quiz" styleClass="page-title"/>
        </HBox>
    </top>

    <center>
        <VBox style="-fx-padding:16 28 32 28;" spacing="0">
            <VBox styleClass="glass-card" spacing="0" style="-fx-padding:0;">

                <!-- Header: quiz title + subtitle + Retour + Modifier -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding:20 24 16 24;
                             -fx-border-color:transparent transparent rgba(255,255,255,0.08) transparent;
                             -fx-border-width:0 0 1 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="labelTitre" text=""
                               style="-fx-text-fill:#f5f5f4; -fx-font-size:20; -fx-font-weight:bold;"/>
                        <Label fx:id="labelSubtitle" text=""
                               styleClass="card-subtitle"/>
                    </VBox>
                    <Button text="← Retour" onAction="#retour"
                            style="-fx-background-color:rgba(255,255,255,0.06); -fx-text-fill:rgba(245,245,244,0.7);
                                   -fx-background-radius:8; -fx-padding:9 18; -fx-cursor:hand; -fx-border-width:0;"/>
                    <Button text="✎ Modifier" styleClass="btn-edit"
                            style="-fx-font-size:13px; -fx-padding:9 18;"
                            onAction="#modifier"/>
                </HBox>

                <!-- Body -->
                <VBox spacing="20" style="-fx-padding:28 28 10 28;">

                    <!-- Titre -->
                    <VBox spacing="6">
                        <Label text="Titre"
                               style="-fx-text-fill:#f5f5f4; -fx-font-weight:bold; -fx-font-size:14;"/>
                        <Label fx:id="labelTitreVal" text=""
                               style="-fx-text-fill:rgba(245,245,244,0.7); -fx-font-size:14;"/>
                    </VBox>

                    <!-- Description -->
                    <VBox spacing="6">
                        <Label text="Description"
                               style="-fx-text-fill:#f5f5f4; -fx-font-weight:bold; -fx-font-size:14;"/>
                        <Label fx:id="labelDescVal" text="" wrapText="true"
                               style="-fx-text-fill:rgba(245,245,244,0.7); -fx-font-size:14;"/>
                    </VBox>

                    <!-- État -->
                    <VBox spacing="8">
                        <Label text="État"
                               style="-fx-text-fill:#f5f5f4; -fx-font-weight:bold; -fx-font-size:14;"/>
                        <Label fx:id="labelEtatBadge" text=""/>
                    </VBox>

                    <!-- Separator -->
                    <Separator styleClass="separator"/>

                    <!-- Supprimer -->
                    <HBox style="-fx-padding:0 0 10 0;">
                        <Button text="🗑 Supprimer" styleClass="btn-delete"
                                style="-fx-font-size:13px; -fx-padding:10 22;"
                                onAction="#supprimer"/>
                    </HBox>

                </VBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
