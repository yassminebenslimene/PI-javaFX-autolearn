<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    index.fxml — Page principale de gestion des quiz (vue hiérarchique)
    Controller : QuizController.java
    C'est la page d'accueil de la section Quiz.
    Elle affiche la liste de tous les quiz avec une structure hiérarchique :
      Quiz → [Sélectionner] → Questions → [Sélectionner] → Options
    Chargée par BackofficeController quand on clique "Gestion Quiz" dans la sidebar.
-->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.QuizController"
            style="-fx-background-color:#0f1a14; -fx-font-family:'Segoe UI',Arial,sans-serif;">

    <!-- ══ HAUT : Titre de la section ══ -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-padding:20 28 0 28;">
            <Label text="Gestion des Quiz"
                   style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#f5f5f4;"/>
        </HBox>
    </top>

    <!-- ══ CENTRE : Carte principale avec la liste des quiz ══ -->
    <center>
        <VBox style="-fx-padding:16 28 24 28;">

            <!-- Carte avec effet verre (glassmorphism) -->
            <VBox style="-fx-background-color:rgba(255,255,255,0.05);
                         -fx-border-color:rgba(255,255,255,0.1);
                         -fx-border-radius:16px; -fx-background-radius:16px;
                         -fx-border-width:1px;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),20,0,0,6);">

                <!-- ── En-tête de la carte : titre + bouton Nouveau + barre de recherche ── -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding:16 20 14 20;
                             -fx-border-color:transparent transparent rgba(255,255,255,0.08) transparent;
                             -fx-border-width:0 0 1 0;">
                    <!-- Icône et texte descriptif -->
                    <Label text="📋" style="-fx-font-size:15;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Liste des Quiz"
                               style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#f5f5f4;"/>
                        <Label text="Cliquez sur « Sélectionner » pour afficher les questions"
                               style="-fx-font-size:12px; -fx-text-fill:rgba(245,245,244,0.4);"/>
                    </VBox>

                    <!-- Bouton "+ Nouveau Quiz" → appelle ouvrirFormAjout() → charge quiz_form.fxml -->
                    <Button text="+ Nouveau Quiz" onAction="#ouvrirFormAjout"
                            style="-fx-background-color:linear-gradient(to bottom right,#34d399,#059669);
                                   -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:13px;
                                   -fx-padding:9px 18px; -fx-background-radius:8px; -fx-cursor:hand;
                                   -fx-border-width:0;
                                   -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.4),10,0,0,3);"/>

                    <!-- Barre de recherche : filtre les quiz par titre ou description -->
                    <HBox alignment="CENTER" spacing="8"
                          style="-fx-background-color:rgba(255,255,255,0.07);
                                 -fx-background-radius:10; -fx-border-color:rgba(255,255,255,0.12);
                                 -fx-border-radius:10; -fx-padding:7 12 7 12;">
                        <Label text="🔍" style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.4);"/>
                        <!-- fx:id="searchField" → lu par onSearch() à chaque touche relâchée -->
                        <TextField fx:id="searchField" onKeyReleased="#onSearch"
                                   prefWidth="180" promptText="Rechercher un quiz..."
                                   style="-fx-background-color:transparent; -fx-border-width:0;
                                          -fx-font-size:13; -fx-text-fill:white;
                                          -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>
                        <!-- Bouton ✕ pour effacer la recherche → appelle onClearSearch() -->
                        <Button onAction="#onClearSearch" text="✕"
                                style="-fx-background-color:transparent; -fx-text-fill:rgba(245,245,244,0.4);
                                       -fx-padding:0 4 0 4; -fx-cursor:hand; -fx-border-width:0; -fx-font-size:12;"/>
                    </HBox>
                </HBox>

                <!-- ── Liste scrollable des quiz ── -->
                <!-- fitToWidth=true : la liste prend toute la largeur disponible -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color:transparent; -fx-background:transparent;
                                   -fx-border-color:transparent; -fx-min-height:500px;">
                    <!--
                        fx:id="mainContainer" → VBox remplie dynamiquement par chargerTout() dans QuizController.
                        Chaque quiz est ajouté comme un bloc (buildQuizBlock).
                        Quand on clique "Sélectionner", les questions apparaissent en dessous.
                        Quand on clique "Sélectionner" sur une question, les options apparaissent.
                    -->
                    <VBox fx:id="mainContainer" spacing="0"
                          style="-fx-background-color:transparent;"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </center>

</BorderPane>

