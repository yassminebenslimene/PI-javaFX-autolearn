<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.CommunauteFormController"
      spacing="20" alignment="TOP_CENTER"
      style="-fx-background-color:#0a0f0d; -fx-padding:40;">

    <Label fx:id="labelTitle" text="Nouvelle Communauté"
           style="-fx-text-fill:white; -fx-font-size:22; -fx-font-weight:bold;"/>

    <VBox spacing="8" maxWidth="500">
        <Label text="Nom *" style="-fx-text-fill:rgba(255,255,255,0.7); -fx-font-size:13;"/>
        <TextField fx:id="fieldNom" promptText="Nom de la communauté"
                   style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:white;
                          -fx-prompt-text-fill:rgba(255,255,255,0.3); -fx-background-radius:10;
                          -fx-border-width:0; -fx-padding:12 16 12 16; -fx-font-size:13;"/>
    </VBox>

    <VBox spacing="8" maxWidth="500">
        <Label text="Description" style="-fx-text-fill:rgba(255,255,255,0.7); -fx-font-size:13;"/>
        <TextArea fx:id="fieldDescription" promptText="Description de la communauté"
                  prefRowCount="4"
                  style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:white;
                         -fx-prompt-text-fill:rgba(255,255,255,0.3); -fx-background-radius:10;
                         -fx-border-width:0; -fx-padding:12 16 12 16; -fx-font-size:13;"/>
    </VBox>

    <VBox spacing="8" maxWidth="500">
        <Label text="Owner ID *" style="-fx-text-fill:rgba(255,255,255,0.7); -fx-font-size:13;"/>
        <TextField fx:id="fieldOwnerId" promptText="ID du propriétaire"
                   style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:white;
                          -fx-prompt-text-fill:rgba(255,255,255,0.3); -fx-background-radius:10;
                          -fx-border-width:0; -fx-padding:12 16 12 16; -fx-font-size:13;"/>
    </VBox>

    <Label fx:id="labelError" text="" style="-fx-text-fill:#e94560; -fx-font-size:12;"/>

    <HBox spacing="12" alignment="CENTER">
        <Button text="Annuler" onAction="#onAnnuler"
                style="-fx-background-color:rgba(255,255,255,0.08); -fx-text-fill:white;
                       -fx-font-size:13; -fx-padding:10 24 10 24; -fx-background-radius:10;
                       -fx-cursor:hand; -fx-border-width:0;"/>
        <Button fx:id="btnSave" text="Enregistrer" onAction="#onSave"
                style="-fx-background-color:#059669; -fx-text-fill:white; -fx-font-weight:bold;
                       -fx-font-size:13; -fx-padding:10 24 10 24; -fx-background-radius:10;
                       -fx-cursor:hand; -fx-border-width:0;"/>
    </HBox>
</VBox>
