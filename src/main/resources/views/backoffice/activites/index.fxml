<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.ActivitesController"
      spacing="0" style="-fx-background-color:#0a0f0d;">

    <!-- Top bar: filters + stats -->
    <HBox spacing="16" alignment="CENTER_LEFT"
          style="-fx-padding:20 28 16 28; -fx-background-color:#0d1a14;
                 -fx-border-color:transparent transparent rgba(255,255,255,0.08) transparent;
                 -fx-border-width:0 0 1 0;">

        <!-- Stats pills -->
        <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color:rgba(5,150,105,0.15); -fx-background-radius:10;
                         -fx-padding:8 16 8 16; -fx-border-color:rgba(5,150,105,0.3);
                         -fx-border-radius:10; -fx-border-width:1;">
                <Label fx:id="statTotal" text="---"
                       style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#34d399;"/>
                <Label text="Total" style="-fx-font-size:10; -fx-text-fill:rgba(245,245,244,0.5);"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color:rgba(99,102,241,0.15); -fx-background-radius:10;
                         -fx-padding:8 16 8 16; -fx-border-color:rgba(99,102,241,0.3);
                         -fx-border-radius:10; -fx-border-width:1;">
                <Label fx:id="statCreations" text="---"
                       style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#a5b4fc;"/>
                <Label text="Creations" style="-fx-font-size:10; -fx-text-fill:rgba(245,245,244,0.5);"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color:rgba(251,191,36,0.15); -fx-background-radius:10;
                         -fx-padding:8 16 8 16; -fx-border-color:rgba(251,191,36,0.3);
                         -fx-border-radius:10; -fx-border-width:1;">
                <Label fx:id="statModifs" text="---"
                       style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#fbbf24;"/>
                <Label text="Modifications" style="-fx-font-size:10; -fx-text-fill:rgba(245,245,244,0.5);"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color:rgba(239,68,68,0.15); -fx-background-radius:10;
                         -fx-padding:8 16 8 16; -fx-border-color:rgba(239,68,68,0.3);
                         -fx-border-radius:10; -fx-border-width:1;">
                <Label fx:id="statSupprs" text="---"
                       style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#f87171;"/>
                <Label text="Suppressions" style="-fx-font-size:10; -fx-text-fill:rgba(245,245,244,0.5);"/>
            </VBox>
        </HBox>

        <!-- Filters -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <ComboBox fx:id="filterType" promptText="Type d'entite"
                      style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:white;
                             -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:8;
                             -fx-background-radius:8; -fx-font-size:12; -fx-pref-height:36;"/>
            <ComboBox fx:id="filterAction" promptText="Action"
                      style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:white;
                             -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:8;
                             -fx-background-radius:8; -fx-font-size:12; -fx-pref-height:36;"/>
            <ComboBox fx:id="filterUser" promptText="Utilisateur"
                      style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:white;
                             -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:8;
                             -fx-background-radius:8; -fx-font-size:12; -fx-pref-height:36;"/>
            <Button text="Reinitialiser" onAction="#onReset"
                    style="-fx-background-color:rgba(255,255,255,0.08); -fx-text-fill:rgba(245,245,244,0.7);
                           -fx-font-size:12; -fx-padding:8 14 8 14; -fx-background-radius:8;
                           -fx-cursor:hand; -fx-border-width:0;"/>
        </HBox>
    </HBox>

    <!-- Geo info bar (current admin location) -->
    <HBox fx:id="geoBar" spacing="8" alignment="CENTER_LEFT"
          style="-fx-padding:10 28 10 28; -fx-background-color:rgba(5,150,105,0.08);
                 -fx-border-color:transparent transparent rgba(255,255,255,0.06) transparent;
                 -fx-border-width:0 0 1 0;">
        <Label text="Votre localisation :"
               style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.45);"/>
        <Label fx:id="labelGeoInfo" text="Chargement..."
               style="-fx-font-size:12; -fx-text-fill:#34d399; -fx-font-weight:600;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelGeoIp" text=""
               style="-fx-font-size:11; -fx-text-fill:rgba(245,245,244,0.3);"/>
    </HBox>

    <!-- Audit table -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-width:0;">
        <VBox fx:id="auditListContainer" spacing="0"
              style="-fx-padding:0 28 20 28; -fx-background-color:#0a0f0d;"/>
    </ScrollPane>

</VBox>
