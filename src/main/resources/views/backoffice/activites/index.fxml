<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.ActivitesController"
      spacing="0" style="-fx-background-color:#0a0f0d;">

    <!-- ── GEO BAR ── -->
    <HBox fx:id="geoBar" spacing="8" alignment="CENTER_LEFT"
          style="-fx-padding:10 28 10 28; -fx-background-color:#0d1a14;
                 -fx-border-color:transparent transparent rgba(255,255,255,0.07) transparent;
                 -fx-border-width:0 0 1 0;">
        <Label text="Votre localisation :"
               style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.4);"/>
        <Label fx:id="labelGeoInfo" text="Chargement..."
               style="-fx-font-size:12; -fx-text-fill:#34d399; -fx-font-weight:600;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelGeoIp" text=""
               style="-fx-font-size:11; -fx-text-fill:rgba(245,245,244,0.25);"/>
    </HBox>

    <!-- ── TABS ── -->
    <HBox spacing="0"
          style="-fx-background-color:#0d1a14;
                 -fx-border-color:transparent transparent rgba(255,255,255,0.08) transparent;
                 -fx-border-width:0 0 1 0; -fx-padding:0 28 0 28;">
        <Button fx:id="btnTabStudents" text="  👥  Activites Etudiants" onAction="#onTabStudents"
                style="-fx-background-color:rgba(122,106,216,0.2); -fx-text-fill:#a5b4fc;
                       -fx-font-size:13; -fx-font-weight:700; -fx-cursor:hand; -fx-border-width:0;
                       -fx-padding:12 20 12 20; -fx-background-radius:0;
                       -fx-border-color:transparent transparent #7a6ad8 transparent; -fx-border-width:0 0 2 0;"/>
        <Button fx:id="btnTabAdmin" text="  🔑  Mon Historique" onAction="#onTabAdmin"
                style="-fx-background-color:transparent; -fx-text-fill:rgba(245,245,244,0.5);
                       -fx-font-size:13; -fx-cursor:hand; -fx-border-width:0;
                       -fx-padding:12 20 12 20; -fx-background-radius:0;"/>
    </HBox>

    <!-- ── STATS BAR ── -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-padding:14 28 14 28; -fx-background-color:#0d1a14;">
        <VBox alignment="CENTER" spacing="2"
              style="-fx-background-color:rgba(5,150,105,0.15); -fx-background-radius:8;
                     -fx-padding:8 16 8 16; -fx-border-color:rgba(5,150,105,0.25); -fx-border-radius:8; -fx-border-width:1;">
            <Label fx:id="statTotal" text="---"
                   style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#34d399;"/>
            <Label text="Total" style="-fx-font-size:10; -fx-text-fill:rgba(245,245,244,0.45);"/>
        </VBox>
        <VBox alignment="CENTER" spacing="2"
              style="-fx-background-color:rgba(99,102,241,0.15); -fx-background-radius:8;
                     -fx-padding:8 16 8 16; -fx-border-color:rgba(99,102,241,0.25); -fx-border-radius:8; -fx-border-width:1;">
            <Label fx:id="statLogins" text="---"
                   style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#a5b4fc;"/>
            <Label text="Connexions" style="-fx-font-size:10; -fx-text-fill:rgba(245,245,244,0.45);"/>
        </VBox>
        <VBox alignment="CENTER" spacing="2"
              style="-fx-background-color:rgba(251,191,36,0.15); -fx-background-radius:8;
                     -fx-padding:8 16 8 16; -fx-border-color:rgba(251,191,36,0.25); -fx-border-radius:8; -fx-border-width:1;">
            <Label fx:id="statViews" text="---"
                   style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#fbbf24;"/>
            <Label text="Consultations" style="-fx-font-size:10; -fx-text-fill:rgba(245,245,244,0.45);"/>
        </VBox>
        <VBox alignment="CENTER" spacing="2"
              style="-fx-background-color:rgba(239,68,68,0.15); -fx-background-radius:8;
                     -fx-padding:8 16 8 16; -fx-border-color:rgba(239,68,68,0.25); -fx-border-radius:8; -fx-border-width:1;">
            <Label fx:id="statSuspensions" text="---"
                   style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#f87171;"/>
            <Label text="Suspensions" style="-fx-font-size:10; -fx-text-fill:rgba(245,245,244,0.45);"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Filters -->
        <ComboBox fx:id="filterAction" promptText="Toutes les actions"
                  style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:white;
                         -fx-border-color:rgba(255,255,255,0.12); -fx-border-radius:8;
                         -fx-background-radius:8; -fx-font-size:12; -fx-pref-height:34; -fx-pref-width:180;"/>
        <ComboBox fx:id="filterUser" promptText="Tous les utilisateurs"
                  style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:white;
                         -fx-border-color:rgba(255,255,255,0.12); -fx-border-radius:8;
                         -fx-background-radius:8; -fx-font-size:12; -fx-pref-height:34; -fx-pref-width:200;"/>
        <Button text="Reinitialiser" onAction="#onReset"
                style="-fx-background-color:rgba(255,255,255,0.07); -fx-text-fill:rgba(245,245,244,0.6);
                       -fx-font-size:12; -fx-padding:7 14 7 14; -fx-background-radius:8;
                       -fx-cursor:hand; -fx-border-width:0;"/>
        <Button text="Actualiser" onAction="#onRefresh"
                style="-fx-background-color:rgba(122,106,216,0.25); -fx-text-fill:#a5b4fc;
                       -fx-font-size:12; -fx-padding:7 14 7 14; -fx-background-radius:8;
                       -fx-cursor:hand; -fx-border-width:0;"/>
    </HBox>

    <!-- ── TABLE CONTENT ── -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-width:0;">
        <VBox fx:id="activityListContainer" spacing="0"
              style="-fx-padding:0 28 20 28; -fx-background-color:#0a0f0d;"/>
    </ScrollPane>

</VBox>
