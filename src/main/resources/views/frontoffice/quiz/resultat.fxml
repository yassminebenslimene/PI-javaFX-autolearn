<?xml version="1.0" encoding="UTF-8"?>
<!--
    ============================================================
    resultat.fxml — Écran de résultats du quiz (front-office)
    ============================================================

    Rôle :
      Affiche le score final de l'étudiant après soumission du quiz.
      Présente les points obtenus, le pourcentage de réussite,
      un message contextuel (succès / encouragement / échec),
      et des statistiques de session (tentative, meilleur score,
      possibilité de recommencer).

    Contrôleur associé : FrontQuizController
      - afficherResultat() : calcule le score et remplit tous les labels
      - onRefaire()        : recharge intro.fxml pour recommencer le quiz
      - onRetour()         : retourne à la liste des chapitres
      - onAccueil()        : navigue vers la page d'accueil

    Calcul du score (effectué dans afficherResultat()) :
      Pour chaque question :
        - Si l'option choisie == option correcte → +points de la question
      Pourcentage = (pointsObtenus / totalPoints) × 100
      Message selon pct vs seuil de réussite (défaut 50 %) :
        - pct >= seuil       → "Félicitations !" (vert)
        - pct >= seuil / 2   → "Peut mieux faire" (orange)
        - pct < seuil / 2    → "Score insuffisant" (rouge)

    Structure de la vue :
      StackPane (fond dégradé violet)
      └── VBox (centré)
          ├── VBox (carte résultats principaux)
          │   ├── Titre "📊 Résultats du Quiz"
          │   ├── labelTitreResultat  — nom du quiz
          │   ├── HBox (score principal)
          │   │   ├── labelPointsObtenus  — points obtenus (violet)
          │   │   ├── labelPourcentage    — pourcentage (orange)
          │   │   └── labelPointsTotal    — total points (noir)
          │   └── labelMessage            — message contextuel coloré
          ├── VBox (carte statistiques)
          │   ├── Titre "📈 Vos statistiques"
          │   └── HBox (3 tuiles)
          │       ├── labelTentative / labelMaxTentatives
          │       ├── labelMeilleurScore
          │       └── labelPeutRecommencer
          └── HBox (boutons d'action)
              ├── Bouton "↺ Refaire le quiz"
              ├── Bouton "← Retour aux chapitres"
              └── Bouton "🏠 Accueil"
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!-- Conteneur racine : fond dégradé violet (du haut-gauche vers le bas-droit) -->
<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.FrontQuizController"
           style="-fx-background-color:linear-gradient(to bottom right,#46178F,#764ba2);">

    <!-- Contenu principal centré, largeur maximale 680 px -->
    <VBox alignment="CENTER" spacing="20" maxWidth="680">
        <padding><Insets top="30" bottom="30"/></padding>

        <!--
            CARTE RÉSULTATS PRINCIPAUX
            Fond blanc, coins arrondis, ombre portée.
            Affiche le titre, le score en 3 colonnes et le message contextuel.
        -->
        <!-- ── Carte résultats principaux ── -->
        <VBox alignment="CENTER" spacing="16"
              style="-fx-background-color:white; -fx-background-radius:20;
                     -fx-padding:36 40 32 40;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),24,0,0,8);">

            <!-- Titre fixe de la section résultats -->
            <!-- Titre -->
            <Label text="📊  Résultats du Quiz"
                   style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
            <!-- Nom du quiz : rempli avec "Quiz - [titre]" par afficherResultat() -->
            <Label fx:id="labelTitreResultat" text=""
                   style="-fx-font-size:14; -fx-text-fill:#7c3aed; -fx-font-weight:700;"/>

            <!--
                SCORE PRINCIPAL : 3 grandes valeurs côte à côte.
                Espacement de 48 px entre les colonnes.
            -->
            <!-- Score principal -->
            <HBox alignment="CENTER" spacing="48" style="-fx-padding:8 0 8 0;">
                <!--
                    Points obtenus : grand chiffre violet.
                    Calculé dans afficherResultat() en comparant les réponses
                    choisies avec les options correctes.
                -->
                <VBox alignment="CENTER" spacing="4">
                    <Label fx:id="labelPointsObtenus" text="0"
                           style="-fx-font-size:48; -fx-font-weight:900; -fx-text-fill:#7c3aed;"/>
                    <Label text="POINTS OBTENUS"
                           style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
                </VBox>
                <!--
                    Pourcentage de réussite : grand chiffre orange.
                    Format : "XX%" (arrondi à l'entier).
                    Calculé : (pointsObtenus / totalPoints) × 100.
                -->
                <VBox alignment="CENTER" spacing="4">
                    <Label fx:id="labelPourcentage" text="0%"
                           style="-fx-font-size:48; -fx-font-weight:900; -fx-text-fill:#f59e0b;"/>
                    <Label text="RÉUSSITE"
                           style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
                </VBox>
                <!--
                    Total des points possibles : grand chiffre noir.
                    Somme des points de toutes les questions du quiz.
                -->
                <VBox alignment="CENTER" spacing="4">
                    <Label fx:id="labelPointsTotal" text="0"
                           style="-fx-font-size:48; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                    <Label text="POINTS TOTAL"
                           style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
                </VBox>
            </HBox>

            <!--
                Message contextuel : fond et couleur changent selon le résultat.
                - Vert  (#059669) : réussite (pct >= seuil)
                - Orange (#d97706): encouragement (pct >= seuil/2)
                - Rouge (#dc2626) : échec (pct < seuil/2)
                Le style inline est appliqué dynamiquement par afficherResultat().
            -->
            <!-- Message résultat -->
            <Label fx:id="labelMessage" text=""
                   style="-fx-font-size:14; -fx-font-weight:700;
                          -fx-background-color:#f1f5f9; -fx-background-radius:10;
                          -fx-padding:10 20 10 20;"
                   wrapText="true"/>
        </VBox>

        <!--
            CARTE STATISTIQUES
            Fond blanc, coins arrondis, ombre portée.
            Affiche 3 tuiles : tentative, meilleur score, peut recommencer.
        -->
        <!-- ── Carte statistiques ── -->
        <VBox spacing="16"
              style="-fx-background-color:white; -fx-background-radius:20;
                     -fx-padding:28 32 28 32;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),24,0,0,8);">

            <!-- Titre de la section statistiques -->
            <Label text="📈  Vos statistiques pour ce quiz"
                   style="-fx-font-size:16; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>

            <!-- 3 tuiles de statistiques côte à côte -->
            <HBox spacing="16" alignment="CENTER">

                <!--
                    Tuile 1 : Numéro de tentative
                    labelTentative     : numéro de la tentative actuelle (toujours "1")
                    labelMaxTentatives : "TENTATIVE / X" ou "TENTATIVE / ∞"
                    Fond violet clair, bordure violette.
                -->
                <!-- Tentative -->
                <HBox spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:#f8f7ff; -fx-background-radius:12;
                             -fx-border-color:#e0d9ff; -fx-border-radius:12; -fx-border-width:1;
                             -fx-padding:16 20 16 20;">
                    <Label text="▶"
                           style="-fx-font-size:18; -fx-background-color:#7c3aed;
                                  -fx-text-fill:white; -fx-background-radius:50%;
                                  -fx-padding:8 10 8 10;"/>
                    <VBox spacing="2">
                        <!-- Numéro de la tentative actuelle -->
                        <Label fx:id="labelTentative" text="1"
                               style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                        <!-- Sous-titre : "TENTATIVE / [max]" ou "TENTATIVE / ∞" -->
                        <Label fx:id="labelMaxTentatives" text="TENTATIVE / ∞"
                               style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
                    </VBox>
                </HBox>

                <!--
                    Tuile 2 : Meilleur score
                    labelMeilleurScore : pourcentage du meilleur score (= score actuel dans cette version)
                    Fond jaune clair, bordure jaune.
                -->
                <!-- Meilleur score -->
                <HBox spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:#fffbf0; -fx-background-radius:12;
                             -fx-border-color:#fde68a; -fx-border-radius:12; -fx-border-width:1;
                             -fx-padding:16 20 16 20;">
                    <Label text="●"
                           style="-fx-font-size:28; -fx-text-fill:#f59e0b;"/>
                    <VBox spacing="2">
                        <!-- Meilleur score en pourcentage (ex : "75%") -->
                        <Label fx:id="labelMeilleurScore" text="0%"
                               style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#f59e0b;"/>
                        <Label text="MEILLEUR SCORE"
                               style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
                    </VBox>
                </HBox>

                <!--
                    Tuile 3 : Peut recommencer
                    labelPeutRecommencer : "OUI" (bleu) ou "NON" (rouge)
                    Logique : peut recommencer si maxTentatives est null ou > 1.
                    Fond bleu clair, bordure bleue.
                -->
                <!-- Peut recommencer -->
                <HBox spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:#f0fbff; -fx-background-radius:12;
                             -fx-border-color:#bae6fd; -fx-border-radius:12; -fx-border-width:1;
                             -fx-padding:16 20 16 20;">
                    <Label text="↺"
                           style="-fx-font-size:20; -fx-background-color:#0ea5e9;
                                  -fx-text-fill:white; -fx-background-radius:50%;
                                  -fx-padding:8 10 8 10;"/>
                    <VBox spacing="2">
                        <!-- "OUI" en bleu si l'étudiant peut recommencer, "NON" en rouge sinon -->
                        <Label fx:id="labelPeutRecommencer" text="OUI"
                               style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#0ea5e9;"/>
                        <Label text="PEUT RECOMMENCER"
                               style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
                    </VBox>
                </HBox>

            </HBox>
        </VBox>

        <!--
            BOUTONS D'ACTION : 3 boutons de navigation en bas de l'écran.
            - "↺ Refaire le quiz"      : onRefaire() → recharge intro.fxml
            - "← Retour aux chapitres" : onRetour()  → callback vers la liste des chapitres
            - "🏠 Accueil"             : onAccueil() → navigue vers la page d'accueil
        -->
        <!-- ── Boutons ── -->
        <HBox spacing="14" alignment="CENTER">
            <!-- Bouton "Refaire" : dégradé cyan-bleu, coins très arrondis -->
            <Button text="↺   Refaire le quiz" onAction="#onRefaire"
                    style="-fx-background-color:linear-gradient(to right,#06b6d4,#0ea5e9);
                           -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;
                           -fx-padding:13 28 13 28; -fx-background-radius:30;
                           -fx-cursor:hand; -fx-border-width:0;"/>
            <!-- Bouton "Retour" : transparent avec bordure blanche -->
            <Button text="← Retour aux chapitres" onAction="#onRetour"
                    style="-fx-background-color:transparent; -fx-text-fill:white;
                           -fx-font-size:13; -fx-font-weight:700;
                           -fx-padding:13 28 13 28; -fx-background-radius:30;
                           -fx-cursor:hand; -fx-border-color:white; -fx-border-radius:30;
                           -fx-border-width:2;"/>
            <!-- Bouton "Accueil" : dégradé vert, coins très arrondis -->
            <Button text="🏠  Accueil" onAction="#onAccueil"
                    style="-fx-background-color:linear-gradient(to right,#22c55e,#16a34a);
                           -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;
                           -fx-padding:13 28 13 28; -fx-background-radius:30;
                           -fx-cursor:hand; -fx-border-width:0;"/>
        </HBox>

    </VBox>
</StackPane>

