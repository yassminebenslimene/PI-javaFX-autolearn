<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.FrontQuizController"
            maxHeight="Infinity" maxWidth="Infinity"
            style="-fx-background-color: linear-gradient(to bottom right, #46178F, #764ba2);">

    <!-- ================= TOP ================= -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding:14 24 14 24; -fx-background-color:rgba(0,0,0,0.25);">

            <Label fx:id="labelTitreHeader" text="Quiz"
                   style="-fx-text-fill:white; -fx-font-size:14; -fx-font-weight:700;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="labelTimer" text="⏱  —"
                   style="-fx-background-color:linear-gradient(to right,#f59e0b,#d97706);
                          -fx-text-fill:white; -fx-font-size:14; -fx-font-weight:800;
                          -fx-padding:6 18 6 18; -fx-background-radius:20;"/>
        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <VBox alignment="CENTER" spacing="25"
              style="-fx-padding:0 40 0 40;">

            <!-- Spacer TOP (limité pour monter le contenu) -->
            <Region VBox.vgrow="ALWAYS" maxHeight="80"/>

            <!-- Carte Question -->
            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color:white; -fx-background-radius:16;
                         -fx-padding:22 36 22 36;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.25),20,0,0,6);">

                <Label fx:id="labelProgress" text="Question 1 / 1"
                       style="-fx-text-fill:#94a3b8; -fx-font-size:12; -fx-font-weight:700;"/>

                <Label fx:id="labelQuestion" text=""
                       style="-fx-font-size:20; -fx-font-weight:900; -fx-text-fill:#0f172a;
                              -fx-text-alignment:CENTER;"
                       wrapText="true" maxWidth="700" alignment="CENTER"/>

                <Label fx:id="labelPoints" text="⭐ 10 points"
                       style="-fx-font-size:13; -fx-text-fill:#f59e0b; -fx-font-weight:700;"/>
            </VBox>

            <!-- Options (plus grandes) -->
            <GridPane fx:id="optionsGrid"
                      hgap="18" vgap="18"
                      alignment="CENTER"
                      maxWidth="900"
                      style="-fx-padding:10 0 10 0;">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                </columnConstraints>
            </GridPane>

            <!-- fallback -->
            <VBox fx:id="optionsContainer" spacing="12" visible="false" managed="false"/>

            <!-- Spacer BOTTOM -->
            <Region VBox.vgrow="ALWAYS"/>

        </VBox>
    </center>

    <!-- ================= BOTTOM ================= -->
    <bottom>
        <VBox spacing="0" style="-fx-padding:0 0 20 0;">

            <!-- Progress bar -->
            <StackPane prefHeight="10">
                <Region style="-fx-background-color:rgba(255,255,255,0.15); -fx-pref-height:10;"/>
                <ProgressBar fx:id="progressBar" progress="0.0"
                             prefHeight="10" maxWidth="Infinity"
                             style="-fx-accent:#22c55e; -fx-background-color:transparent;"/>
            </StackPane>

            <!-- Navigation -->
            <HBox alignment="CENTER" spacing="16"
                  style="-fx-padding:12 28 12 28; -fx-background-color:rgba(0,0,0,0.35); -fx-min-height:70;">

                <Button fx:id="btnPrev" text="❮" onAction="#onPrev"
                        minWidth="44" minHeight="44"
                        style="-fx-background-color:rgba(255,255,255,0.25); -fx-text-fill:white;
                               -fx-font-size:18; -fx-font-weight:900; -fx-background-radius:50%;"/>

                <Button fx:id="btnNext" text="❯" onAction="#onNext"
                        minWidth="44" minHeight="44"
                        style="-fx-background-color:rgba(255,255,255,0.25); -fx-text-fill:white;
                               -fx-font-size:18; -fx-font-weight:900; -fx-background-radius:50%;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="labelRepondues" text="0 / 0 questions répondues"
                       style="-fx-text-fill:rgba(255,255,255,0.9); -fx-font-size:13; -fx-font-weight:600;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="btnSoumettre" text="✔   Soumettre le Quiz"
                        onAction="#onSoumettre"
                        disable="true"
                        minWidth="200" minHeight="45"
                        style="-fx-background-color:rgba(255,255,255,0.18);
                               -fx-text-fill:rgba(255,255,255,0.5);
                               -fx-font-size:14; -fx-font-weight:700;
                               -fx-padding:10 24 10 24;
                               -fx-background-radius:24;">
                    <HBox.margin>
                        <Insets bottom="8"/>
                    </HBox.margin>
                </Button>

            </HBox>

        </VBox>
    </bottom>

    </BorderPane>