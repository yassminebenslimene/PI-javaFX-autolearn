<?xml version="1.0" encoding="UTF-8"?>
<!--
    ============================================================
    intro.fxml — Écran d'introduction du quiz (front-office)
    ============================================================

    Rôle :
      Présente le quiz à l'étudiant avant qu'il ne commence.
      Affiche le titre, la description, les statistiques clés
      (nombre de questions, total de points, durée) et propose
      deux actions : commencer le quiz ou retourner aux chapitres.

    Contrôleur associé : FrontQuizController
      - onCommencer() : lance l'écran de chargement puis les questions
      - onRetour()     : exécute le callback de retour aux chapitres

    Structure de la vue :
      StackPane (fond violet)
      ├── VBox (bouton retour en haut à gauche)
      └── VBox (carte blanche centrale)
          ├── Icône rouge (emoji 📱)
          ├── Titre du quiz (labelTitreQuiz)
          ├── Description du quiz (labelDescQuiz)
          ├── Bande de statistiques (HBox)
          │   ├── Nombre de questions (labelNbQuestions)
          │   ├── Total de points (labelTotalPoints)
          │   └── Durée en minutes (labelDuree)
          └── Bouton "Commencer le quiz"
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<!-- Conteneur racine : fond violet plein, occupe tout l'espace disponible -->
<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.FrontQuizController"
           style="-fx-background-color:#6b21a8;">

    <!-- Couche de fond : contient uniquement le bouton "Retour" en haut à gauche -->
    <!-- Fond violet avec effet diagonal (simulé par des rectangles) -->
    <VBox alignment="TOP_LEFT" style="-fx-background-color:transparent;">
        <!-- Bouton retour en haut à gauche -->
        <!-- Navigation : déclenche onRetour() → exécute le callback vers la liste des chapitres -->
        <HBox style="-fx-padding:18 0 0 18;">
            <Button text="← Retour aux chapitres" onAction="#onRetour"
                    style="-fx-background-color:rgba(255,255,255,0.18); -fx-text-fill:white;
                           -fx-font-size:13; -fx-font-weight:700; -fx-padding:9 18 9 18;
                           -fx-background-radius:22; -fx-cursor:hand; -fx-border-width:0;"/>
        </HBox>
    </VBox>

    <!-- Carte centrale blanche : contient toutes les informations du quiz -->
    <!-- maxWidth/maxHeight limitent la taille de la carte pour un rendu centré -->
    <!-- Card centrale -->
    <VBox alignment="CENTER" spacing="0" maxWidth="460" maxHeight="420"
          style="-fx-background-color:white; -fx-background-radius:20;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.35),32,0,0,10);">
        <padding><Insets top="36" right="36" bottom="36" left="36"/></padding>

        <!-- Icône décorative rouge en haut de la carte -->
        <!-- Icône rouge -->
        <HBox alignment="CENTER" style="-fx-padding:0 0 16 0;">
            <Label text="📱"
                   style="-fx-font-size:36; -fx-background-color:#e53935;
                          -fx-background-radius:16; -fx-padding:14 16 14 16;
                          -fx-text-fill:white;"/>
        </HBox>

        <!-- Titre du quiz : rempli dynamiquement par afficherIntro() -->
        <!-- Format : "Quiz - [titre du quiz]" -->
        <!-- Titre -->
        <Label fx:id="labelTitreQuiz" text="Quiz"
               style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#0f172a;
                      -fx-text-alignment:CENTER;"
               wrapText="true" maxWidth="380"/>

        <!-- Description du quiz : remplie depuis quiz.getDescription() -->
        <!-- Vide si la description est null -->
        <!-- Description -->
        <Label fx:id="labelDescQuiz" text=""
               style="-fx-font-size:13; -fx-text-fill:#7c3aed; -fx-text-alignment:CENTER;
                      -fx-padding:6 0 20 0;"
               wrapText="true" maxWidth="380"/>

        <!-- Bande de statistiques : 3 colonnes (questions, points, durée) -->
        <!-- Fond gris clair avec bordure, coins arrondis -->
        <!-- Stats -->
        <HBox spacing="0" alignment="CENTER"
              style="-fx-background-color:#f8fafc; -fx-background-radius:12;
                     -fx-border-color:#e2e8f0; -fx-border-radius:12;
                     -fx-padding:18 0 18 0; -fx-min-width:360;">

            <!-- Colonne 1 : Nombre de questions -->
            <!-- labelNbQuestions : rempli avec questions.size() -->
            <!-- Questions -->
            <VBox alignment="CENTER" spacing="6" prefWidth="120">
                <Label text="❓"
                       style="-fx-font-size:22; -fx-background-color:#ef4444;
                              -fx-background-radius:50%; -fx-padding:6 8 6 8;"/>
                <Label fx:id="labelNbQuestions" text="0"
                       style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                <Label text="QUESTIONS"
                       style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
            </VBox>

            <!-- Colonne 2 : Total des points du quiz -->
            <!-- labelTotalPoints : somme des points de toutes les questions -->
            <!-- Points -->
            <VBox alignment="CENTER" spacing="6" prefWidth="120">
                <Label text="⭐"
                       style="-fx-font-size:22; -fx-background-color:#f59e0b;
                              -fx-background-radius:50%; -fx-padding:6 8 6 8;"/>
                <Label fx:id="labelTotalPoints" text="0"
                       style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                <Label text="POINTS"
                       style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
            </VBox>

            <!-- Colonne 3 : Durée maximale en minutes -->
            <!-- labelDuree : affiche quiz.getDureeMaxMinutes() ou "—" si illimitée -->
            <!-- Minutes -->
            <VBox alignment="CENTER" spacing="6" prefWidth="120">
                <Label text="⏱"
                       style="-fx-font-size:22; -fx-background-color:#3b82f6;
                              -fx-background-radius:50%; -fx-padding:6 8 6 8;"/>
                <Label fx:id="labelDuree" text="—"
                       style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#0f172a;"/>
                <Label text="MINUTES"
                       style="-fx-font-size:10; -fx-text-fill:#94a3b8; -fx-font-weight:700;"/>
            </VBox>
        </HBox>

        <!-- Bouton principal : lance le quiz -->
        <!-- Navigation : onCommencer() → charge loading.fxml → puis question.fxml -->
        <!-- Bouton commencer -->
        <Button text="▶   Commencer le quiz" onAction="#onCommencer"
                maxWidth="Infinity"
                style="-fx-background-color:linear-gradient(to right,#22c55e,#16a34a);
                       -fx-text-fill:white; -fx-font-size:15; -fx-font-weight:800;
                       -fx-padding:14 0 14 0; -fx-background-radius:30;
                       -fx-cursor:hand; -fx-border-width:0;
                       -fx-effect:dropshadow(gaussian,rgba(34,197,94,0.5),12,0,0,4);">
            <VBox.margin><Insets top="22"/></VBox.margin>
        </Button>
    </VBox>

</StackPane>
