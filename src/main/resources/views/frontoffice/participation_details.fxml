<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.evenement.front.ParticipationDetailsController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f0f0f8;">

    <!-- NAVBAR fixe -->
        <top>
        <fx:include source="../components/navbar_front.fxml" fx:id="navbar"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f0f0f8; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0">
                <VBox spacing="28"
                      style="-fx-background-color:white; -fx-padding:48 120 48 120;">

                    <!-- Title + status -->
                    <VBox alignment="CENTER" spacing="12">
                        <Label text="Details de la participation"
                               style="-fx-font-size:26; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        <Label fx:id="labelStatut" text="&#10003; Accepte"
                               style="-fx-background-color:#d1fae5; -fx-text-fill:#065f46; -fx-font-size:13;
                                      -fx-font-weight:700; -fx-background-radius:20; -fx-padding:6 18 6 18;"/>
                    </VBox>

                    <Separator style="-fx-background-color:#eeeeee;"/>

                    <!-- Event info -->
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📅" style="-fx-font-size:16;"/>
                            <Label text="Informations sur l'evenement"
                                   style="-fx-font-size:16; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                        </HBox>
                        <HBox spacing="12">
                            <VBox fx:id="cardEventName" spacing="4" prefWidth="200"
                                  style="-fx-background-color:#f8f8ff; -fx-background-radius:10;
                                         -fx-border-color:#e8e4ff; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16;">
                                <Label text="Nom de l'evenement" style="-fx-font-size:11; -fx-text-fill:#888;"/>
                                <Label fx:id="labelEventName" text="" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </VBox>
                            <VBox spacing="4" prefWidth="200"
                                  style="-fx-background-color:#f8f8ff; -fx-background-radius:10;
                                         -fx-border-color:#e8e4ff; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16;">
                                <Label text="Lieu" style="-fx-font-size:11; -fx-text-fill:#888;"/>
                                <Label fx:id="labelLieu" text="" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </VBox>
                            <VBox spacing="4" prefWidth="200"
                                  style="-fx-background-color:#f8f8ff; -fx-background-radius:10;
                                         -fx-border-color:#e8e4ff; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16;">
                                <Label text="Type" style="-fx-font-size:11; -fx-text-fill:#888;"/>
                                <Label fx:id="labelType" text="" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="12">
                            <VBox spacing="4" prefWidth="200"
                                  style="-fx-background-color:#f8f8ff; -fx-background-radius:10;
                                         -fx-border-color:#e8e4ff; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16;">
                                <Label text="Date de debut" style="-fx-font-size:11; -fx-text-fill:#888;"/>
                                <Label fx:id="labelDateDebut" text="" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </VBox>
                            <VBox spacing="4" prefWidth="200"
                                  style="-fx-background-color:#f8f8ff; -fx-background-radius:10;
                                         -fx-border-color:#e8e4ff; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16;">
                                <Label text="Date de fin" style="-fx-font-size:11; -fx-text-fill:#888;"/>
                                <Label fx:id="labelDateFin" text="" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </VBox>
                            <VBox spacing="4" prefWidth="200"
                                  style="-fx-background-color:#f8f8ff; -fx-background-radius:10;
                                         -fx-border-color:#e8e4ff; -fx-border-radius:10; -fx-border-width:1; -fx-padding:16;">
                                <Label text="Equipes max" style="-fx-font-size:11; -fx-text-fill:#888;"/>
                                <Label fx:id="labelNbMax" text="" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Team members -->
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="👥" style="-fx-font-size:16;"/>
                            <Label fx:id="labelTeamTitle" text="Team:"
                                   style="-fx-font-size:16; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                        </HBox>
                        <VBox fx:id="membersContainer" spacing="8"/>
                    </VBox>

                    <!-- Participation status -->
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="ℹ" style="-fx-font-size:16;"/>
                            <Label text="Statut de la participation"
                                   style="-fx-font-size:16; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                        </HBox>
                        <VBox style="-fx-background-color:#f0f9ff; -fx-background-radius:10;
                                    -fx-border-color:#bae6fd; -fx-border-radius:10; -fx-border-width:0 0 0 4;
                                    -fx-border-color:#7a6ad8; -fx-padding:16;">
                            <Label text="&#10003;  Votre participation a ete acceptee !"
                                   style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#1e4d8c;"/>
                            <Label text="Votre equipe est inscrite a cet evenement. A bientot !"
                                   style="-fx-font-size:12; -fx-text-fill:#555;"/>
                        </VBox>
                    </VBox>

                    <Separator style="-fx-background-color:#eeeeee;"/>

                    <!-- Action buttons -->
                    <HBox spacing="12" alignment="CENTER">
                        <Button text="&#128640;  Modifier la participation" onAction="#onEditParticipation"
                                style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:13;
                                       -fx-font-weight:700; -fx-padding:12 24 12 24; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-width:0;"/>
                        <Button text="&#128465;  Supprimer la participation" onAction="#onDeleteParticipation"
                                style="-fx-background-color:#fee2e2; -fx-text-fill:#dc2626; -fx-font-size:13;
                                       -fx-font-weight:600; -fx-padding:12 24 12 24; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-color:#fca5a5; -fx-border-width:1; -fx-border-radius:10;"/>
                        <Button text="&#8592; Retour a mes participations" onAction="#onBack"
                                style="-fx-background-color:white; -fx-text-fill:#555; -fx-font-size:13;
                                       -fx-font-weight:600; -fx-padding:12 24 12 24; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-color:#ddd; -fx-border-width:1; -fx-border-radius:10;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="56" style="-fx-background-color:#1e1e1e;">
            <Label text="&#169; 2026 AutoLearn &#8212; Tous droits r&#233;serv&#233;s"
                   style="-fx-text-fill:rgba(255,255,255,0.45); -fx-font-size:12;"/>
        </HBox>
    </bottom>
</BorderPane>