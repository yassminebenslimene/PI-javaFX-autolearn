<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.evenement.front.EvenementFrontController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f4f3ff;">

    <top>
        <fx:include source="../components/navbar_front.fxml" fx:id="navbar"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f4f3ff; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0">

                <!-- Hero header -->
                <VBox alignment="CENTER" spacing="14" prefHeight="170"
                      style="-fx-background-color:linear-gradient(to bottom right,#7a6ad8,#4e3b9c);
                             -fx-padding:44 80 44 80;">
                    <Label text="🎉  Nos Événements"
                           style="-fx-font-size:36; -fx-font-weight:800; -fx-text-fill:white;"/>
                    <Label text="Participez, apprenez et connectez-vous avec vos pairs"
                           style="-fx-font-size:14; -fx-text-fill:rgba(255,255,255,0.8);"/>
                    <Button text="📅  Voir le Calendrier" onAction="#onVoirCalendrier"
                            style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                   -fx-font-size:13; -fx-font-weight:600; -fx-padding:9 26 9 26;
                                   -fx-background-radius:22; -fx-border-color:rgba(255,255,255,0.5);
                                   -fx-border-radius:22; -fx-cursor:hand; -fx-border-width:1.5;"/>
                </VBox>

                <!-- Intro -->
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color:white; -fx-padding:20 80 20 80;
                             -fx-border-color:#eeeeee; -fx-border-width:0 0 1 0;">
                    <Label text="🎯  Développez vos compétences par la pratique"
                           style="-fx-font-size:14; -fx-font-weight:700; -fx-text-fill:#333;"/>
                    <Label text="Hackathons, workshops, conférences — rejoignez une équipe et participez !"
                           wrapText="true"
                           style="-fx-font-size:12; -fx-text-fill:#666; -fx-text-alignment:CENTER;"/>
                </VBox>

                <!-- Filtres + compteur -->
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color:#f4f3ff; -fx-padding:20 40 14 40;">
                    <HBox fx:id="filterBar" spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="labelTotal" style="-fx-font-size:13; -fx-font-weight:700;"/>
                </HBox>

                <!-- Grille des événements -->
                <VBox fx:id="eventsContainer" spacing="0"
                      style="-fx-padding:0 40 40 40; -fx-background-color:#f4f3ff;"/>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="50" style="-fx-background-color:#1e1e1e;">
            <Label text="© 2026 AutoLearn — Tous droits réservés"
                   style="-fx-text-fill:rgba(255,255,255,0.4); -fx-font-size:12;"/>
        </HBox>
    </bottom>
</BorderPane>
