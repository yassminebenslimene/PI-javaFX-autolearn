<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color:transparent; -fx-background:#f4f6fb; -fx-border-width:0;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.FrontChapitreDetailController">
    <content>
        <VBox spacing="0" style="-fx-background-color:#f4f6fb;">

            <!-- HEADER -->
            <VBox spacing="10"
                  style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                         -fx-padding:24 60 24 60;">
                <HBox alignment="CENTER_LEFT">
                    <Button text="← Retour aux chapitres" onAction="#onRetour"
                            style="-fx-background-color:rgba(255,255,255,0.18); -fx-text-fill:white;
                                   -fx-font-size:12; -fx-font-weight:600; -fx-padding:7 16 7 16;
                                   -fx-background-radius:20; -fx-cursor:hand; -fx-border-width:0;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnQuiz" text="❓  Passer le quiz" onAction="#onQuiz"
                            style="-fx-background-color:linear-gradient(to right,#f59e0b,#d97706);
                                   -fx-text-fill:white; -fx-font-size:12; -fx-font-weight:700;
                                   -fx-padding:7 18 7 18; -fx-background-radius:20;
                                   -fx-cursor:hand; -fx-border-width:0;"/>
                </HBox>
                <Label fx:id="labelBadge"
                       style="-fx-font-size:11; -fx-font-weight:700; -fx-text-fill:white;
                              -fx-background-color:rgba(255,255,255,0.2); -fx-background-radius:20;
                              -fx-padding:4 14 4 14;"/>
                <Label fx:id="labelTitre"
                       style="-fx-text-fill:white; -fx-font-size:26; -fx-font-weight:900;"
                       wrapText="true"/>
                <Label fx:id="labelCours"
                       style="-fx-text-fill:rgba(255,255,255,0.7); -fx-font-size:12;"/>
            </VBox>

            <!-- CONTENU PRINCIPAL -->
            <HBox spacing="24" style="-fx-padding:32 60 40 60; -fx-background-color:#f4f6fb;"
                  alignment="TOP_LEFT">

                <!-- Article principal -->
                <VBox spacing="0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white; -fx-background-radius:16;
                             -fx-border-color:#eeeeee; -fx-border-radius:16;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),12,0,0,3);">

                    <!-- WebView pour rendre le HTML proprement -->
                    <WebView fx:id="webContent" prefHeight="520"
                             style="-fx-background-color:white; -fx-background-radius:16;"/>

                    <!-- Ressource si disponible -->
                    <VBox fx:id="boxRessource" spacing="8" managed="false" visible="false"
                          style="-fx-padding:16 24 20 24; -fx-border-color:#f0f0f0 transparent transparent transparent;
                                 -fx-border-width:1 0 0 0;">
                        <Label text="🔗  Ressource"
                               style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                        <Label fx:id="labelRessource"
                               style="-fx-text-fill:#2563eb; -fx-font-size:13;" wrapText="true"/>
                    </VBox>
                </VBox>

                <!-- Sidebar navigation -->
                <VBox spacing="12" prefWidth="220" minWidth="220">

                    <!-- Progression -->
                    <VBox spacing="8"
                          style="-fx-background-color:white; -fx-background-radius:14;
                                 -fx-border-color:#eeeeee; -fx-border-radius:14; -fx-padding:16;">
                        <Label text="Navigation"
                               style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                        <Separator/>
                        <Button fx:id="btnSuivant" text="Chapitre suivant →" onAction="#onSuivant"
                                maxWidth="Infinity"
                                style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                                       -fx-text-fill:white; -fx-font-weight:700; -fx-font-size:12;
                                       -fx-padding:10 0 10 0; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-width:0;"/>
                        <Button text="📄  Télécharger PDF" onAction="#onPdf"
                                maxWidth="Infinity"
                                style="-fx-background-color:linear-gradient(to right,#7c3aed,#6d28d9);
                                       -fx-text-fill:white; -fx-font-weight:700; -fx-font-size:12;
                                       -fx-padding:10 0 10 0; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-width:0;"/>
                    </VBox>

                    <!-- Info chapitre -->
                    <VBox spacing="10"
                          style="-fx-background-color:white; -fx-background-radius:14;
                                 -fx-border-color:#eeeeee; -fx-border-radius:14; -fx-padding:16;">
                        <Label text="Infos"
                               style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                        <Separator/>
                        <Label fx:id="labelInfoType"
                               style="-fx-font-size:12; -fx-text-fill:#555;"/>
                        <Label fx:id="labelInfoFichier"
                               style="-fx-font-size:12; -fx-text-fill:#555;" wrapText="true"/>
                    </VBox>
                </VBox>
            </HBox>

        </VBox>
    </content>
</ScrollPane>
