<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color:transparent; -fx-background:#f4f6fb; -fx-border-width:0;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.FrontChapitreController">
    <content>
        <VBox spacing="0" style="-fx-background-color:#f4f6fb;">

            <!-- HEADER BANNER avec bouton retour -->
            <VBox spacing="10"
                  style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                         -fx-padding:28 60 28 60;">
                <!-- Bouton retour en haut à droite -->
                <HBox alignment="CENTER_LEFT">
                    <Button text="← Retour aux cours" onAction="#onRetourCours"
                            style="-fx-background-color:rgba(255,255,255,0.18); -fx-text-fill:white;
                                   -fx-font-size:12; -fx-font-weight:600; -fx-padding:7 16 7 16;
                                   -fx-background-radius:20; -fx-cursor:hand; -fx-border-width:0;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label fx:id="labelCourseTitle" text="Chapitres"
                       style="-fx-text-fill:white; -fx-font-size:26; -fx-font-weight:900;"/>
                <Label fx:id="labelCourseMeta"
                       style="-fx-text-fill:rgba(255,255,255,0.75); -fx-font-size:13; -fx-font-weight:600;"/>
            </VBox>

            <!-- EMPTY STATE -->
            <Label fx:id="labelEmpty" text="Aucun chapitre disponible pour ce cours."
                   visible="false" managed="false"
                   style="-fx-text-fill:#94a3b8; -fx-font-size:14; -fx-padding:40 60 0 60;"/>

            <!-- CARDS GRID -->
            <VBox fx:id="chaptersContainer" spacing="0"
                  style="-fx-padding:24 60 40 60;"/>

        </VBox>
    </content>
</ScrollPane>

