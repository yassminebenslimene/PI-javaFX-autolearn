<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.FrontCommunauteDetailController"
      style="-fx-background-color:#f5f5f5;">
    <top>
        <fx:include source="../../components/navbar_front.fxml" fx:id="navbar"/>
    </top>
    <center>
    <VBox spacing="0" style="-fx-background-color:#f5f5f5;">

    <!-- Header communauté -->
    <VBox spacing="10" style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                               -fx-padding:36 80 36 80;">
        <Button text="← Retour" onAction="#onRetour"
                style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                       -fx-font-size:12; -fx-padding:6 16 6 16; -fx-background-radius:20;
                       -fx-cursor:hand; -fx-border-width:0;"/>
        <Label fx:id="labelNom" text=""
               style="-fx-font-size:28; -fx-font-weight:800; -fx-text-fill:white;"/>
        <Label fx:id="labelDescription" text="" wrapText="true"
               style="-fx-font-size:14; -fx-text-fill:rgba(255,255,255,0.75);"/>
        <!-- Bouton membres visible uniquement pour le owner -->
        <Button fx:id="btnGererMembres" text="👥  Gérer les membres" onAction="#onGererMembres"
                visible="false" managed="false"
                style="-fx-background-color:rgba(255,255,255,0.2); -fx-text-fill:white;
                       -fx-font-size:12; -fx-font-weight:600; -fx-padding:7 18 7 18;
                       -fx-background-radius:20; -fx-cursor:hand; -fx-border-width:0;"/>
    </VBox>

    <!-- Posts section -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-padding:32 80 32 80;" spacing="20">

        <!-- New post -->
        <VBox spacing="10" style="-fx-background-color:white; -fx-background-radius:14;
                                   -fx-border-color:#eeeeee; -fx-border-radius:14;
                                   -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);
                                   -fx-padding:20;">
            <Label text="Nouveau post" style="-fx-font-size:14; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
            <TextField fx:id="fieldTitre" promptText="Titre du post"
                       style="-fx-background-color:#f5f5f5; -fx-background-radius:8;
                              -fx-border-width:0; -fx-padding:10 14 10 14; -fx-font-size:13;"/>
            <TextArea fx:id="fieldContenu" promptText="Contenu..." prefRowCount="3"
                      style="-fx-background-color:#f5f5f5; -fx-background-radius:8;
                             -fx-border-width:0; -fx-padding:10 14 10 14; -fx-font-size:13;"/>
            <HBox alignment="CENTER_RIGHT">
                <Button text="Publier" onAction="#onPublier"
                        style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-weight:700;
                               -fx-font-size:13; -fx-padding:9 24 9 24; -fx-background-radius:10;
                               -fx-cursor:hand; -fx-border-width:0;"/>
            </HBox>
        </VBox>

        <!-- Posts list -->
        <HBox alignment="CENTER_RIGHT">
            <Button text="🔄  Rafraîchir" onAction="#onRefresh"
                    style="-fx-background-color:transparent; -fx-text-fill:#7a6ad8;
                           -fx-font-size:12; -fx-font-weight:600; -fx-cursor:hand;
                           -fx-border-color:#7a6ad8; -fx-border-radius:8; -fx-border-width:1;
                           -fx-padding:6 14 6 14; -fx-background-radius:8;"/>
        </HBox>
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-width:0;">
            <VBox fx:id="postsPane" spacing="16"/>
        </ScrollPane>
    </VBox>
</VBox>
    </center>
</BorderPane>
