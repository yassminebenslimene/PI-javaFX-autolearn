<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.FrontCommunauteController"
      style="-fx-background-color:#f5f5f5;">
    <top>
        <fx:include source="../../components/navbar_front.fxml" fx:id="navbar"/>
    </top>
    <center>
    <VBox spacing="0" style="-fx-background-color:#f5f5f5;">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="12" prefHeight="180"
          style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c); -fx-padding:40 80 40 80;">
        <Label text="👥  Communautés"
               style="-fx-font-size:30; -fx-font-weight:800; -fx-text-fill:white;"/>
        <Label text="Rejoignez une communauté et partagez vos connaissances"
               style="-fx-font-size:14; -fx-text-fill:rgba(255,255,255,0.75);"/>
        <HBox alignment="CENTER" spacing="12">
            <TextField fx:id="searchField" promptText="🔍  Rechercher..."
                       prefWidth="300"
                       style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                              -fx-prompt-text-fill:rgba(255,255,255,0.5); -fx-background-radius:30;
                              -fx-border-width:0; -fx-padding:10 20 10 20; -fx-font-size:13;"/>
            <Button text="＋  Créer une communauté" onAction="#onCreer"
                    style="-fx-background-color:white; -fx-text-fill:#7a6ad8; -fx-font-weight:700;
                           -fx-font-size:13; -fx-padding:10 20 10 20; -fx-background-radius:30;
                           -fx-cursor:hand; -fx-border-width:0;"/>
        </HBox>
    </VBox>

    <!-- Cards grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:#f5f5f5; -fx-background:transparent; -fx-border-width:0;">
        <VBox style="-fx-padding:36 80 36 80;" spacing="0">
            <FlowPane fx:id="cardsPane" hgap="24" vgap="24"
                      style="-fx-background-color:transparent;"/>
            <Label fx:id="emptyLabel" text="Aucune communauté disponible."
                   style="-fx-text-fill:#aaa; -fx-font-size:14;" visible="false"/>
        </VBox>
    </ScrollPane>
</VBox>
    </center>
</BorderPane>
