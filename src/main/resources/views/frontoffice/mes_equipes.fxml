<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.evenement.front.MesEquipesController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f0f0f8;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.96);
                     -fx-min-height:68; -fx-max-height:68;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),10,0,0,3);">
            <padding><Insets left="36" right="36"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="&#127891;" style="-fx-font-size:24;"/>
                <Label text="AutoLearn" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:white;"/>
            </HBox>
            <HBox spacing="0" alignment="CENTER" style="-fx-padding:0 0 0 36;">
                <Button text="Accueil" onAction="#onHome"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
                <Button text="Evenements" onAction="#onEvenements"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="12">
                <Label fx:id="labelAvatarNav"
                       style="-fx-background-color:rgba(255,255,255,0.25); -fx-text-fill:white;
                              -fx-font-weight:700; -fx-font-size:14; -fx-background-radius:50%;
                              -fx-padding:8 11 8 11;"/>
                <Label fx:id="labelCurrentUser" text=""
                       style="-fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;"/>
                <MenuButton fx:id="menuUser" text="&#9662;"
                            style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                   -fx-font-size:13; -fx-padding:7 14 7 14; -fx-background-radius:20;
                                   -fx-cursor:hand; -fx-border-width:0;">
                    <items>
                        <MenuItem text="Mon Profil" onAction="#onProfile"/>
                        <MenuItem text="Mes Participations" onAction="#onMesParticipations"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Deconnexion" onAction="#onLogout"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f0f0f8; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0">
                <!-- Header -->
                <VBox alignment="CENTER" spacing="12" prefHeight="160"
                      style="-fx-background-color:linear-gradient(to bottom right,#7a6ad8,#4e3b9c); -fx-padding:30 80 30 80;">
                    <Button text="&#8592; Retour aux evenements" onAction="#onEvenements"
                            style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                   -fx-font-size:12; -fx-padding:6 16 6 16; -fx-background-radius:20;
                                   -fx-cursor:hand; -fx-border-width:0;"/>
                    <Label text="Mes Equipes"
                           style="-fx-font-size:30; -fx-font-weight:800; -fx-text-fill:white;"/>
                    <Label text="Creez et gerez vos equipes pour les evenements"
                           style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.75);"/>
                    <Button text="+ Creer une nouvelle equipe" onAction="#onCreateNewTeam"
                            style="-fx-background-color:white; -fx-text-fill:#7a6ad8; -fx-font-size:13;
                                   -fx-font-weight:700; -fx-padding:10 28 10 28; -fx-background-radius:30;
                                   -fx-cursor:hand; -fx-border-width:0;
                                   -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),8,0,0,3);"/>
                </VBox>

                <!-- Success banner -->
                <VBox fx:id="successBannerContainer" style="-fx-padding:16 80 0 80; -fx-background-color:#f0f0f8;">
                    <Label fx:id="labelSuccessBanner" text="" wrapText="true"
                           style="-fx-background-color:#d1fae5; -fx-text-fill:#065f46; -fx-font-size:13;
                                  -fx-font-weight:600; -fx-background-radius:8; -fx-padding:12 16 12 16;
                                  -fx-border-color:#6ee7b7; -fx-border-radius:8; -fx-border-width:1;"/>
                </VBox>

                <!-- Teams grid -->
                <VBox fx:id="teamsContainer" spacing="16"
                      style="-fx-padding:24 80 32 80; -fx-background-color:#f0f0f8;"/>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="56" style="-fx-background-color:#1e1e1e;">
            <Label text="&#169; 2026 AutoLearn - Tous droits reserves"
                   style="-fx-text-fill:rgba(255,255,255,0.45); -fx-font-size:12;"/>
        </HBox>
    </bottom>
</BorderPane>
