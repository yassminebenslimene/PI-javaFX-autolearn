<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.evenement.front.CreateTeamController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f0f0f8;">

        <top>
        <fx:include source="../components/navbar_front.fxml" fx:id="navbar"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f0f0f8; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0">
                <VBox alignment="CENTER" spacing="24"
                      style="-fx-background-color:white; -fx-padding:48 200 48 200;">

                    <Label text="Creer une nouvelle equipe"
                           style="-fx-font-size:28; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                    <Label fx:id="labelForEvent" text=""
                           style="-fx-font-size:13; -fx-text-fill:#666;"/>

                    <VBox spacing="6" maxWidth="500">
                        <Label text="Nom de l'equipe"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#333;"/>
                        <TextField fx:id="fieldNomEquipe" promptText="Ex: Les Champions"
                                   style="-fx-font-size:13; -fx-padding:10 14 10 14; -fx-background-radius:8;
                                          -fx-border-color:#ddd; -fx-border-radius:8; -fx-border-width:1;"/>
                    </VBox>

                    <VBox spacing="10" maxWidth="500">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="Membres de l'equipe (4 a 6 etudiants)"
                                   style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#333;"/>
                            <Label fx:id="labelCount" text="0 selectionne"
                                   style="-fx-background-color:#7a6ad8; -fx-text-fill:white;
                                          -fx-font-size:11; -fx-font-weight:700; -fx-background-radius:20;
                                          -fx-padding:3 10 3 10;"/>
                        </HBox>
                        <VBox spacing="4"
                              style="-fx-background-color:#eff6ff; -fx-background-radius:8;
                                     -fx-border-color:#bfdbfe; -fx-border-radius:8; -fx-border-width:1;
                                     -fx-padding:12;">
                            <Label text="Comment selectionner les etudiants :"
                                   style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#1d4ed8;"/>
                            <Label text="- Cochez les cases a cote des etudiants que vous voulez dans votre equipe"
                                   style="-fx-font-size:11; -fx-text-fill:#374151;"/>
                            <Label text="- Vous devez selectionner entre 4 et 6 etudiants"
                                   style="-fx-font-size:11; -fx-text-fill:#374151;"/>
                            <Label text="- Cliquez a nouveau sur une case cochee pour la decocher"
                                   style="-fx-font-size:11; -fx-text-fill:#374151;"/>
                        </VBox>
                        <ScrollPane prefHeight="260" fitToWidth="true" hbarPolicy="NEVER"
                                    style="-fx-background-color:transparent; -fx-border-color:#ddd; -fx-border-radius:8;">
                            <VBox fx:id="studentsContainer" spacing="0"/>
                        </ScrollPane>
                    </VBox>

                    <Label fx:id="labelError" text="" wrapText="true"
                           style="-fx-text-fill:#e94560; -fx-font-size:12;"/>

                    <HBox spacing="16" alignment="CENTER">
                        <Button text="Creer l'equipe" onAction="#onCreateTeam"
                                style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:13;
                                       -fx-font-weight:700; -fx-padding:12 32 12 32; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-width:0;"/>
                        <Button text="Annuler" onAction="#onCancel"
                                style="-fx-background-color:white; -fx-text-fill:#555; -fx-font-size:13;
                                       -fx-font-weight:600; -fx-padding:12 32 12 32; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-color:#ddd; -fx-border-width:1; -fx-border-radius:10;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="56" style="-fx-background-color:#1e1e1e;">
            <Label text="&#169; 2026 AutoLearn - Tous droits reserves"
                   style="-fx-text-fill:rgba(255,255,255,0.45); -fx-font-size:12;"/>
        </HBox>
    </bottom>
</BorderPane>
