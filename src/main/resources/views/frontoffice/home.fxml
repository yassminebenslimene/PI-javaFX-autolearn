<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color:linear-gradient(to bottom right,#e2e8f0,#f8fafc);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <Label text="Bienvenue dans votre espace etudiant" style="-fx-text-fill:#0f172a; -fx-font-size:34; -fx-font-weight:900;"/>
    <Label text="Consultez les cours disponibles puis ouvrez les chapitres pour commencer votre apprentissage." wrapText="true"
           style="-fx-text-fill:#334155; -fx-font-size:15; -fx-max-width:700;"/>

    <VBox spacing="10" style="-fx-background-color:white; -fx-background-radius:14; -fx-border-color:#dbeafe; -fx-border-radius:14; -fx-padding:18;">
        <Label text="Conseil" style="-fx-text-fill:#1d4ed8; -fx-font-size:14; -fx-font-weight:800;"/>
        <Label text="Commencez par les cours de votre niveau pour avancer de maniere progressive." wrapText="true"
               style="-fx-text-fill:#334155; -fx-font-size:13;"/>
    </VBox>
</VBox>

