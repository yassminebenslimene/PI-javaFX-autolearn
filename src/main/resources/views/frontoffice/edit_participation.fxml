<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.evenement.front.EditParticipationController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f0f0f8;">

    <!-- NAVBAR fixe -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.96);
                     -fx-min-height:68; -fx-max-height:68;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),10,0,0,3);">
            <padding><Insets left="36" right="36"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🎓" style="-fx-font-size:24;"/>
                <Label text="AutoLearn" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:white;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="12">
                <Label fx:id="labelAvatarNav"
                       style="-fx-background-color:rgba(255,255,255,0.25); -fx-text-fill:white;
                              -fx-font-weight:700; -fx-font-size:14; -fx-background-radius:50%;
                              -fx-padding:8 11 8 11;"/>
                <Label fx:id="labelCurrentUser" text=""
                       style="-fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;"/>
                <MenuButton fx:id="menuUser" text="▾"
                            style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                   -fx-font-size:13; -fx-padding:7 14 7 14; -fx-background-radius:20;
                                   -fx-cursor:hand; -fx-border-width:0;">
                    <items>
                        <MenuItem text="👤  Mon Profil" onAction="#onProfile"/>
                        <MenuItem text="🏆  Mes Participations" onAction="#onMesParticipations"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="⎋  Déconnexion" onAction="#onLogout"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f0f0f8; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0">
                <VBox alignment="CENTER" spacing="24"
                      style="-fx-background-color:white; -fx-padding:48 200 48 200;">

                    <Label text="Modifier la participation"
                           style="-fx-font-size:26; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                    <Label text="Mettez a jour les details de votre participation"
                           style="-fx-font-size:13; -fx-text-fill:#666;"/>

                    <!-- Note -->
                    <VBox style="-fx-background-color:#eff6ff; -fx-background-radius:8;
                                 -fx-border-color:#bfdbfe; -fx-border-radius:8; -fx-border-width:1; -fx-padding:14;"
                          maxWidth="500">
                        <Label text="Note: Modifier l'equipe ou l'evenement re-validera la participation selon la capacite et les regles de disponibilite."
                               wrapText="true" style="-fx-font-size:12; -fx-text-fill:#1d4ed8;"/>
                    </VBox>

                    <!-- Equipe dropdown -->
                    <VBox spacing="6" maxWidth="500">
                        <Label text="Votre équipe"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#333;"/>
                        <ComboBox fx:id="comboEquipe" prefWidth="500"
                                  style="-fx-font-size:13; -fx-padding:4; -fx-background-radius:8;
                                         -fx-border-color:#ddd; -fx-border-radius:8; -fx-border-width:1;"/>
                        <Label text="Selectionnez l'equipe participant a cet evenement"
                               style="-fx-font-size:11; -fx-text-fill:#888;"/>
                    </VBox>

                    <!-- Evenement dropdown -->
                    <VBox spacing="6" maxWidth="500">
                        <Label text="Événement"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#333;"/>
                        <ComboBox fx:id="comboEvenement" prefWidth="500"
                                  style="-fx-font-size:13; -fx-padding:4; -fx-background-radius:8;
                                         -fx-border-color:#ddd; -fx-border-radius:8; -fx-border-width:1;"/>
                        <Label text="Selectionnez l'evenement auquel participer"
                               style="-fx-font-size:11; -fx-text-fill:#888;"/>
                    </VBox>

                    <Label fx:id="labelError" text="" wrapText="true"
                           style="-fx-text-fill:#e94560; -fx-font-size:12;"/>

                    <!-- Buttons -->
                    <HBox spacing="16" alignment="CENTER">
                        <Button text="&#10003;  Mettre a jour la participation" onAction="#onUpdate"
                                style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:13;
                                       -fx-font-weight:700; -fx-padding:12 32 12 32; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-width:0;"/>
                        <Button text="&#10007;  Annuler" onAction="#onCancel"
                                style="-fx-background-color:white; -fx-text-fill:#555; -fx-font-size:13;
                                       -fx-font-weight:600; -fx-padding:12 32 12 32; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-color:#ddd; -fx-border-width:1; -fx-border-radius:10;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="56" style="-fx-background-color:#1e1e1e;">
            <Label text="&#169; 2026 AutoLearn &#8212; Tous droits r&#233;serv&#233;s"
                   style="-fx-text-fill:rgba(255,255,255,0.45); -fx-font-size:12;"/>
        </HBox>
    </bottom>
</BorderPane>