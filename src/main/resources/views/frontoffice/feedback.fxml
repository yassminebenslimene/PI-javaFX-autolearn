<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.evenement.front.FeedbackController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f0f0f8;">

        <top>
        <fx:include source="../components/navbar_front.fxml" fx:id="navbar"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f0f0f8; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0">
                <!-- Header -->
                <VBox alignment="CENTER" spacing="6" prefHeight="130"
                      style="-fx-background-color:linear-gradient(to bottom right,#7a6ad8,#4e3b9c); -fx-padding:28 80 28 80;">
                    <Label text="&#128203;  Votre Feedback"
                           style="-fx-font-size:26; -fx-font-weight:800; -fx-text-fill:white;"/>
                    <Label fx:id="labelEventName" text=""
                           style="-fx-font-size:15; -fx-font-weight:700; -fx-text-fill:white;"/>
                    <Label fx:id="labelEventMeta" text=""
                           style="-fx-font-size:12; -fx-text-fill:rgba(255,255,255,0.7);"/>
                </VBox>

                <!-- Form -->
                <VBox spacing="0" style="-fx-background-color:white; -fx-padding:40 200 40 200;">

                    <!-- Evaluation Globale -->
                    <VBox spacing="12" style="-fx-padding:0 0 24 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="&#11088;" style="-fx-font-size:18;"/>
                            <Label text="Evaluation Globale"
                                   style="-fx-font-size:15; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        </HBox>
                        <Label text="Comment evaluez-vous cet evenement dans son ensemble?"
                               style="-fx-font-size:12; -fx-text-fill:#666;"/>
                        <HBox fx:id="starsGlobal" spacing="8" alignment="CENTER"/>
                        <Label fx:id="labelGlobalRating" text="Cliquez sur les etoiles"
                               style="-fx-font-size:12; -fx-text-fill:#888; -fx-alignment:CENTER;"/>
                    </VBox>

                    <Separator style="-fx-background-color:#eeeeee;"/>

                    <!-- Evaluation Detaillee -->
                    <VBox spacing="16" style="-fx-padding:24 0 24 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="&#128202;" style="-fx-font-size:18;"/>
                            <Label text="Evaluation Detaillee"
                                   style="-fx-font-size:15; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        </HBox>
                        <!-- Organisation -->
                        <VBox spacing="6">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="&#127919; Organisation" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#333;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="badgeOrga" text=""
                                       style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:11;
                                              -fx-font-weight:700; -fx-background-radius:20; -fx-padding:2 10 2 10;"/>
                            </HBox>
                            <HBox fx:id="starsOrga" spacing="6"/>
                        </VBox>
                        <!-- Contenu -->
                        <VBox spacing="6">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="&#128218; Contenu" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#333;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="badgeContenu" text=""
                                       style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:11;
                                              -fx-font-weight:700; -fx-background-radius:20; -fx-padding:2 10 2 10;"/>
                            </HBox>
                            <HBox fx:id="starsContenu" spacing="6"/>
                        </VBox>
                        <!-- Lieu -->
                        <VBox spacing="6">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="&#128205; Lieu / Infrastructure" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#333;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="badgeLieu" text=""
                                       style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:11;
                                              -fx-font-weight:700; -fx-background-radius:20; -fx-padding:2 10 2 10;"/>
                            </HBox>
                            <HBox fx:id="starsLieu" spacing="6"/>
                        </VBox>
                        <!-- Animation -->
                        <VBox spacing="6">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="&#127908; Animation / Intervenants" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#333;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="badgeAnimation" text=""
                                       style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:11;
                                              -fx-font-weight:700; -fx-background-radius:20; -fx-padding:2 10 2 10;"/>
                            </HBox>
                            <HBox fx:id="starsAnimation" spacing="6"/>
                        </VBox>
                    </VBox>

                    <Separator style="-fx-background-color:#eeeeee;"/>

                    <!-- Ressenti -->
                    <VBox spacing="12" style="-fx-padding:24 0 24 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="&#128522;" style="-fx-font-size:18;"/>
                            <Label text="Votre Ressenti"
                                   style="-fx-font-size:15; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        </HBox>
                        <Label text="Comment vous etes-vous senti pendant cet evenement?"
                               style="-fx-font-size:12; -fx-text-fill:#666;"/>
                        <HBox fx:id="sentimentBox" spacing="12" alignment="CENTER_LEFT"/>
                    </VBox>

                    <Separator style="-fx-background-color:#eeeeee;"/>

                    <!-- Commentaire -->
                    <VBox spacing="10" style="-fx-padding:24 0 24 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="&#128172;" style="-fx-font-size:18;"/>
                            <Label text="Votre Commentaire"
                                   style="-fx-font-size:15; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        </HBox>
                        <Label text="Partagez vos impressions, suggestions ou remarques (optionnel)"
                               style="-fx-font-size:12; -fx-text-fill:#666;"/>
                        <TextArea fx:id="fieldComment" prefRowCount="4"
                                  style="-fx-font-size:13; -fx-background-radius:8;
                                         -fx-border-color:#ddd; -fx-border-radius:8; -fx-border-width:1;
                                         -fx-control-inner-background:#ffffff; -fx-text-fill:#333;"/>
                        <Label fx:id="labelCharCount" text="0/1000 caracteres"
                               style="-fx-font-size:11; -fx-text-fill:#888; -fx-alignment:CENTER_RIGHT;"/>
                    </VBox>

                    <!-- Error -->
                    <Label fx:id="labelError" text="" wrapText="true"
                           style="-fx-text-fill:#e94560; -fx-font-size:12; -fx-padding:0 0 8 0;"/>

                    <!-- Buttons -->
                    <VBox spacing="10">
                        <Button text="&#128260;  Envoyer mon feedback" onAction="#onSubmit"
                                maxWidth="Infinity"
                                style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                                       -fx-text-fill:white; -fx-font-size:14; -fx-font-weight:700;
                                       -fx-padding:14 0 14 0; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-width:0;"/>
                        <Button text="Retour aux evenements" onAction="#onBack"
                                maxWidth="Infinity"
                                style="-fx-background-color:white; -fx-text-fill:#555; -fx-font-size:13;
                                       -fx-font-weight:600; -fx-padding:12 0 12 0; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-color:#ddd; -fx-border-width:1; -fx-border-radius:10;"/>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="56" style="-fx-background-color:#1e1e1e;">
            <Label text="&#169; 2026 AutoLearn - Tous droits reserves"
                   style="-fx-text-fill:rgba(255,255,255,0.45); -fx-font-size:12;"/>
        </HBox>
    </bottom>
</BorderPane>
