<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.FrontofficeController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f8f9fa;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.96); -fx-min-height:64; -fx-max-height:64;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),10,0,0,3);">
            <padding><Insets left="36" right="36"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="AutoLearn" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:white;"/>
            </HBox>
            <HBox spacing="0" alignment="CENTER" style="-fx-padding:0 0 0 32;">
                <Button fx:id="btnHome" text="Accueil" onAction="#onHome"
                        style="-fx-background-color:rgba(255,255,255,0.2); -fx-text-fill:white; -fx-font-size:13;
                               -fx-font-weight:700; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0; -fx-background-radius:8;"/>
                <Button fx:id="btnCours" text="Cours" onAction="#onCours"
