                            <Label text="Nos Cours"
                                   style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.85);
                                          -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20; -fx-padding:4 14 4 14;"/>
                            <Label text="Apprenez la Programmation" wrapText="true"
                                   style="-fx-font-size:36; -fx-font-weight:900; -fx-text-fill:white; -fx-max-width:460;"/>
                            <Label fx:id="welcomeLabel" text="" wrapText="true"
                                   style="-fx-font-size:14; -fx-text-fill:rgba(255,255,255,0.75); -fx-max-width:420;"/>
                            <HBox spacing="14">
                                <Button text="Voir les cours" onAction="#onCours"
