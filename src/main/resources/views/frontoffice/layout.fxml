<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.FrontofficeController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f5f5f5;">

    <!-- ══ NAVBAR ══ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.96);
                     -fx-min-height:64; -fx-max-height:64;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),10,0,0,3);">
            <padding><Insets left="36" right="36"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🎓" style="-fx-font-size:22;"/>
                <Label text="AutoLearn" style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:white;"/>
            </HBox>
            <HBox spacing="0" alignment="CENTER" style="-fx-padding:0 0 0 32;">
                <Button fx:id="btnHome" text="Accueil" onAction="#onHome"
                        style="-fx-background-color:rgba(255,255,255,0.2); -fx-text-fill:white;
                               -fx-font-size:13; -fx-font-weight:700; -fx-cursor:hand;
                               -fx-padding:7 16 7 16; -fx-border-width:0; -fx-background-radius:8;"/>
                <Button text="Cours" onAction="#onCours"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.8);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button text="Challenges" onAction="#onChallenges"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.8);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button text="Événements" onAction="#onEvenements"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.8);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button text="Communauté" onAction="#onCommunaute"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.8);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="12">
                <Label fx:id="labelAvatarNav"
                       style="-fx-background-color:rgba(255,255,255,0.25); -fx-text-fill:white;
                              -fx-font-weight:700; -fx-font-size:13; -fx-background-radius:50%;
                              -fx-padding:7 10 7 10;"/>
                <VBox alignment="CENTER_RIGHT" spacing="1">
                    <Label fx:id="labelCurrentUser" text=""
                           style="-fx-text-fill:white; -fx-font-size:12; -fx-font-weight:700;"/>
                    <Label fx:id="labelNiveauUser" text=""
                           style="-fx-text-fill:rgba(255,255,255,0.65); -fx-font-size:10;"/>
                </VBox>
                <MenuButton fx:id="menuUser" text=""
                            style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                   -fx-font-size:12; -fx-padding:7 12 7 12;
                                   -fx-background-radius:20; -fx-cursor:hand; -fx-border-width:0;">
                    <items>
                        <MenuItem text="Mon Profil" onAction="#onProfile"/>
                        <MenuItem text="Mes Participations" onAction="#onMesParticipations"/>
                        <MenuItem text="Mes Equipes" onAction="#onMesEquipes"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Deconnexion" onAction="#onLogout"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f5f5f5; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0" style="-fx-background-color:#f5f5f5;">

                <!-- ── HERO SLIDER (animé par FrontofficeController) ── -->
                <StackPane fx:id="heroSlider" prefHeight="380"
                           style="-fx-background-color:linear-gradient(to bottom right,#7a6ad8,#4e3b9c);">

                    <!-- Slide 1 -->
                    <VBox fx:id="slide1" alignment="CENTER" spacing="18"
                          style="-fx-padding:60 120 60 120;">
                        <Label text="Nos Cours"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.8);
                                      -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20;
                                      -fx-padding:4 16 4 16;"/>
                        <Label text="Apprenez la Programmation"
                               style="-fx-font-size:38; -fx-font-weight:900; -fx-text-fill:white;" wrapText="true"/>
                        <Label fx:id="welcomeLabel" text=""
                               style="-fx-font-size:15; -fx-text-fill:rgba(255,255,255,0.75);" wrapText="true"/>
                        <HBox spacing="14" alignment="CENTER">
                            <Button text="Voir les cours" onAction="#onCours"
                                    style="-fx-background-color:white; -fx-text-fill:#7a6ad8; -fx-font-size:13;
                                           -fx-font-weight:700; -fx-padding:12 28 12 28; -fx-background-radius:30;
                                           -fx-cursor:hand; -fx-border-width:0;
                                           -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),8,0,0,3);"/>
                            <Button text="Commencer maintenant" onAction="#onCours"
                                    style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                           -fx-font-size:13; -fx-padding:12 28 12 28;
                                           -fx-background-radius:30; -fx-cursor:hand; -fx-border-width:1;
                                           -fx-border-color:rgba(255,255,255,0.4); -fx-border-radius:30;"/>
                        </HBox>
                    </VBox>

                    <!-- Slide 2 -->
                    <VBox fx:id="slide2" alignment="CENTER" spacing="18"
                          style="-fx-padding:60 120 60 120;" visible="false" managed="false">
                        <Label text="Meilleurs Résultats"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.8);
                                      -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20;
                                      -fx-padding:4 16 4 16;"/>
                        <Label text="Développez Vos Compétences"
                               style="-fx-font-size:38; -fx-font-weight:900; -fx-text-fill:white;" wrapText="true"/>
                        <Label text="Progressez rapidement avec nos challenges interactifs et exercices IA."
                               style="-fx-font-size:15; -fx-text-fill:rgba(255,255,255,0.75);" wrapText="true"/>
                        <HBox spacing="14" alignment="CENTER">
                            <Button text="Relever un challenge" onAction="#onChallenges"
                                    style="-fx-background-color:white; -fx-text-fill:#7a6ad8; -fx-font-size:13;
                                           -fx-font-weight:700; -fx-padding:12 28 12 28; -fx-background-radius:30;
                                           -fx-cursor:hand; -fx-border-width:0;
                                           -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),8,0,0,3);"/>
                            <Button text="Explorer les cours" onAction="#onCours"
                                    style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                           -fx-font-size:13; -fx-padding:12 28 12 28;
                                           -fx-background-radius:30; -fx-cursor:hand; -fx-border-width:1;
                                           -fx-border-color:rgba(255,255,255,0.4); -fx-border-radius:30;"/>
                        </HBox>
                    </VBox>

                    <!-- Slide 3 -->
                    <VBox fx:id="slide3" alignment="CENTER" spacing="18"
                          style="-fx-padding:60 120 60 120;" visible="false" managed="false">
                        <Label text="Apprentissage en Ligne"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.8);
                                      -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20;
                                      -fx-padding:4 16 4 16;"/>
                        <Label text="Apprenez à Votre Rythme"
                               style="-fx-font-size:38; -fx-font-weight:900; -fx-text-fill:white;" wrapText="true"/>
                        <Label text="Accédez à nos contenus 24h/24, 7j/7, depuis n'importe où."
                               style="-fx-font-size:15; -fx-text-fill:rgba(255,255,255,0.75);" wrapText="true"/>
                        <HBox spacing="14" alignment="CENTER">
                            <Button text="Rejoindre la communauté" onAction="#onCommunaute"
                                    style="-fx-background-color:white; -fx-text-fill:#7a6ad8; -fx-font-size:13;
                                           -fx-font-weight:700; -fx-padding:12 28 12 28; -fx-background-radius:30;
                                           -fx-cursor:hand; -fx-border-width:0;
                                           -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),8,0,0,3);"/>
                            <Button text="Découvrir AutoLearn" onAction="#onCours"
                                    style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                           -fx-font-size:13; -fx-padding:12 28 12 28;
                                           -fx-background-radius:30; -fx-cursor:hand; -fx-border-width:1;
                                           -fx-border-color:rgba(255,255,255,0.4); -fx-border-radius:30;"/>
                        </HBox>
                    </VBox>

                    <!-- Dots indicateurs -->
                    <HBox fx:id="sliderDots" alignment="BOTTOM_CENTER" spacing="8"
                          style="-fx-padding:0 0 20 0;">
                        <Label fx:id="dot1" text="●" style="-fx-text-fill:white; -fx-font-size:10;"/>
                        <Label fx:id="dot2" text="●" style="-fx-text-fill:rgba(255,255,255,0.4); -fx-font-size:10;"/>
                        <Label fx:id="dot3" text="●" style="-fx-text-fill:rgba(255,255,255,0.4); -fx-font-size:10;"/>
                    </HBox>
                </StackPane>

                <!-- ── STATS BAR ── -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color:white;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                    <VBox alignment="CENTER" spacing="3" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(0,0,0,0.06) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelNiveauStat" text="—"
                               style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Votre niveau" style="-fx-font-size:11; -fx-text-fill:#999;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(0,0,0,0.06) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelCoursCount" text="—"
                               style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Cours disponibles" style="-fx-font-size:11; -fx-text-fill:#999;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(0,0,0,0.06) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelChallengesCount" text="—"
                               style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Challenges actifs" style="-fx-font-size:11; -fx-text-fill:#999;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3" prefWidth="220" prefHeight="72">
                        <Label fx:id="labelEtudiantsCount" text="—"
                               style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Étudiants actifs" style="-fx-font-size:11; -fx-text-fill:#999;"/>
                    </VBox>
                </HBox>

                <!-- ── NOS COURS ── -->
                <VBox spacing="24" style="-fx-padding:52 80 52 80; -fx-background-color:#f5f5f5;">
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="Nos Cours"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                                      -fx-background-color:rgba(122,106,216,0.1); -fx-background-radius:20;
                                      -fx-padding:4 14 4 14;"/>
                        <Label text="Découvrez Nos Cours de Programmation"
                               style="-fx-font-size:26; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        <Label text="Apprenez à votre rythme avec du contenu de qualité"
                               style="-fx-font-size:14; -fx-text-fill:#888;"/>
                    </VBox>
                    <HBox fx:id="coursCardsContainer" spacing="24" alignment="CENTER"/>
                </VBox>

                <!-- ── À PROPOS ── -->
                <VBox spacing="0" style="-fx-background-color:white; -fx-padding:52 80 52 80;">
                    <VBox alignment="CENTER" spacing="6" style="-fx-padding:0 0 40 0;">
                        <Label text="Notre Mission"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                                      -fx-background-color:rgba(122,106,216,0.1); -fx-background-radius:20;
                                      -fx-padding:4 14 4 14;"/>
                        <Label text="Révolutionner l'apprentissage en ligne"
                               style="-fx-font-size:26; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                    </VBox>
                    <HBox spacing="60" alignment="CENTER">
                        <VBox spacing="16" prefWidth="480">
                            <Label text="AutoLearn est une plateforme d'apprentissage innovante qui combine l'intelligence artificielle et la pédagogie moderne pour offrir une expérience personnalisée et efficace. Notre mission est de rendre l'éducation accessible à tous, partout et à tout moment."
                                   wrapText="true"
                                   style="-fx-font-size:14; -fx-text-fill:#555; -fx-line-spacing:4;"/>
                            <HBox spacing="32">
                                <VBox spacing="4" alignment="CENTER">
                                    <Label text="1000+"
                                           style="-fx-font-size:28; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                                    <Label text="Étudiants" style="-fx-font-size:12; -fx-text-fill:#888;"/>
                                </VBox>
                                <VBox spacing="4" alignment="CENTER">
                                    <Label text="50+"
                                           style="-fx-font-size:28; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                                    <Label text="Cours" style="-fx-font-size:12; -fx-text-fill:#888;"/>
                                </VBox>
                                <VBox spacing="4" alignment="CENTER">
                                    <Label text="500+"
                                           style="-fx-font-size:28; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                                    <Label text="Exercices IA" style="-fx-font-size:12; -fx-text-fill:#888;"/>
                                </VBox>
                                <VBox spacing="4" alignment="CENTER">
                                    <Label text="24/7"
                                           style="-fx-font-size:28; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                                    <Label text="Disponible" style="-fx-font-size:12; -fx-text-fill:#888;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox spacing="16" prefWidth="400">
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="IA Intégrée"
                                       style="-fx-background-color:rgba(122,106,216,0.1); -fx-text-fill:#7a6ad8;
                                              -fx-font-weight:700; -fx-font-size:13; -fx-background-radius:10;
                                              -fx-padding:10 16 10 16;"/>
                                <Label text="Correction automatique et exercices adaptés à votre niveau."
                                       wrapText="true" style="-fx-font-size:13; -fx-text-fill:#555;"/>
                            </HBox>
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="Challenges"
                                       style="-fx-background-color:rgba(245,158,11,0.1); -fx-text-fill:#f59e0b;
                                              -fx-font-weight:700; -fx-font-size:13; -fx-background-radius:10;
                                              -fx-padding:10 16 10 16;"/>
                                <Label text="Défis stimulants avec feedback détaillé et progression en temps réel."
                                       wrapText="true" style="-fx-font-size:13; -fx-text-fill:#555;"/>
                            </HBox>
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="Communauté"
                                       style="-fx-background-color:rgba(52,211,153,0.1); -fx-text-fill:#059669;
                                              -fx-font-weight:700; -fx-font-size:13; -fx-background-radius:10;
                                              -fx-padding:10 16 10 16;"/>
                                <Label text="Partagez, posez des questions et collaborez avec d'autres apprenants."
                                       wrapText="true" style="-fx-font-size:13; -fx-text-fill:#555;"/>
                            </HBox>
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="Événements"
                                       style="-fx-background-color:rgba(96,165,250,0.1); -fx-text-fill:#3b82f6;
                                              -fx-font-weight:700; -fx-font-size:13; -fx-background-radius:10;
                                              -fx-padding:10 16 10 16;"/>
                                <Label text="Webinaires et sessions de formation en direct avec des experts."
                                       wrapText="true" style="-fx-font-size:13; -fx-text-fill:#555;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── CONTACT ── -->
                <VBox spacing="24" style="-fx-padding:52 80 52 80; -fx-background-color:#f5f5f5;">
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="Contact"
                               style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                                      -fx-background-color:rgba(122,106,216,0.1); -fx-background-radius:20;
                                      -fx-padding:4 14 4 14;"/>
                        <Label text="Contactez-nous"
                               style="-fx-font-size:26; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        <Label text="Une question ? Nous sommes là pour vous aider."
                               style="-fx-font-size:14; -fx-text-fill:#888;"/>
                    </VBox>
                    <HBox spacing="40" alignment="TOP_CENTER">
                        <!-- Infos contact -->
                        <VBox spacing="20" prefWidth="320">
                            <VBox spacing="6">
                                <Label text="Email"
                                       style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                                <Label text="contact@autolearn.tn"
                                       style="-fx-font-size:14; -fx-text-fill:#333;"/>
                            </VBox>
                            <VBox spacing="6">
                                <Label text="Téléphone"
                                       style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                                <Label text="+216 XX XXX XXX"
                                       style="-fx-font-size:14; -fx-text-fill:#333;"/>
                            </VBox>
                            <VBox spacing="6">
                                <Label text="Adresse"
                                       style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                                <Label text="ESPRIT, Ariana, Tunisie"
                                       style="-fx-font-size:14; -fx-text-fill:#333;"/>
                            </VBox>
                        </VBox>
                        <!-- Formulaire -->
                        <VBox spacing="14" prefWidth="500"
                              style="-fx-background-color:white; -fx-background-radius:16;
                                     -fx-border-color:#eeeeee; -fx-border-radius:16;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);
                                     -fx-padding:28;">
                            <HBox spacing="14">
                                <TextField fx:id="contactNom" promptText="Votre nom" HBox.hgrow="ALWAYS"
                                           style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                                  -fx-border-radius:8; -fx-background-radius:8;
                                                  -fx-padding:11 14 11 14; -fx-font-size:13;"/>
                                <TextField fx:id="contactEmail" promptText="Votre email" HBox.hgrow="ALWAYS"
                                           style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                                  -fx-border-radius:8; -fx-background-radius:8;
                                                  -fx-padding:11 14 11 14; -fx-font-size:13;"/>
                            </HBox>
                            <TextField fx:id="contactSujet" promptText="Sujet"
                                       style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                              -fx-border-radius:8; -fx-background-radius:8;
                                              -fx-padding:11 14 11 14; -fx-font-size:13;"/>
                            <TextArea fx:id="contactMessage" promptText="Votre message..." prefRowCount="4"
                                      style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                             -fx-border-radius:8; -fx-background-radius:8;
                                             -fx-padding:11 14 11 14; -fx-font-size:13;"/>
                            <Label fx:id="contactStatus" text="" wrapText="true"
                                   style="-fx-font-size:12;" visible="false" managed="false"/>
                            <Button text="Envoyer le message" onAction="#onContactSend" maxWidth="Infinity"
                                    style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                                           -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;
                                           -fx-padding:12 0 12 0; -fx-background-radius:10;
                                           -fx-cursor:hand; -fx-border-width:0;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── FOOTER ── -->
                <HBox alignment="CENTER" prefHeight="52"
                      style="-fx-background-color:#1e1e1e;">
                    <Label text="© 2026 AutoLearn — Tous droits réservés"
                           style="-fx-text-fill:rgba(255,255,255,0.4); -fx-font-size:12;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
