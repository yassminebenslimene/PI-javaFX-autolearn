<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.FrontofficeController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#0f0c29;">

    <!-- ══ NAVBAR ══ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.96);
                     -fx-min-height:64; -fx-max-height:64;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),12,0,0,4);">
            <padding><Insets left="36" right="36"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🎓" style="-fx-font-size:22;"/>
                <Label text="AutoLearn"
                       style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:white;"/>
            </HBox>
            <HBox spacing="0" alignment="CENTER" style="-fx-padding:0 0 0 32;">
                <Button fx:id="btnHome" text="Accueil" onAction="#onHome"
                        style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                               -fx-font-size:13; -fx-font-weight:700; -fx-cursor:hand;
                               -fx-padding:7 16 7 16; -fx-border-width:0; -fx-background-radius:8;"/>
                <Button text="Cours" onAction="#onCours"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button text="Challenges" onAction="#onChallenges"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button text="Événements" onAction="#onEvenements"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button text="Communauté" onAction="#onCommunaute"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="12">
                <Label fx:id="labelAvatarNav"
                       style="-fx-background-color:rgba(255,255,255,0.2); -fx-text-fill:white;
                              -fx-font-weight:700; -fx-font-size:13; -fx-background-radius:50%;
                              -fx-padding:7 10 7 10;"/>
                <VBox alignment="CENTER_RIGHT" spacing="1">
                    <Label fx:id="labelCurrentUser" text=""
                           style="-fx-text-fill:white; -fx-font-size:12; -fx-font-weight:700;"/>
                    <Label fx:id="labelNiveauUser" text=""
                           style="-fx-text-fill:rgba(255,255,255,0.6); -fx-font-size:10;"/>
                </VBox>
                <MenuButton fx:id="menuUser" text=""
                            style="-fx-background-color:rgba(255,255,255,0.12); -fx-text-fill:white;
                                   -fx-font-size:12; -fx-padding:7 12 7 12;
                                   -fx-background-radius:20; -fx-cursor:hand; -fx-border-width:0;">
                    <items>
                        <MenuItem text="Mon Profil" onAction="#onProfile"/>
                        <MenuItem text="Mes Participations" onAction="#onMesParticipations"/>
                        <MenuItem text="Mes Equipes" onAction="#onMesEquipes"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Deconnexion" onAction="#onLogout"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <!-- ══ CONTENT ══ -->
    <center>
        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#0f0c29; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0" style="-fx-background-color:linear-gradient(to bottom,#0f0c29,#302b63,#24243e);">

                <!-- ── HERO ── -->
                <VBox fx:id="heroSection" alignment="CENTER" spacing="20" prefHeight="320"
                      style="-fx-padding:60 80 60 80;">
                    <Label fx:id="welcomeLabel" text=""
                           style="-fx-font-size:14; -fx-text-fill:rgba(165,148,249,0.9); -fx-font-weight:600;"/>
                    <Label text="Apprenez. Progressez. Réussissez."
                           style="-fx-font-size:40; -fx-font-weight:900; -fx-text-fill:white;
                                  -fx-effect:dropshadow(gaussian,rgba(122,106,216,0.6),20,0,0,0);"
                           wrapText="true"/>
                    <Label text="Accédez à des cours de qualité, des challenges stimulants et une communauté active."
                           style="-fx-font-size:15; -fx-text-fill:rgba(255,255,255,0.55);" wrapText="true"/>
                    <HBox spacing="14" alignment="CENTER">
                        <Button text="Voir les cours" onAction="#onCours"
                                style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                                       -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;
                                       -fx-padding:12 28 12 28; -fx-background-radius:30;
                                       -fx-cursor:hand; -fx-border-width:0;
                                       -fx-effect:dropshadow(gaussian,rgba(122,106,216,0.5),12,0,0,4);"/>
                        <Button text="Challenges" onAction="#onChallenges"
                                style="-fx-background-color:rgba(255,255,255,0.08); -fx-text-fill:white;
                                       -fx-font-size:13; -fx-padding:12 28 12 28;
                                       -fx-background-radius:30; -fx-cursor:hand; -fx-border-width:1;
                                       -fx-border-color:rgba(255,255,255,0.2); -fx-border-radius:30;"/>
                    </HBox>
                </VBox>

                <!-- ── STATS ── -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color:rgba(255,255,255,0.04);
                             -fx-border-color:rgba(255,255,255,0.08) transparent rgba(255,255,255,0.08) transparent;
                             -fx-border-width:1 0 1 0;">
                    <VBox alignment="CENTER" spacing="4" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(255,255,255,0.08) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelNiveauStat" text="—"
                               style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#a78bfa;"/>
                        <Label text="Votre niveau" style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.4);"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(255,255,255,0.08) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelCoursCount" text="—"
                               style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#34d399;"/>
                        <Label text="Cours disponibles" style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.4);"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(255,255,255,0.08) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelChallengesCount" text="—"
                               style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#f59e0b;"/>
                        <Label text="Challenges actifs" style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.4);"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" prefWidth="220" prefHeight="72">
                        <Label fx:id="labelEtudiantsCount" text="—"
                               style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#60a5fa;"/>
                        <Label text="Étudiants actifs" style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.4);"/>
                    </VBox>
                </HBox>

                <!-- ── NOS COURS ── -->
                <VBox spacing="20" style="-fx-padding:44 80 44 80;">
                    <VBox spacing="4">
                        <Label text="NOS COURS"
                               style="-fx-font-size:11; -fx-font-weight:700; -fx-text-fill:#a78bfa;
                                      -fx-letter-spacing:2;"/>
                        <Label text="Commencez à apprendre"
                               style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:white;"/>
                    </VBox>
                    <HBox fx:id="coursCardsContainer" spacing="20" alignment="CENTER_LEFT"/>
                </VBox>

                <!-- ── FEATURES ── -->
                <VBox spacing="20"
                      style="-fx-padding:0 80 44 80; -fx-background-color:rgba(255,255,255,0.02);">
                    <VBox spacing="4">
                        <Label text="FONCTIONNALITÉS"
                               style="-fx-font-size:11; -fx-font-weight:700; -fx-text-fill:#34d399;
                                      -fx-letter-spacing:2;"/>
                        <Label text="Ce qui nous rend uniques"
                               style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:white;"/>
                    </VBox>
                    <HBox spacing="16" alignment="CENTER">
                        <VBox spacing="10" prefWidth="240" alignment="CENTER"
                              style="-fx-background-color:rgba(122,106,216,0.12);
                                     -fx-background-radius:16; -fx-border-color:rgba(122,106,216,0.3);
                                     -fx-border-radius:16; -fx-border-width:1; -fx-padding:24;">
                            <Label text="IA Intégrée"
                                   style="-fx-font-size:14; -fx-font-weight:700; -fx-text-fill:white;"/>
                            <Label text="Correction automatique et exercices adaptés à votre niveau."
                                   wrapText="true" style="-fx-font-size:12; -fx-text-fill:rgba(255,255,255,0.55); -fx-text-alignment:CENTER;"/>
                        </VBox>
                        <VBox spacing="10" prefWidth="240" alignment="CENTER"
                              style="-fx-background-color:rgba(52,211,153,0.1);
                                     -fx-background-radius:16; -fx-border-color:rgba(52,211,153,0.3);
                                     -fx-border-radius:16; -fx-border-width:1; -fx-padding:24;">
                            <Label text="Suivi de Progression"
                                   style="-fx-font-size:14; -fx-font-weight:700; -fx-text-fill:white;"/>
                            <Label text="Visualisez votre avancement en temps réel."
                                   wrapText="true" style="-fx-font-size:12; -fx-text-fill:rgba(255,255,255,0.55); -fx-text-alignment:CENTER;"/>
                        </VBox>
                        <VBox spacing="10" prefWidth="240" alignment="CENTER"
                              style="-fx-background-color:rgba(245,158,11,0.1);
                                     -fx-background-radius:16; -fx-border-color:rgba(245,158,11,0.3);
                                     -fx-border-radius:16; -fx-border-width:1; -fx-padding:24;">
                            <Label text="Événements Live"
                                   style="-fx-font-size:14; -fx-font-weight:700; -fx-text-fill:white;"/>
                            <Label text="Webinaires et sessions de formation en direct."
                                   wrapText="true" style="-fx-font-size:12; -fx-text-fill:rgba(255,255,255,0.55); -fx-text-alignment:CENTER;"/>
                        </VBox>
                        <VBox spacing="10" prefWidth="240" alignment="CENTER"
                              style="-fx-background-color:rgba(96,165,250,0.1);
                                     -fx-background-radius:16; -fx-border-color:rgba(96,165,250,0.3);
                                     -fx-border-radius:16; -fx-border-width:1; -fx-padding:24;">
                            <Label text="Communauté Active"
                                   style="-fx-font-size:14; -fx-font-weight:700; -fx-text-fill:white;"/>
                            <Label text="Partagez et collaborez avec d'autres apprenants."
                                   wrapText="true" style="-fx-font-size:12; -fx-text-fill:rgba(255,255,255,0.55); -fx-text-alignment:CENTER;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── FOOTER ── -->
                <HBox alignment="CENTER" prefHeight="48"
                      style="-fx-background-color:rgba(0,0,0,0.3);">
                    <Label text="© 2026 AutoLearn — Tous droits réservés"
                           style="-fx-text-fill:rgba(255,255,255,0.25); -fx-font-size:11;"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
