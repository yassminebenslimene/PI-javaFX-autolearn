                                <Label text="Disponible" style="-fx-font-size:11; -fx-text-fill:#999;"/>
                            </VBox>
                        </HBox>
                        <Button text="Decouvrir nos cours" onAction="#onCours"
                                style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                                       -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;
                                       -fx-padding:11 28 11 28; -fx-background-radius:30;
                                       -fx-cursor:hand; -fx-border-width:0;"/>
                    </VBox>
                    <!-- Illustration -->
                    <VBox spacing="14" prefWidth="360" HBox.hgrow="NEVER" alignment="CENTER">
                        <HBox spacing="14" alignment="CENTER">
                            <VBox alignment="CENTER" spacing="8" prefWidth="160" prefHeight="100"
                                  style="-fx-background-color:#f9f9ff; -fx-background-radius:14;
