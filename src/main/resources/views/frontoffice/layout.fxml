                    <HBox fx:id="coursCardsContainer" spacing="20" alignment="CENTER"
                          style="-fx-wrap-text:true;" prefWidth="1040"/>
                </VBox>

                <!-- NOS CHALLENGES -->
                <VBox spacing="20" style="-fx-padding:0 80 40 80; -fx-background-color:#f8f9fa;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Challenges"
                                   style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#e94560;
                                          -fx-background-color:rgba(233,69,96,0.1); -fx-background-radius:20; -fx-padding:3 12 3 12;"/>
                            <Label text="Relevez des defis"
