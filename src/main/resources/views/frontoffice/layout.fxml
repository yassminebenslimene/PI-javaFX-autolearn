                                <Label fx:id="aboutIcon2" text="" style="-fx-font-size:32;"/>
                                <Label text="Progression" style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="14" alignment="CENTER">
                            <VBox alignment="CENTER" spacing="8" prefWidth="160" prefHeight="100"
                                  style="-fx-background-color:#f9f9ff; -fx-background-radius:14;
