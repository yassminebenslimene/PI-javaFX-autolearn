                                               -fx-font-weight:700; -fx-padding:12 28 12 28; -fx-background-radius:30;
                                               -fx-cursor:hand; -fx-border-width:0;
                                               -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.15),8,0,0,3);"/>
                                <Button text="Commencer" onAction="#onCours"
                                        style="-fx-background-color:rgba(255,255,255,0.12); -fx-text-fill:white;
                                               -fx-font-size:13; -fx-padding:12 24 12 24; -fx-background-radius:30;
                                               -fx-cursor:hand; -fx-border-width:1;
                                               -fx-border-color:rgba(255,255,255,0.35); -fx-border-radius:30;"/>
                            </HBox>
                        </VBox>
                        <StackPane prefWidth="320" prefHeight="300" HBox.hgrow="NEVER">
                            <Circle radius="120" style="-fx-fill:rgba(255,255,255,0.07);"/>
                            <Circle radius="80" style="-fx-fill:rgba(255,255,255,0.1);"/>
                            <VBox alignment="CENTER" spacing="10">
                                <Label fx:id="slide1Icon" text=""
                                       style="-fx-font-size:64; -fx-text-fill:white;"/>
                                <Label fx:id="labelCoursIllus" text=""
                                       style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:white;
                                              -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20;
                                              -fx-padding:5 16 5 16;"/>
                            </VBox>
                        </StackPane>
                    </HBox>
                    <!-- Slide 2 -->
                    <HBox fx:id="slide2" alignment="CENTER" spacing="0" style="-fx-padding:0 80 0 80;"
