                                <Label fx:id="aboutIcon3" text="" style="-fx-font-size:32;"/>
                                <Label text="Challenges" style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="8" prefWidth="160" prefHeight="100"
