                        <Label fx:id="dot3" text="&#9679;" style="-fx-text-fill:rgba(255,255,255,0.35); -fx-font-size:10;"/>
                    </HBox>
                </StackPane>

                <!-- STATS BAR -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color:white; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <VBox alignment="CENTER" spacing="2" prefWidth="220" prefHeight="68"
