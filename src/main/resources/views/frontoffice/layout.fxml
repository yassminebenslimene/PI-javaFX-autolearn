                    </VBox>
                    <VBox alignment="CENTER" spacing="2" prefWidth="220" prefHeight="68">
                        <Label fx:id="labelEtudiantsCount" text="---" style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Etudiants actifs" style="-fx-font-size:11; -fx-text-fill:#aaa;"/>
                    </VBox>
                </HBox>

                <!-- NOS COURS -->
                <VBox spacing="20" style="-fx-padding:40 80 40 80; -fx-background-color:#f8f9fa;">
