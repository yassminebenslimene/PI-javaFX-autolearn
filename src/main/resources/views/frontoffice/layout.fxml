<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.FrontofficeController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f8f9fa;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.97); -fx-min-height:64; -fx-max-height:64;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),10,0,0,3);">
            <padding><Insets left="36" right="36"/></padding>
            <Label text="AutoLearn" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:white;"/>
            <HBox spacing="0" alignment="CENTER" style="-fx-padding:0 0 0 32;">
                <Button fx:id="btnHome" text="Accueil" onAction="#onHome"
                        style="-fx-background-color:rgba(255,255,255,0.2); -fx-text-fill:white; -fx-font-size:13;
                               -fx-font-weight:700; -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0; -fx-background-radius:8;"/>
                <Button fx:id="btnNavCours" text="Cours" onAction="#onCours"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.85); -fx-font-size:13;
                               -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button fx:id="btnNavChallenges" text="Challenges" onAction="#onChallenges"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.85); -fx-font-size:13;
                               -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button fx:id="btnNavEvenements" text="Evenements" onAction="#onEvenements"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.85); -fx-font-size:13;
                               -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
                <Button fx:id="btnNavCommunaute" text="Communaute" onAction="#onCommunaute"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.85); -fx-font-size:13;
                               -fx-cursor:hand; -fx-padding:7 16 7 16; -fx-border-width:0;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="12">
                <Label fx:id="labelAvatarNav"
                       style="-fx-background-color:rgba(255,255,255,0.25); -fx-text-fill:white;
                              -fx-font-weight:700; -fx-font-size:13; -fx-background-radius:50%; -fx-padding:7 10 7 10;"/>
                <VBox alignment="CENTER_RIGHT" spacing="1">
                    <Label fx:id="labelCurrentUser" text="" style="-fx-text-fill:white; -fx-font-size:12; -fx-font-weight:700;"/>
                    <Label fx:id="labelNiveauUser" text="" style="-fx-text-fill:rgba(255,255,255,0.65); -fx-font-size:10;"/>
                </VBox>
                <MenuButton fx:id="menuUser" text=""
                            style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white; -fx-font-size:12;
                                   -fx-padding:7 12 7 12; -fx-background-radius:20; -fx-cursor:hand; -fx-border-width:0;">
                    <items>
                        <MenuItem text="Mon Profil" onAction="#onProfile"/>
                        <MenuItem text="Mes Participations" onAction="#onMesParticipations"/>
                        <MenuItem text="Mes Equipes" onAction="#onMesEquipes"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Deconnexion" onAction="#onLogout"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>
    <center>
        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f8f9fa; -fx-background:transparent; -fx-border-width:0;">
            <VBox fx:id="homeContent" spacing="0" style="-fx-background-color:#f8f9fa;">

                <!-- HERO SLIDER -->
                <StackPane fx:id="heroSlider" prefHeight="420"
                           style="-fx-background-color:linear-gradient(to bottom right,#7a6ad8,#4e3b9c);">
                    <HBox fx:id="slide1" alignment="CENTER" spacing="0" style="-fx-padding:0 80 0 80;">
                        <VBox spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <Label fx:id="slide1Badge" text="Nos Cours"
                                   style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.9);
                                          -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20; -fx-padding:5 16 5 16;"/>
                            <Label text="Apprenez la Programmation" wrapText="true"
                                   style="-fx-font-size:40; -fx-font-weight:900; -fx-text-fill:white; -fx-max-width:500;"/>
                            <Label fx:id="welcomeLabel" text="" wrapText="true"
                                   style="-fx-font-size:15; -fx-text-fill:rgba(255,255,255,0.8); -fx-max-width:460;"/>
                            <HBox spacing="14">
                                <Button text="Voir les cours" onAction="#onCours"
                                        style="-fx-background-color:white; -fx-text-fill:#7a6ad8; -fx-font-size:14;
                                               -fx-font-weight:700; -fx-padding:13 32 13 32; -fx-background-radius:30;
                                               -fx-cursor:hand; -fx-border-width:0;
                                               -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),10,0,0,3);"/>
                                <Button text="Commencer" onAction="#onCours"
                                        style="-fx-background-color:transparent; -fx-text-fill:white; -fx-font-size:14;
                                               -fx-padding:13 32 13 32; -fx-background-radius:30; -fx-cursor:hand;
                                               -fx-border-width:2; -fx-border-color:rgba(255,255,255,0.5); -fx-border-radius:30;"/>
                            </HBox>
                        </VBox>
                        <StackPane prefWidth="340" prefHeight="340" HBox.hgrow="NEVER" mouseTransparent="true">
                            <Circle radius="140" style="-fx-fill:rgba(255,255,255,0.06);" mouseTransparent="true"/>
                            <Circle radius="100" style="-fx-fill:rgba(255,255,255,0.09);" mouseTransparent="true"/>
                            <VBox alignment="CENTER" spacing="12" mouseTransparent="true">
                                <Label fx:id="slide1Icon" text="" style="-fx-font-size:80;"/>
                                <Label fx:id="labelCoursIllus" text=""
                                       style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:white;
                                              -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20; -fx-padding:6 18 6 18;"/>
                            </VBox>
                        </StackPane>
                    </HBox>
                    <HBox fx:id="slide2" alignment="CENTER" spacing="0" style="-fx-padding:0 80 0 80;" visible="false" managed="false">
                        <VBox spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <Label text="Challenges"
                                   style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.9);
                                          -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20; -fx-padding:5 16 5 16;"/>
                            <Label text="Developpez Vos Competences" wrapText="true"
                                   style="-fx-font-size:40; -fx-font-weight:900; -fx-text-fill:white; -fx-max-width:500;"/>
                            <Label text="Relevez des defis stimulants avec feedback IA et suivez votre progression." wrapText="true"
                                   style="-fx-font-size:15; -fx-text-fill:rgba(255,255,255,0.8); -fx-max-width:460;"/>
                            <HBox spacing="14">
                                <Button text="Relever un challenge" onAction="#onChallenges"
                                        style="-fx-background-color:white; -fx-text-fill:#7a6ad8; -fx-font-size:14;
                                               -fx-font-weight:700; -fx-padding:13 32 13 32; -fx-background-radius:30;
                                               -fx-cursor:hand; -fx-border-width:0;
                                               -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),10,0,0,3);"/>
                                <Button text="Explorer les cours" onAction="#onCours"
                                        style="-fx-background-color:transparent; -fx-text-fill:white; -fx-font-size:14;
                                               -fx-padding:13 32 13 32; -fx-background-radius:30; -fx-cursor:hand;
                                               -fx-border-width:2; -fx-border-color:rgba(255,255,255,0.5); -fx-border-radius:30;"/>
                            </HBox>
                        </VBox>
                        <StackPane prefWidth="340" prefHeight="340" HBox.hgrow="NEVER" mouseTransparent="true">
                            <Circle radius="140" style="-fx-fill:rgba(255,255,255,0.06);" mouseTransparent="true"/>
                            <Circle radius="100" style="-fx-fill:rgba(255,255,255,0.09);" mouseTransparent="true"/>
                            <Label fx:id="slide2Icon" text="" style="-fx-font-size:80;" mouseTransparent="true"/>
                        </StackPane>
                    </HBox>
                    <HBox fx:id="slide3" alignment="CENTER" spacing="0" style="-fx-padding:0 80 0 80;" visible="false" managed="false">
                        <VBox spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <Label text="Communaute"
                                   style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.9);
                                          -fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20; -fx-padding:5 16 5 16;"/>
                            <Label text="Apprenez a Votre Rythme" wrapText="true"
                                   style="-fx-font-size:40; -fx-font-weight:900; -fx-text-fill:white; -fx-max-width:500;"/>
                            <Label text="Rejoignez une communaute active. Partagez et progressez ensemble." wrapText="true"
                                   style="-fx-font-size:15; -fx-text-fill:rgba(255,255,255,0.8); -fx-max-width:460;"/>
                            <HBox spacing="14">
                                <Button text="Rejoindre" onAction="#onCommunaute"
                                        style="-fx-background-color:white; -fx-text-fill:#7a6ad8; -fx-font-size:14;
                                               -fx-font-weight:700; -fx-padding:13 32 13 32; -fx-background-radius:30;
                                               -fx-cursor:hand; -fx-border-width:0;
                                               -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),10,0,0,3);"/>
                                <Button text="Voir les evenements" onAction="#onEvenements"
                                        style="-fx-background-color:transparent; -fx-text-fill:white; -fx-font-size:14;
                                               -fx-padding:13 32 13 32; -fx-background-radius:30; -fx-cursor:hand;
                                               -fx-border-width:2; -fx-border-color:rgba(255,255,255,0.5); -fx-border-radius:30;"/>
                            </HBox>
                        </VBox>
                        <StackPane prefWidth="340" prefHeight="340" HBox.hgrow="NEVER" mouseTransparent="true">
                            <Circle radius="140" style="-fx-fill:rgba(255,255,255,0.06);" mouseTransparent="true"/>
                            <Circle radius="100" style="-fx-fill:rgba(255,255,255,0.09);" mouseTransparent="true"/>
                            <Label fx:id="slide3Icon" text="" style="-fx-font-size:80;" mouseTransparent="true"/>
                        </StackPane>
                    </HBox>
                    <HBox fx:id="sliderDots" alignment="BOTTOM_CENTER" style="-fx-padding:0 0 16 0;" spacing="8" mouseTransparent="true">
                        <Label fx:id="dot1" text="&#9679;" style="-fx-text-fill:white; -fx-font-size:12;"/>
                        <Label fx:id="dot2" text="&#9679;" style="-fx-text-fill:rgba(255,255,255,0.35); -fx-font-size:12;"/>
                        <Label fx:id="dot3" text="&#9679;" style="-fx-text-fill:rgba(255,255,255,0.35); -fx-font-size:12;"/>
                    </HBox>
                </StackPane>

                <!-- STATS BAR -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color:white; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                    <VBox alignment="CENTER" spacing="2" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(0,0,0,0.06) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelNiveauStat" text="---" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Votre niveau" style="-fx-font-size:11; -fx-text-fill:#aaa;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(0,0,0,0.06) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelCoursCount" text="---" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Cours disponibles" style="-fx-font-size:11; -fx-text-fill:#aaa;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2" prefWidth="220" prefHeight="72"
                          style="-fx-border-color:transparent rgba(0,0,0,0.06) transparent transparent; -fx-border-width:0 1 0 0;">
                        <Label fx:id="labelChallengesCount" text="---" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Challenges actifs" style="-fx-font-size:11; -fx-text-fill:#aaa;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2" prefWidth="220" prefHeight="72">
                        <Label fx:id="labelEtudiantsCount" text="---" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#7a6ad8;"/>
                        <Label text="Etudiants actifs" style="-fx-font-size:11; -fx-text-fill:#aaa;"/>
                    </VBox>
                </HBox>

                <!-- NOS COURS -->
                <VBox fx:id="sectionCours" spacing="24" style="-fx-padding:48 80 48 80; -fx-background-color:#f8f9fa;">
                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Nos Cours"
                                   style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                                          -fx-background-color:rgba(122,106,216,0.1); -fx-background-radius:20; -fx-padding:3 12 3 12;"/>
                            <Label text="Decouvrez nos formations" style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                            <Label text="Des cours structures par des experts pour progresser a votre rythme"
                                   style="-fx-font-size:13; -fx-text-fill:#888;"/>
                        </VBox>
                        <Button text="Voir tous les cours" onAction="#onCours"
                                style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:13;
                                       -fx-font-weight:600; -fx-cursor:hand; -fx-border-width:0;
                                       -fx-padding:10 24 10 24; -fx-background-radius:20;"/>
                    </HBox>
                    <HBox fx:id="coursCardsContainer" spacing="20" alignment="CENTER_LEFT"/>
                </VBox>

                <!-- POURQUOI AUTOLEARN -->
                <VBox fx:id="sectionFeatures" spacing="32" style="-fx-padding:48 80 48 80; -fx-background-color:white;">
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="Pourquoi AutoLearn ?"
                               style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                                      -fx-background-color:rgba(122,106,216,0.1); -fx-background-radius:20; -fx-padding:3 12 3 12;"/>
                        <Label text="Une plateforme pensee pour votre reussite"
                               style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        <Label text="Tout ce dont vous avez besoin pour apprendre efficacement"
                               style="-fx-font-size:13; -fx-text-fill:#888;"/>
                    </VBox>
                    <HBox fx:id="featuresContainer" spacing="20" alignment="CENTER"/>
                </VBox>

                <!-- TEMOIGNAGES / EQUIPE -->
                <VBox fx:id="sectionTeam" spacing="32" style="-fx-padding:48 80 48 80; -fx-background-color:#f8f9fa;">
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="Notre Equipe"
                               style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                                      -fx-background-color:rgba(122,106,216,0.1); -fx-background-radius:20; -fx-padding:3 12 3 12;"/>
                        <Label text="Des experts passionnes par l&apos;education"
                               style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                    </VBox>
                    <HBox fx:id="teamContainer" spacing="20" alignment="CENTER"/>
                </VBox>

                <!-- CONTACT -->
                <HBox spacing="48" alignment="TOP_CENTER"
                      style="-fx-padding:48 80 48 80; -fx-background-color:white;">
                    <VBox spacing="16" prefWidth="300">
                        <Label text="Contact"
                               style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                                      -fx-background-color:rgba(122,106,216,0.1); -fx-background-radius:20; -fx-padding:3 12 3 12;"/>
                        <Label text="Contactez-nous" style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                        <Label text="Une question ? Nous sommes la pour vous aider."
                               wrapText="true" style="-fx-font-size:13; -fx-text-fill:#666;"/>
                        <Label text="autolearn66@gmail.com" style="-fx-font-size:13; -fx-text-fill:#7a6ad8; -fx-font-weight:600;"/>
                        <Label text="Tunisie" style="-fx-font-size:13; -fx-text-fill:#555;"/>
                    </VBox>
                    <VBox spacing="14" prefWidth="540"
                          style="-fx-background-color:#f8f9fa; -fx-background-radius:16;
                                 -fx-border-color:#eeeeee; -fx-border-radius:16;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,4); -fx-padding:28;">
                        <HBox spacing="12">
                            <TextField fx:id="contactNom" promptText="Votre nom" HBox.hgrow="ALWAYS"
                                       style="-fx-background-color:white; -fx-border-color:#e0e0e0;
                                              -fx-border-radius:8; -fx-background-radius:8;
                                              -fx-padding:11 14 11 14; -fx-font-size:13;"/>
                            <TextField fx:id="contactEmail" promptText="Votre email" HBox.hgrow="ALWAYS"
                                       style="-fx-background-color:white; -fx-border-color:#e0e0e0;
                                              -fx-border-radius:8; -fx-background-radius:8;
                                              -fx-padding:11 14 11 14; -fx-font-size:13;"/>
                        </HBox>
                        <TextField fx:id="contactSujet" promptText="Sujet"
                                   style="-fx-background-color:white; -fx-border-color:#e0e0e0;
                                          -fx-border-radius:8; -fx-background-radius:8;
                                          -fx-padding:11 14 11 14; -fx-font-size:13;"/>
                        <TextArea fx:id="contactMessage" promptText="Votre message..." prefRowCount="3"
                                  style="-fx-background-color:white; -fx-border-color:#e0e0e0;
                                         -fx-border-radius:8; -fx-background-radius:8;
                                         -fx-padding:11 14 11 14; -fx-font-size:13;"/>
                        <Label fx:id="contactStatus" text="" wrapText="true"
                               style="-fx-font-size:12;" visible="false" managed="false"/>
                        <Button text="Envoyer le message" onAction="#onContactSend" maxWidth="Infinity"
                                style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                                       -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;
                                       -fx-padding:12 0 12 0; -fx-background-radius:10;
                                       -fx-cursor:hand; -fx-border-width:0;"/>
                    </VBox>
                </HBox>

                <!-- FOOTER -->
                <VBox alignment="CENTER" spacing="8" prefHeight="60"
                      style="-fx-background-color:#1e1e1e; -fx-padding:16 80 16 80;">
                    <Label text="&#169; 2026 AutoLearn - Tous droits reserves - Tunisie"
                           style="-fx-text-fill:rgba(255,255,255,0.4); -fx-font-size:12;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
