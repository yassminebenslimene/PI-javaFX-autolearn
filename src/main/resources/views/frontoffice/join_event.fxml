<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.evenement.front.JoinEventController"
            prefWidth="1200" prefHeight="760"
            style="-fx-background-color:#f0f0f8;">

    <!-- NAVBAR fixe -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.96);
                     -fx-min-height:68; -fx-max-height:68;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),10,0,0,3);">
            <padding><Insets left="36" right="36"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🎓" style="-fx-font-size:24;"/>
                <Label text="AutoLearn" style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:white;"/>
            </HBox>
            <HBox spacing="0" alignment="CENTER" style="-fx-padding:0 0 0 36;">
                <Button text="Accueil" onAction="#onHome"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
                <Button text="Événements" onAction="#onEvenements"
                        style="-fx-background-color:transparent; -fx-text-fill:rgba(255,255,255,0.75);
                               -fx-font-size:13; -fx-cursor:hand; -fx-padding:8 16 8 16; -fx-border-width:0;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="12">
                <Label fx:id="labelAvatarNav"
                       style="-fx-background-color:rgba(255,255,255,0.25); -fx-text-fill:white;
                              -fx-font-weight:700; -fx-font-size:14; -fx-background-radius:50%;
                              -fx-padding:8 11 8 11;"/>
                <Label fx:id="labelCurrentUser" text=""
                       style="-fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;"/>
                <MenuButton fx:id="menuUser" text="▾"
                            style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                   -fx-font-size:13; -fx-padding:7 14 7 14; -fx-background-radius:20;
                                   -fx-cursor:hand; -fx-border-width:0;">
                    <items>
                        <MenuItem text="👤  Mon Profil" onAction="#onProfile"/>
                        <MenuItem text="🏆  Mes Participations" onAction="#onMesParticipations"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="⎋  Déconnexion" onAction="#onLogout"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" focusTraversable="false"
                    style="-fx-background-color:#f0f0f8; -fx-background:transparent; -fx-border-width:0;">
            <VBox spacing="0">
                <!-- Header gradient -->
                <VBox alignment="CENTER" spacing="8" prefHeight="140"
                      style="-fx-background-color:linear-gradient(to bottom right,#7a6ad8,#4e3b9c); -fx-padding:30 80 30 80;">
                    <Button text="← Back to Events" onAction="#onBack"
                            style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                                   -fx-font-size:12; -fx-padding:6 16 6 16; -fx-background-radius:20;
                                   -fx-cursor:hand; -fx-border-width:0;" HBox.hgrow="NEVER"/>
                    <Label text="🎯  Join the Event"
                           style="-fx-font-size:30; -fx-font-weight:800; -fx-text-fill:white;"/>
                    <Label fx:id="labelEventName" text=""
                           style="-fx-font-size:14; -fx-text-fill:rgba(255,255,255,0.75);"/>
                </VBox>

                <!-- Why Participate -->
                <VBox spacing="20" style="-fx-background-color:white; -fx-padding:40 80 40 80;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🚀" style="-fx-font-size:22;"/>
                        <Label text="Why Participate in Our Events?"
                               style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                    </HBox>
                    <Label text="Our events are carefully designed to provide you with practical, hands-on experience that goes beyond traditional classroom learning."
                           wrapText="true" style="-fx-font-size:13; -fx-text-fill:#555;"/>
                    <HBox spacing="16">
                        <VBox spacing="8" prefWidth="220"
                              style="-fx-background-color:#f8f8ff; -fx-background-radius:12;
                                     -fx-border-color:#e8e4ff; -fx-border-radius:12; -fx-padding:20;">
                            <Label text="🤝  Networking" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                            <Label text="Connect with peers, mentors, and industry professionals to expand your professional network."
                                   wrapText="true" style="-fx-font-size:11; -fx-text-fill:#666;"/>
                        </VBox>
                        <VBox spacing="8" prefWidth="220"
                              style="-fx-background-color:#f8f8ff; -fx-background-radius:12;
                                     -fx-border-color:#e8e4ff; -fx-border-radius:12; -fx-padding:20;">
                            <Label text="💬  Communication" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                            <Label text="Enhance your ability to articulate ideas, collaborate effectively, and present solutions."
                                   wrapText="true" style="-fx-font-size:11; -fx-text-fill:#666;"/>
                        </VBox>
                        <VBox spacing="8" prefWidth="220"
                              style="-fx-background-color:#f8f8ff; -fx-background-radius:12;
                                     -fx-border-color:#e8e4ff; -fx-border-radius:12; -fx-padding:20;">
                            <Label text="👥  Teamwork" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                            <Label text="Learn to work efficiently in teams, manage conflicts, and leverage diverse perspectives."
                                   wrapText="true" style="-fx-font-size:11; -fx-text-fill:#666;"/>
                        </VBox>
                        <VBox spacing="8" prefWidth="220"
                              style="-fx-background-color:#f8f8ff; -fx-background-radius:12;
                                     -fx-border-color:#e8e4ff; -fx-border-radius:12; -fx-padding:20;">
                            <Label text="🔧  Technical Skills" style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:#7a6ad8;"/>
                            <Label text="Apply what you've learned through practical projects, hackathons, and workshops."
                                   wrapText="true" style="-fx-font-size:11; -fx-text-fill:#666;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Choose Your Path -->
                <VBox spacing="24" style="-fx-background-color:#f0f0f8; -fx-padding:40 80 40 80;">
                    <Label text="Choose Your Path"
                           style="-fx-font-size:22; -fx-font-weight:800; -fx-text-fill:#1e1e1e; -fx-alignment:CENTER;"/>
                    <HBox spacing="24" alignment="CENTER">
                        <VBox spacing="16" prefWidth="380" alignment="CENTER"
                              style="-fx-background-color:white; -fx-background-radius:16;
                                     -fx-border-color:#eeeeee; -fx-border-radius:16;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);
                                     -fx-padding:36;">
                            <Label text="👥" style="-fx-font-size:40; -fx-background-color:#7a6ad8;
                                          -fx-background-radius:50%; -fx-padding:16 18 16 18; -fx-text-fill:white;"/>
                            <Label text="Join an Existing Team"
                                   style="-fx-font-size:16; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                            <Label text="Connect with students who are already registered for this event. Teams can have up to 6 members, so you can join any team with available spots."
                                   wrapText="true" style="-fx-font-size:12; -fx-text-fill:#666; -fx-text-alignment:CENTER;"/>
                            <Label fx:id="labelJoinStatus" text=""
                                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:#e94560;"/>
                            <VBox fx:id="joinTeamsContainer" spacing="8"/>
                        </VBox>
                        <VBox spacing="16" prefWidth="380" alignment="CENTER"
                              style="-fx-background-color:white; -fx-background-radius:16;
                                     -fx-border-color:#eeeeee; -fx-border-radius:16;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);
                                     -fx-padding:36;">
                            <Label text="✨" style="-fx-font-size:40; -fx-background-color:#7a6ad8;
                                          -fx-background-radius:50%; -fx-padding:16 18 16 18; -fx-text-fill:white;"/>
                            <Label text="Create a New Team"
                                   style="-fx-font-size:16; -fx-font-weight:800; -fx-text-fill:#1e1e1e;"/>
                            <Label text="Start your own team with your classmates! Select 4 to 6 students and give your team a unique name. You'll automatically be registered for this event."
                                   wrapText="true" style="-fx-font-size:12; -fx-text-fill:#666; -fx-text-alignment:CENTER;"/>
                            <Button text="Create New Team" onAction="#onCreateTeam"
                                    style="-fx-background-color:#7a6ad8; -fx-text-fill:white; -fx-font-size:13;
                                           -fx-font-weight:700; -fx-padding:12 32 12 32; -fx-background-radius:10;
                                           -fx-cursor:hand; -fx-border-width:0;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="56" style="-fx-background-color:#1e1e1e;">
            <Label text="&#169; 2026 AutoLearn &#8212; Tous droits r&#233;serv&#233;s"
                   style="-fx-text-fill:rgba(255,255,255,0.45); -fx-font-size:12;"/>
        </HBox>
    </bottom>
</BorderPane>