<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ProfileController"
            maxWidth="Infinity" maxHeight="Infinity"
            style="-fx-background-color:#0f0c29;">

    <!-- Navbar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.96);
                     -fx-min-height:64; -fx-max-height:64;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),12,0,0,4);">
            <padding><Insets left="36" right="36"/></padding>
            <Label text="🎓" style="-fx-font-size:22;"/>
            <Label text="  AutoLearn"
                   style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Retour" onAction="#onBack"
                    style="-fx-background-color:rgba(255,255,255,0.18); -fx-text-fill:white;
                           -fx-font-size:12; -fx-font-weight:600; -fx-cursor:hand;
                           -fx-border-width:0; -fx-padding:8 20 8 20; -fx-background-radius:20;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:#0f0c29; -fx-background:transparent; -fx-border-width:0;">
            <VBox alignment="TOP_CENTER" spacing="0"
                  style="-fx-background-color:linear-gradient(to bottom,#0f0c29,#302b63,#24243e);">

                <!-- Hero compact -->
                <VBox alignment="CENTER" spacing="16" prefHeight="220"
                      style="-fx-background-color:linear-gradient(to bottom right,#7a6ad8,#4e3b9c);
                             -fx-padding:36 80 36 80;">
                    <StackPane minWidth="90" minHeight="90" prefWidth="90" prefHeight="90">
                        <Circle radius="45"
                                style="-fx-fill:rgba(255,255,255,0.15);
                                       -fx-effect:dropshadow(gaussian,rgba(122,106,216,0.8),20,0,0,0);"/>
                        <Label fx:id="labelInitials" text=""
                               style="-fx-text-fill:white; -fx-font-size:30; -fx-font-weight:800;"/>
                    </StackPane>
                    <Label fx:id="labelFullName" text=""
                           style="-fx-font-size:26; -fx-font-weight:800; -fx-text-fill:white;"/>
                    <Label fx:id="labelEmailHeader" text=""
                           style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.7);"/>
                    <HBox alignment="CENTER" spacing="8">
                        <Label fx:id="labelRole" text=""
                               style="-fx-background-color:rgba(255,255,255,0.2); -fx-text-fill:white;
                                      -fx-background-radius:20; -fx-padding:4 14 4 14;
                                      -fx-font-size:12; -fx-font-weight:700;"/>
                        <Label fx:id="labelNiveauBadge" text=""
                               style="-fx-background-color:rgba(251,191,36,0.25); -fx-text-fill:#fbbf24;
                                      -fx-background-radius:20; -fx-padding:4 14 4 14;
                                      -fx-font-size:12; -fx-font-weight:700;"
                               visible="false" managed="false"/>
                    </HBox>
                </VBox>

                <!-- Form area -->
                <VBox alignment="TOP_CENTER" spacing="20"
                      style="-fx-padding:32 0 48 0;">
                    <VBox spacing="20" prefWidth="720" maxWidth="720">

                        <!-- Success -->
                        <Label fx:id="successLabel" text="" wrapText="true"
                               style="-fx-background-color:rgba(52,211,153,0.15);
                                      -fx-border-color:#34d399; -fx-border-width:0 0 0 4;
                                      -fx-border-radius:8; -fx-background-radius:8;
                                      -fx-text-fill:#34d399; -fx-font-size:13; -fx-font-weight:700;
                                      -fx-padding:14 20 14 20;"
                               visible="false" managed="false"/>

                        <!-- Infos card -->
                        <VBox spacing="0"
                              style="-fx-background-color:rgba(255,255,255,0.06);
                                     -fx-background-radius:16;
                                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:16;
                                     -fx-border-width:1;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),20,0,0,4);">
                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-padding:18 24 14 24;
                                         -fx-border-color:transparent transparent rgba(255,255,255,0.08) transparent;
                                         -fx-border-width:0 0 1 0;">
                                <Label text="Informations Personnelles"
                                       style="-fx-font-size:15; -fx-font-weight:700; -fx-text-fill:white;"/>
                            </HBox>
                            <VBox spacing="16" style="-fx-padding:20 24 24 24;">
                                <HBox spacing="16">
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="Prénom"
                                               style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.6);"/>
                                        <TextField fx:id="fieldPrenom" promptText="Votre prénom"
                                                   style="-fx-background-color:rgba(255,255,255,0.08);
                                                          -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                                          -fx-background-radius:10; -fx-padding:11 14 11 14;
                                                          -fx-font-size:13; -fx-text-fill:white;
                                                          -fx-prompt-text-fill:rgba(255,255,255,0.3);"/>
                                        <Label fx:id="errorPrenom"
                                               style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="12"/>
                                    </VBox>
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="Nom"
                                               style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.6);"/>
                                        <TextField fx:id="fieldNom" promptText="Votre nom"
                                                   style="-fx-background-color:rgba(255,255,255,0.08);
                                                          -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                                          -fx-background-radius:10; -fx-padding:11 14 11 14;
                                                          -fx-font-size:13; -fx-text-fill:white;
                                                          -fx-prompt-text-fill:rgba(255,255,255,0.3);"/>
                                        <Label fx:id="errorNom"
                                               style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="12"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="16">
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="Email"
                                               style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.6);"/>
                                        <TextField fx:id="fieldEmail" promptText="votre@email.com"
                                                   style="-fx-background-color:rgba(255,255,255,0.08);
                                                          -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                                          -fx-background-radius:10; -fx-padding:11 14 11 14;
                                                          -fx-font-size:13; -fx-text-fill:white;
                                                          -fx-prompt-text-fill:rgba(255,255,255,0.3);"/>
                                        <Label fx:id="errorEmail"
                                               style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="12"/>
                                    </VBox>
                                    <VBox fx:id="labelNiveauRow" spacing="6" HBox.hgrow="ALWAYS"
                                          visible="false" managed="false">
                                        <Label text="Niveau"
                                               style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.6);"/>
                                        <ComboBox fx:id="comboNiveau" maxWidth="Infinity"
                                                  style="-fx-background-color:rgba(255,255,255,0.08);
                                                         -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                                         -fx-background-radius:10; -fx-font-size:13;"/>
                                    </VBox>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- Password card -->
                        <VBox spacing="0"
                              style="-fx-background-color:rgba(255,255,255,0.06);
                                     -fx-background-radius:16;
                                     -fx-border-color:rgba(255,255,255,0.1); -fx-border-radius:16;
                                     -fx-border-width:1;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.3),20,0,0,4);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding:18 24 14 24;
                                         -fx-border-color:transparent transparent rgba(255,255,255,0.08) transparent;
                                         -fx-border-width:0 0 1 0;">
                                <Label text="Sécurité"
                                       style="-fx-font-size:15; -fx-font-weight:700; -fx-text-fill:white;"/>
                            </HBox>
                            <HBox spacing="16" style="-fx-padding:20 24 24 24;">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="Nouveau mot de passe"
                                           style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.6);"/>
                                    <PasswordField fx:id="fieldPassword" promptText="••••••••"
                                                   style="-fx-background-color:rgba(255,255,255,0.08);
                                                          -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                                          -fx-background-radius:10; -fx-padding:11 14 11 14;
                                                          -fx-font-size:13; -fx-text-fill:white;
                                                          -fx-prompt-text-fill:rgba(255,255,255,0.3);"/>
                                    <Label fx:id="errorPassword"
                                           style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="12"/>
                                </VBox>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="Confirmer"
                                           style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.6);"/>
                                    <PasswordField fx:id="fieldConfirmPassword" promptText="••••••••"
                                                   style="-fx-background-color:rgba(255,255,255,0.08);
                                                          -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                                          -fx-background-radius:10; -fx-padding:11 14 11 14;
                                                          -fx-font-size:13; -fx-text-fill:white;
                                                          -fx-prompt-text-fill:rgba(255,255,255,0.3);"/>
                                    <Label fx:id="errorConfirmPassword"
                                           style="-fx-text-fill:#f87171; -fx-font-size:11;" minHeight="12"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Save -->
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Sauvegarder" onAction="#onSave"
                                    style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                                           -fx-text-fill:white; -fx-font-size:14; -fx-font-weight:700;
                                           -fx-padding:13 40 13 40; -fx-background-radius:12;
                                           -fx-cursor:hand; -fx-border-width:0;
                                           -fx-effect:dropshadow(gaussian,rgba(122,106,216,0.5),14,0,0,4);"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
