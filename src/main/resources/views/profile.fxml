
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.ProfileController"
            maxWidth="Infinity" maxHeight="Infinity"
            style="-fx-background-color:#f8f9fa;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:rgba(122,106,216,0.96); -fx-min-height:64; -fx-max-height:64;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.18),10,0,0,3);">
            <padding><Insets left="36" right="36"/></padding>
            <Label text="🎓" style="-fx-font-size:22;"/>
            <Label text="  AutoLearn" style="-fx-font-size:18; -fx-font-weight:800; -fx-text-fill:white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Retour" onAction="#onBack"
                    style="-fx-background-color:rgba(255,255,255,0.18); -fx-text-fill:white;
                           -fx-font-size:12; -fx-font-weight:600; -fx-cursor:hand;
                           -fx-border-width:0; -fx-padding:8 20 8 20; -fx-background-radius:20;"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:#f8f9fa; -fx-background:transparent; -fx-border-width:0;">
            <VBox alignment="TOP_CENTER" spacing="0" style="-fx-background-color:#f8f9fa;">

                <!-- Hero compact -->
                <HBox alignment="CENTER_LEFT" spacing="28"
                      style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                             -fx-padding:32 80 32 80;">
                    <StackPane minWidth="80" minHeight="80" prefWidth="80" prefHeight="80">
                        <Circle radius="40" style="-fx-fill:rgba(255,255,255,0.2);"/>
                        <Label fx:id="labelInitials" text=""
                               style="-fx-text-fill:white; -fx-font-size:26; -fx-font-weight:800;"/>
                    </StackPane>
                    <VBox spacing="4">
                        <Label fx:id="labelFullName" text=""
                               style="-fx-font-size:24; -fx-font-weight:800; -fx-text-fill:white;"/>
                        <Label fx:id="labelEmailHeader" text=""
                               style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.75);"/>
                        <HBox spacing="8">
                            <Label fx:id="labelRole" text=""
                                   style="-fx-background-color:rgba(255,255,255,0.2); -fx-text-fill:white;
                                          -fx-background-radius:20; -fx-padding:3 12 3 12;
                                          -fx-font-size:11; -fx-font-weight:700;"/>
                            <Label fx:id="labelNiveauBadge" text=""
                                   style="-fx-background-color:rgba(251,191,36,0.3); -fx-text-fill:#fef3c7;
                                          -fx-background-radius:20; -fx-padding:3 12 3 12;
                                          -fx-font-size:11; -fx-font-weight:700;"
                                   visible="false" managed="false"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Form -->
                <VBox alignment="TOP_CENTER" spacing="16" style="-fx-padding:28 80 40 80;">
                    <VBox spacing="16" prefWidth="800" maxWidth="800">

                        <!-- Success -->
                        <Label fx:id="successLabel" text="" wrapText="true"
                               style="-fx-background-color:#d1fae5; -fx-border-color:#059669;
                                      -fx-border-width:0 0 0 4; -fx-border-radius:6; -fx-background-radius:6;
                                      -fx-text-fill:#065f46; -fx-font-size:13; -fx-font-weight:700;
                                      -fx-padding:12 18 12 18;"
                               visible="false" managed="false"/>

                        <!-- Infos Personnelles -->
                        <VBox spacing="0"
                              style="-fx-background-color:white; -fx-background-radius:14;
                                     -fx-border-color:#e8e8e8; -fx-border-radius:14;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,3);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding:16 22 12 22;
                                         -fx-border-color:transparent transparent #f0f0f0 transparent;
                                         -fx-border-width:0 0 1 0;">
                                <Label text="Informations Personnelles"
                                       style="-fx-font-size:15; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </HBox>
                            <VBox spacing="14" style="-fx-padding:18 22 22 22;">
                                <HBox spacing="16">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Prénom" style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:#555;"/>
                                        <TextField fx:id="fieldPrenom" promptText="Votre prénom"
                                                   style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                                          -fx-border-radius:8; -fx-background-radius:8;
                                                          -fx-padding:10 14 10 14; -fx-font-size:13;"/>
                                        <Label fx:id="errorPrenom" style="-fx-text-fill:#e74c3c; -fx-font-size:11;" minHeight="12"/>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Nom" style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:#555;"/>
                                        <TextField fx:id="fieldNom" promptText="Votre nom"
                                                   style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                                          -fx-border-radius:8; -fx-background-radius:8;
                                                          -fx-padding:10 14 10 14; -fx-font-size:13;"/>
                                        <Label fx:id="errorNom" style="-fx-text-fill:#e74c3c; -fx-font-size:11;" minHeight="12"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="16">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Email" style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:#555;"/>
                                        <TextField fx:id="fieldEmail" promptText="votre@email.com"
                                                   style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                                          -fx-border-radius:8; -fx-background-radius:8;
                                                          -fx-padding:10 14 10 14; -fx-font-size:13;"/>
                                        <Label fx:id="errorEmail" style="-fx-text-fill:#e74c3c; -fx-font-size:11;" minHeight="12"/>
                                    </VBox>
                                    <VBox fx:id="labelNiveauRow" spacing="5" HBox.hgrow="ALWAYS"
                                          visible="false" managed="false">
                                        <Label text="Niveau" style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:#555;"/>
                                        <ComboBox fx:id="comboNiveau" maxWidth="Infinity"
                                                  style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                                         -fx-border-radius:8; -fx-background-radius:8; -fx-font-size:13;"/>
                                    </VBox>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- Sécurité -->
                        <VBox spacing="0"
                              style="-fx-background-color:white; -fx-background-radius:14;
                                     -fx-border-color:#e8e8e8; -fx-border-radius:14;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,3);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding:16 22 12 22;
                                         -fx-border-color:transparent transparent #f0f0f0 transparent;
                                         -fx-border-width:0 0 1 0;">
                                <Label text="Changer le mot de passe"
                                       style="-fx-font-size:15; -fx-font-weight:700; -fx-text-fill:#1e1e1e;"/>
                            </HBox>
                            <HBox spacing="16" style="-fx-padding:18 22 22 22;">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="Nouveau mot de passe" style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:#555;"/>
                                    <PasswordField fx:id="fieldPassword" promptText="••••••••"
                                                   style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                                          -fx-border-radius:8; -fx-background-radius:8;
                                                          -fx-padding:10 14 10 14; -fx-font-size:13;"/>
                                    <Label text="Laissez vide pour ne pas changer"
                                           style="-fx-text-fill:#aaa; -fx-font-size:11;"/>
                                    <Label fx:id="errorPassword" style="-fx-text-fill:#e74c3c; -fx-font-size:11;" minHeight="12"/>
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="Confirmer" style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:#555;"/>
                                    <PasswordField fx:id="fieldConfirmPassword" promptText="••••••••"
                                                   style="-fx-background-color:#f9f9f9; -fx-border-color:#e0e0e0;
                                                          -fx-border-radius:8; -fx-background-radius:8;
                                                          -fx-padding:10 14 10 14; -fx-font-size:13;"/>
                                    <Label fx:id="errorConfirmPassword" style="-fx-text-fill:#e74c3c; -fx-font-size:11;" minHeight="12"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Save -->
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Sauvegarder les modifications" onAction="#onSave"
                                    style="-fx-background-color:linear-gradient(to right,#7a6ad8,#4e3b9c);
                                           -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:700;
                                           -fx-padding:12 36 12 36; -fx-background-radius:12;
                                           -fx-cursor:hand; -fx-border-width:0;
                                           -fx-effect:dropshadow(gaussian,rgba(122,106,216,0.35),10,0,0,3);"/>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
