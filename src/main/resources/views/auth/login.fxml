<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.LoginController"
      prefWidth="900" prefHeight="580">

    <!-- LEFT PANEL — brand -->
    <VBox prefWidth="380" alignment="CENTER" spacing="16"
          style="-fx-background-color:#1a1a2e;">
        <padding><Insets top="60" right="50" bottom="60" left="50"/></padding>
        <Label text="🎓" style="-fx-font-size:52;"/>
        <Label text="AutoLearn" style="-fx-font-size:32; -fx-font-weight:bold; -fx-text-fill:white;"/>
        <Label text="Plateforme d'apprentissage en ligne"
               style="-fx-font-size:13; -fx-text-fill:#8892b0; -fx-wrap-text:true;"
               wrapText="true" textAlignment="CENTER"/>
        <Region prefHeight="20"/>
        <Label text="« Apprenez. Progressez. Réussissez. »"
               style="-fx-font-size:12; -fx-text-fill:#e94560; -fx-font-style:italic;"
               wrapText="true" textAlignment="CENTER"/>
    </VBox>

    <!-- RIGHT PANEL — form -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
          style="-fx-background-color:#f8f9fa;">
        <padding><Insets top="0" right="60" bottom="0" left="60"/></padding>

        <VBox spacing="6" maxWidth="360">
            <Label text="Connexion" style="-fx-font-size:26; -fx-font-weight:bold; -fx-text-fill:#1a1a2e;"/>
            <Label text="Bienvenue ! Connectez-vous à votre compte."
                   style="-fx-font-size:13; -fx-text-fill:#6c757d;"/>

            <Region prefHeight="20"/>

            <!-- Email -->
            <Label text="Adresse email" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#495057;"/>
            <TextField fx:id="fieldEmail" promptText="votre@email.com"
                       style="-fx-background-color:white; -fx-border-color:#dee2e6; -fx-border-radius:8;
                              -fx-background-radius:8; -fx-padding:10 14 10 14; -fx-font-size:13;"/>

            <Region prefHeight="8"/>

            <!-- Password label + forgot -->
            <HBox alignment="CENTER_LEFT">
                <Label text="Mot de passe" style="-fx-font-size:12; -fx-font-weight:bold; -fx-text-fill:#495057;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Mot de passe oublié ?" onAction="#onForgotPassword"
                        style="-fx-background-color:transparent; -fx-text-fill:#e94560; -fx-font-size:11;
                               -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
            </HBox>
            <PasswordField fx:id="fieldPassword" promptText="••••••••"
                           style="-fx-background-color:white; -fx-border-color:#dee2e6; -fx-border-radius:8;
                                  -fx-background-radius:8; -fx-padding:10 14 10 14; -fx-font-size:13;"/>

            <Region prefHeight="4"/>

            <!-- Remember me -->
            <CheckBox fx:id="checkRememberMe" text="Se souvenir de moi"
                      style="-fx-font-size:12; -fx-text-fill:#495057;"/>

            <!-- Error -->
            <Label fx:id="errorLabel" text="" wrapText="true"
                   style="-fx-text-fill:#e74c3c; -fx-font-size:12; -fx-background-color:#fdecea;
                          -fx-background-radius:6; -fx-padding:8 12 8 12;" managed="false" visible="false"/>

            <Region prefHeight="8"/>

            <!-- Submit -->
            <Button text="Se connecter →" onAction="#onLogin" maxWidth="Infinity"
                    style="-fx-background-color:#1a1a2e; -fx-text-fill:white; -fx-font-size:14;
                           -fx-font-weight:bold; -fx-padding:12 0 12 0; -fx-background-radius:8;
                           -fx-cursor:hand;"/>

            <Region prefHeight="16"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Pas encore de compte ?" style="-fx-font-size:12; -fx-text-fill:#6c757d;"/>
                <Button text="S'inscrire" onAction="#onGoToRegister"
                        style="-fx-background-color:transparent; -fx-text-fill:#1a1a2e; -fx-font-size:12;
                               -fx-font-weight:bold; -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;
                               -fx-underline:true;"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
