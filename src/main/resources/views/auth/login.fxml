<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!-- Glassmorphism dark — matches Symfony backoffice/cnx/login.html.twig -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.controllers.LoginController"
           maxWidth="Infinity" maxHeight="Infinity"
           style="-fx-background-color:#0a0f0d;">

    <!-- Background orbs -->
    <StackPane style="-fx-background-color:transparent;" mouseTransparent="true">
        <StackPane prefWidth="400" prefHeight="400"
                   style="-fx-background-color:radial-gradient(center 50% 50%, radius 50%, rgba(5,150,105,0.18), transparent);
                          -fx-background-radius:200;"
                   translateX="-260" translateY="-160"/>
        <StackPane prefWidth="320" prefHeight="320"
                   style="-fx-background-color:radial-gradient(center 50% 50%, radius 50%, rgba(99,102,241,0.14), transparent);
                          -fx-background-radius:160;"
                   translateX="280" translateY="180"/>
        <StackPane prefWidth="260" prefHeight="260"
                   style="-fx-background-color:radial-gradient(center 50% 50%, radius 50%, rgba(5,150,105,0.10), transparent);
                          -fx-background-radius:130;"
                   translateX="200" translateY="-200"/>
    </StackPane>

    <!-- Glass card -->
    <VBox alignment="CENTER" spacing="0" maxWidth="420"
          style="-fx-background-color:rgba(255,255,255,0.06);
                 -fx-background-radius:24;
                 -fx-border-color:rgba(255,255,255,0.12); -fx-border-radius:24;
                 -fx-border-width:1;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.5),40,0,0,16);
                 -fx-padding:44 44 40 44;">

        <!-- Header: logo + title -->
        <VBox alignment="CENTER" spacing="10" style="-fx-padding:0 0 28 0;">
            <Label text="G"
                   style="-fx-background-color:linear-gradient(to bottom right,#34d399,#059669);
                          -fx-text-fill:white; -fx-font-size:26; -fx-font-weight:800;
                          -fx-background-radius:16; -fx-padding:12 18 12 18;
                          -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.5),12,0,0,4);"/>
            <Label text="Welcome Back"
                   style="-fx-font-size:24; -fx-font-weight:700; -fx-text-fill:white;"/>
            <Label text="Sign in to continue to AutoLearn"
                   style="-fx-font-size:13; -fx-text-fill:rgba(245,245,244,0.5);"/>
        </VBox>

        <!-- Error label -->
        <Label fx:id="errorLabel" text="" wrapText="true" maxWidth="340"
               style="-fx-text-fill:#f87171; -fx-font-size:12;
                      -fx-background-color:rgba(220,38,38,0.12);
                      -fx-background-radius:8; -fx-padding:10 14 10 14;
                      -fx-border-color:rgba(220,38,38,0.3); -fx-border-radius:8; -fx-border-width:1;"
               visible="false" managed="false"/>
        <Region fx:id="errorSpacer" prefHeight="0" managed="false"/>

        <!-- Form -->
        <VBox spacing="6">
            <Label text="Email Address"
                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.7);"/>
            <ComboBox fx:id="fieldEmail" promptText="Enter your email" editable="true"
                      maxWidth="Infinity"
                      style="-fx-background-color:rgba(255,255,255,0.08);
                             -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                             -fx-background-radius:10;
                             -fx-font-size:13; -fx-text-fill:white;"/>

            <Region prefHeight="8"/>

            <HBox alignment="CENTER_LEFT">
                <Label text="Password"
                       style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.7);"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Forgot Password?" onAction="#onForgotPassword"
                        style="-fx-background-color:transparent; -fx-text-fill:#34d399;
                               -fx-font-size:11; -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
            </HBox>
            <PasswordField fx:id="fieldPassword" promptText="Enter your password"
                           style="-fx-background-color:rgba(255,255,255,0.08);
                                  -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                  -fx-background-radius:10; -fx-padding:12 16 12 16;
                                  -fx-font-size:13; -fx-text-fill:white;
                                  -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>

            <Region prefHeight="4"/>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <CheckBox fx:id="checkRememberMe"
                          style="-fx-text-fill:rgba(245,245,244,0.6); -fx-font-size:12;"/>
                <Label text="Remember me"
                       style="-fx-text-fill:rgba(245,245,244,0.6); -fx-font-size:12;"/>
            </HBox>

            <Region prefHeight="12"/>

            <!-- Sign In button -->
            <Button text="Sign In  →" onAction="#onLogin" maxWidth="Infinity"
                    style="-fx-background-color:linear-gradient(to right,#34d399,#059669);
                           -fx-text-fill:white; -fx-font-size:14; -fx-font-weight:700;
                           -fx-padding:13 0 13 0; -fx-background-radius:12;
                           -fx-cursor:hand; -fx-border-width:0;
                           -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.45),12,0,0,4);"/>

            <Region prefHeight="16"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?"
                       style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.45);"/>
                <Button text="Create Account" onAction="#onGoToRegister"
                        style="-fx-background-color:transparent; -fx-text-fill:#34d399;
                               -fx-font-size:12; -fx-font-weight:600;
                               -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
