<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.LoginController"
      maxWidth="Infinity" maxHeight="Infinity">

    <!-- LEFT: white form -->
    <VBox spacing="0" alignment="CENTER" prefWidth="500" minWidth="420"
          style="-fx-background-color:white;">

        <VBox spacing="28" maxWidth="360">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Auto" style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#7a6ad8;"/>
                <Label text="Learn" style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"/>
            </HBox>

            <VBox spacing="6">
                <Label text="Bon retour !"
                       style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"/>
                <Label text="Connectez-vous pour continuer"
                       style="-fx-font-size:13; -fx-text-fill:#888;"/>
            </VBox>

            <Label fx:id="errorLabel" text="" wrapText="true" maxWidth="360"
                   style="-fx-text-fill:#dc2626; -fx-font-size:12; -fx-background-color:#fef2f2;
                          -fx-background-radius:8; -fx-padding:10 14 10 14; -fx-border-color:#fecaca;
                          -fx-border-radius:8; -fx-border-width:1;"
                   visible="false" managed="false"/>

            <VBox spacing="16">
                <VBox spacing="6">
                    <Label text="Adresse email"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151;"/>
                    <TextField fx:id="fieldEmail" promptText="exemple@domaine.com"
                               style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                      -fx-border-radius:10; -fx-background-radius:10;
                                      -fx-padding:13 16 13 16; -fx-font-size:14;"/>
                </VBox>

                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mot de passe"
                               style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Oublie ?" onAction="#onForgotPassword"
                                style="-fx-background-color:transparent; -fx-text-fill:#7a6ad8;
                                       -fx-font-size:12; -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
                    </HBox>
                    <StackPane>
                        <PasswordField fx:id="fieldPassword" promptText="Votre mot de passe"
                                       style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                              -fx-border-radius:10; -fx-background-radius:10;
                                              -fx-padding:13 44 13 16; -fx-font-size:14;"/>
                        <TextField fx:id="fieldPasswordVisible" promptText="Votre mot de passe"
                                   visible="false" managed="false"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:10; -fx-background-radius:10;
                                          -fx-padding:13 44 13 16; -fx-font-size:14;"/>
                        <Button fx:id="btnTogglePassword" text="&#128065;" onAction="#onTogglePassword"
                                style="-fx-background-color:transparent; -fx-border-width:0;
                                       -fx-cursor:hand; -fx-font-size:15; -fx-text-fill:#9ca3af;
                                       -fx-padding:0 14 0 0;"
                                StackPane.alignment="CENTER_RIGHT"/>
                    </StackPane>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <CheckBox fx:id="checkRememberMe"/>
                    <Label text="Se souvenir de moi" style="-fx-font-size:13; -fx-text-fill:#6b7280;"/>
                </HBox>

                <Button text="Se connecter" onAction="#onLogin" maxWidth="Infinity"
                        style="-fx-background-color:#7a6ad8; -fx-text-fill:white;
                               -fx-font-size:15; -fx-font-weight:700; -fx-padding:14 0 14 0;
                               -fx-background-radius:10; -fx-cursor:hand; -fx-border-width:0;"/>

                <HBox alignment="CENTER" spacing="12">
                    <Line endX="120" style="-fx-stroke:#e5e7eb;"/>
                    <Label text="ou" style="-fx-font-size:12; -fx-text-fill:#aaa;"/>
                    <Line endX="120" style="-fx-stroke:#e5e7eb;"/>
                </HBox>

                <HBox alignment="CENTER" spacing="12">
                    <VBox alignment="CENTER" prefWidth="100" prefHeight="44"
                          style="-fx-background-color:#f9fafb; -fx-background-radius:10;
                                 -fx-border-color:#e5e7eb; -fx-border-radius:10; -fx-border-width:1;">
                        <Label text="G" style="-fx-font-size:18; -fx-font-weight:900; -fx-text-fill:#ea4335;"/>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="100" prefHeight="44"
                          style="-fx-background-color:#f9fafb; -fx-background-radius:10;
                                 -fx-border-color:#e5e7eb; -fx-border-radius:10; -fx-border-width:1;">
                        <Label text="f" style="-fx-font-size:18; -fx-font-weight:900; -fx-text-fill:#1877f2;"/>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="100" prefHeight="44"
                          style="-fx-background-color:#f9fafb; -fx-background-radius:10;
                                 -fx-border-color:#e5e7eb; -fx-border-radius:10; -fx-border-width:1;">
                        <Label text="&#63743;" style="-fx-font-size:18; -fx-text-fill:#1a1a2e;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="10" alignment="CENTER">
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Pas encore de compte ?" style="-fx-font-size:13; -fx-text-fill:#888;"/>
                    <Button text="S'inscrire gratuitement" onAction="#onGoToRegister"
                            style="-fx-background-color:transparent; -fx-text-fill:#7a6ad8;
                                   -fx-font-size:13; -fx-font-weight:700; -fx-cursor:hand;
                                   -fx-padding:0; -fx-border-width:0;"/>
                </HBox>
                <HBox alignment="CENTER" spacing="6">
                    <Label text="&#8592;" style="-fx-font-size:12; -fx-text-fill:#ccc;"/>
                    <Button text="Retour a l'accueil" onAction="#onBackToLanding"
                            style="-fx-background-color:transparent; -fx-text-fill:#ccc;
                                   -fx-font-size:12; -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
                </HBox>
            </VBox>

        </VBox>
    </VBox>

    <!-- RIGHT: gradient with image background + centered content -->
    <StackPane HBox.hgrow="ALWAYS">

        <!-- Background image with dark overlay -->
        <ImageView fx:id="bgImage" fitWidth="800" fitHeight="760" preserveRatio="false"/>
        <Rectangle width="800" height="760"
                   style="-fx-fill:linear-gradient(to bottom right,rgba(122,106,216,0.88),rgba(78,59,156,0.92));"
                   mouseTransparent="true"/>

        <!-- Floating shapes -->
        <Circle radius="140" translateX="-180" translateY="-120"
                style="-fx-fill:rgba(255,255,255,0.06);" mouseTransparent="true"/>
        <Circle radius="100" translateX="200" translateY="140"
                style="-fx-fill:rgba(255,255,255,0.04);" mouseTransparent="true"/>

        <!-- Content centered -->
        <VBox spacing="32" alignment="CENTER" maxWidth="420"
              style="-fx-padding:60 48 60 48;">

            <!-- Quote card -->
            <VBox fx:id="quoteCard" spacing="14" alignment="CENTER"
                  style="-fx-background-color:rgba(255,255,255,0.14); -fx-background-radius:16;
                         -fx-padding:24 20 24 20; -fx-border-color:rgba(255,255,255,0.25);
                         -fx-border-radius:16; -fx-border-width:1;">
                <Label text="&#10077;"
                       style="-fx-font-size:28; -fx-text-fill:rgba(255,255,255,0.35);"/>
                <Label text="AutoLearn m'a permis de progresser a mon rythme et de decrocher mon premier poste en developpement."
                       wrapText="true" maxWidth="340"
                       style="-fx-font-size:15; -fx-font-weight:600; -fx-text-fill:white;
                              -fx-line-spacing:4; -fx-text-alignment:center;"/>
                <VBox spacing="2" alignment="CENTER">
                    <Label text="Islem B."
                           style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.95);"/>
                    <Label text="Etudiant en Informatique — Tunis"
                           style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.6);"/>
                </VBox>
            </VBox>

            <!-- Stats -->
            <HBox fx:id="statsRow" spacing="0" alignment="CENTER">
                <VBox alignment="CENTER" spacing="3" prefWidth="120">
                    <Label text="500+"
                           style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:white;"/>
                    <Label text="Etudiants"
                           style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.65);"/>
                </VBox>
                <Rectangle width="1" height="44" style="-fx-fill:rgba(255,255,255,0.25);"/>
                <VBox alignment="CENTER" spacing="3" prefWidth="120">
                    <Label text="50+"
                           style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:white;"/>
                    <Label text="Cours"
                           style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.65);"/>
                </VBox>
                <Rectangle width="1" height="44" style="-fx-fill:rgba(255,255,255,0.25);"/>
                <VBox alignment="CENTER" spacing="3" prefWidth="120">
                    <Label text="100%"
                           style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:white;"/>
                    <Label text="Gratuit"
                           style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.65);"/>
                </VBox>
            </HBox>

            <!-- Features -->
            <VBox fx:id="featuresList" spacing="10" alignment="CENTER_LEFT">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="&#128218;"
                           style="-fx-font-size:20; -fx-background-color:rgba(255,255,255,0.18);
                                  -fx-background-radius:10; -fx-padding:8 10 8 10;"/>
                    <Label text="Cours structures par des experts"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.95);"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="&#129302;"
                           style="-fx-font-size:20; -fx-background-color:rgba(255,255,255,0.18);
                                  -fx-background-radius:10; -fx-padding:8 10 8 10;"/>
                    <Label text="Correction par IA instantanee"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.95);"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="&#127942;"
                           style="-fx-font-size:20; -fx-background-color:rgba(255,255,255,0.18);
                                  -fx-background-radius:10; -fx-padding:8 10 8 10;"/>
                    <Label text="Challenges et badges"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:rgba(255,255,255,0.95);"/>
                </HBox>
            </VBox>

        </VBox>
    </StackPane>

</HBox>
