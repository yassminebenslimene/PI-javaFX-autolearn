<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.LoginController"
      maxWidth="Infinity" maxHeight="Infinity">

    <!-- LEFT: violet brand panel -->
    <VBox spacing="32" alignment="CENTER_LEFT" prefWidth="480" minWidth="380"
          style="-fx-background-color:#7a6ad8; -fx-padding:64 56 64 64;">

        <!-- Logo -->
        <VBox spacing="6">
            <Label text="AutoLearn"
                   style="-fx-font-size:28; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Label text="Votre plateforme d'apprentissage"
                   style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.7);"/>
        </VBox>

        <!-- Tagline -->
        <VBox spacing="12">
            <Label text="Apprenez. Pratiquez. Progressez."
                   style="-fx-font-size:22; -fx-font-weight:800; -fx-text-fill:white;"
                   wrapText="true"/>
            <Label text="Des cours structures, des challenges corriges par IA et des evenements tech en Tunisie."
                   wrapText="true"
                   style="-fx-font-size:14; -fx-text-fill:rgba(255,255,255,0.75); -fx-line-spacing:4; -fx-max-width:340;"/>
        </VBox>

        <!-- Feature pills -->
        <VBox spacing="10">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="&#10003;"
                       style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                              -fx-background-color:white; -fx-background-radius:50%;
                              -fx-padding:3 7 3 7;"/>
                <Label text="Cours de programmation structures"
                       style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="&#10003;"
                       style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                              -fx-background-color:white; -fx-background-radius:50%;
                              -fx-padding:3 7 3 7;"/>
                <Label text="Challenges avec feedback IA"
                       style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="&#10003;"
                       style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                              -fx-background-color:white; -fx-background-radius:50%;
                              -fx-padding:3 7 3 7;"/>
                <Label text="Evenements et hackathons en Tunisie"
                       style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Label text="Pas encore de compte ?"
               style="-fx-font-size:12; -fx-text-fill:rgba(255,255,255,0.6);"/>
        <Button text="Creer un compte gratuitement →" onAction="#onGoToRegister"
                style="-fx-background-color:white; -fx-text-fill:#7a6ad8;
                       -fx-font-size:13; -fx-font-weight:700; -fx-cursor:hand;
                       -fx-border-width:0; -fx-padding:12 24 12 24; -fx-background-radius:8;"/>
    </VBox>

    <!-- RIGHT: white form panel -->
    <VBox spacing="0" alignment="CENTER" HBox.hgrow="ALWAYS"
          style="-fx-background-color:white; -fx-padding:64 80 64 80;">

        <VBox spacing="28" maxWidth="400">

            <!-- Header -->
            <VBox spacing="6">
                <Label text="Bon retour !"
                       style="-fx-font-size:28; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"/>
                <Label text="Connectez-vous a votre compte AutoLearn"
                       style="-fx-font-size:13; -fx-text-fill:#888;"/>
            </VBox>

            <!-- Error label -->
            <Label fx:id="errorLabel" text="" wrapText="true" maxWidth="400"
                   style="-fx-text-fill:#dc2626; -fx-font-size:12;
                          -fx-background-color:#fef2f2;
                          -fx-background-radius:8; -fx-padding:10 14 10 14;
                          -fx-border-color:#fecaca; -fx-border-radius:8; -fx-border-width:1;"
                   visible="false" managed="false"/>

            <!-- Form -->
            <VBox spacing="16">
                <VBox spacing="6">
                    <Label text="Adresse email"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151;"/>
                    <TextField fx:id="fieldEmail" promptText="exemple@domaine.com"
                               style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                      -fx-border-radius:8; -fx-background-radius:8;
                                      -fx-padding:12 14 12 14; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
                </VBox>

                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mot de passe"
                               style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Mot de passe oublie ?" onAction="#onForgotPassword"
                                style="-fx-background-color:transparent; -fx-text-fill:#7a6ad8;
                                       -fx-font-size:12; -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
                    </HBox>
                    <!-- Password field with show/hide toggle -->
                    <StackPane>
                        <PasswordField fx:id="fieldPassword" promptText="Votre mot de passe"
                                       style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                              -fx-border-radius:8; -fx-background-radius:8;
                                              -fx-padding:12 44 12 14; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
                        <TextField fx:id="fieldPasswordVisible" promptText="Votre mot de passe"
                                   visible="false" managed="false"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:8; -fx-background-radius:8;
                                          -fx-padding:12 44 12 14; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
                        <Button fx:id="btnTogglePassword" text="&#128065;" onAction="#onTogglePassword"
                                style="-fx-background-color:transparent; -fx-border-width:0;
                                       -fx-cursor:hand; -fx-font-size:14; -fx-text-fill:#9ca3af;
                                       -fx-padding:0 12 0 0;"
                                StackPane.alignment="CENTER_RIGHT"/>
                    </StackPane>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <CheckBox fx:id="checkRememberMe"/>
                    <Label text="Se souvenir de moi"
                           style="-fx-font-size:12; -fx-text-fill:#6b7280;"/>
                </HBox>

                <Button text="Se connecter" onAction="#onLogin" maxWidth="Infinity"
                        style="-fx-background-color:#7a6ad8; -fx-text-fill:white;
                               -fx-font-size:14; -fx-font-weight:700;
                               -fx-padding:14 0 14 0; -fx-background-radius:8;
                               -fx-cursor:hand; -fx-border-width:0;
                               -fx-effect:dropshadow(gaussian,rgba(122,106,216,0.3),10,0,0,3);"/>
            </VBox>

            <!-- Back to landing -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="&#8592;"
                       style="-fx-font-size:12; -fx-text-fill:#aaa;"/>
                <Button text="Retour a l'accueil" onAction="#onBackToLanding"
                        style="-fx-background-color:transparent; -fx-text-fill:#aaa;
                               -fx-font-size:12; -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
            </HBox>

        </VBox>
    </VBox>

</HBox>

