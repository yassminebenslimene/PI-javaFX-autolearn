<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.RegisterController"
      maxWidth="Infinity" maxHeight="Infinity">

    <!-- LEFT: white form -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefWidth="580" minWidth="480"
                style="-fx-background-color:white; -fx-background:transparent; -fx-border-width:0;">
        <VBox spacing="0" alignment="CENTER" style="-fx-background-color:white;">

            <VBox spacing="24" maxWidth="480" style="-fx-padding:40 0 40 0;">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Auto" style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#7a6ad8;"/>
                    <Label text="Learn" style="-fx-font-size:22; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"/>
                </HBox>

                <VBox spacing="6">
                    <Label text="Creer votre compte"
                           style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"/>
                    <Label text="Rejoignez des milliers d'etudiants en Tunisie"
                           style="-fx-font-size:13; -fx-text-fill:#888;"/>
                </VBox>

                <GridPane hgap="16" vgap="4">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Nom *" GridPane.columnIndex="0" GridPane.rowIndex="0"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151; -fx-padding:0 0 4 0;"/>
                    <Label text="Prenom *" GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151; -fx-padding:0 0 4 0;"/>

                    <TextField fx:id="fieldNom" promptText="Votre nom"
                               GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"
                               style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                      -fx-border-radius:10; -fx-background-radius:10;
                                      -fx-padding:12 14 12 14; -fx-font-size:13;"/>
                    <TextField fx:id="fieldPrenom" promptText="Votre prenom"
                               GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"
                               style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                      -fx-border-radius:10; -fx-background-radius:10;
                                      -fx-padding:12 14 12 14; -fx-font-size:13;"/>

                    <Label fx:id="errorNom" GridPane.columnIndex="0" GridPane.rowIndex="2"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>
                    <Label fx:id="errorPrenom" GridPane.columnIndex="1" GridPane.rowIndex="2"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>

                    <Label text="Email *" GridPane.columnIndex="0" GridPane.rowIndex="3"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151; -fx-padding:8 0 4 0;"/>
                    <Label text="Type de compte *" GridPane.columnIndex="1" GridPane.rowIndex="3"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151; -fx-padding:8 0 4 0;"/>

                    <TextField fx:id="fieldEmail" promptText="exemple@domaine.com"
                               GridPane.columnIndex="0" GridPane.rowIndex="4" maxWidth="Infinity"
                               style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                      -fx-border-radius:10; -fx-background-radius:10;
                                      -fx-padding:12 14 12 14; -fx-font-size:13;"/>
                    <ComboBox fx:id="comboRole" promptText="Choisir un role" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="4"
                              style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                     -fx-border-radius:10; -fx-background-radius:10;
                                     -fx-font-size:13; -fx-pref-height:44;"/>

                    <Label fx:id="errorEmail" GridPane.columnIndex="0" GridPane.rowIndex="5"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>
                    <Label fx:id="errorRole" GridPane.columnIndex="1" GridPane.rowIndex="5"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>

                    <Label text="Mot de passe *" GridPane.columnIndex="0" GridPane.rowIndex="6"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151; -fx-padding:8 0 4 0;"/>
                    <Label text="Confirmer *" GridPane.columnIndex="1" GridPane.rowIndex="6"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151; -fx-padding:8 0 4 0;"/>

                    <PasswordField fx:id="fieldPassword" promptText="Minimum 6 caracteres"
                                   GridPane.columnIndex="0" GridPane.rowIndex="7" maxWidth="Infinity"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:10; -fx-background-radius:10;
                                          -fx-padding:12 14 12 14; -fx-font-size:13;"/>
                    <PasswordField fx:id="fieldConfirmPassword" promptText="Repetez le mot de passe"
                                   GridPane.columnIndex="1" GridPane.rowIndex="7" maxWidth="Infinity"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:10; -fx-background-radius:10;
                                          -fx-padding:12 14 12 14; -fx-font-size:13;"/>

                    <Label fx:id="errorPassword" GridPane.columnIndex="0" GridPane.rowIndex="8"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>
                    <Label fx:id="errorConfirm" GridPane.columnIndex="1" GridPane.rowIndex="8"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>

                    <Label fx:id="labelNiveau" text="Niveau *"
                           GridPane.columnIndex="0" GridPane.rowIndex="9"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151; -fx-padding:8 0 4 0;"
                           visible="false" managed="false"/>
                    <ComboBox fx:id="comboNiveau" promptText="Choisir un niveau" maxWidth="Infinity"
                              GridPane.columnIndex="0" GridPane.rowIndex="10"
                              style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                     -fx-border-radius:10; -fx-background-radius:10;
                                     -fx-font-size:13; -fx-pref-height:44;"
                              visible="false" managed="false"/>
                    <Label fx:id="errorNiveau" GridPane.columnIndex="0" GridPane.rowIndex="11"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;"
                           visible="false" managed="false" minHeight="14"/>
                </GridPane>

                <Label fx:id="errorGeneral" style="-fx-text-fill:#dc2626; -fx-font-size:12;" minHeight="14"/>

                <Button text="Creer mon compte" onAction="#onRegister" maxWidth="Infinity"
                        style="-fx-background-color:#7a6ad8; -fx-text-fill:white;
                               -fx-font-size:15; -fx-font-weight:700; -fx-padding:14 0 14 0;
                               -fx-background-radius:10; -fx-cursor:hand; -fx-border-width:0;"/>

                <VBox spacing="10" alignment="CENTER">
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Deja un compte ?" style="-fx-font-size:13; -fx-text-fill:#888;"/>
                        <Button text="Se connecter" onAction="#onGoToLogin"
                                style="-fx-background-color:transparent; -fx-text-fill:#7a6ad8;
                                       -fx-font-size:13; -fx-font-weight:700; -fx-cursor:hand;
                                       -fx-padding:0; -fx-border-width:0;"/>
                    </HBox>
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="&#8592;" style="-fx-font-size:12; -fx-text-fill:#ccc;"/>
                        <Button text="Retour a l'accueil" onAction="#onBackToLanding"
                                style="-fx-background-color:transparent; -fx-text-fill:#ccc;
                                       -fx-font-size:12; -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
                    </HBox>
                </VBox>

            </VBox>
        </VBox>
    </ScrollPane>

    <!-- RIGHT: gradient with centered content -->
    <StackPane HBox.hgrow="ALWAYS"
               style="-fx-background-color:linear-gradient(to bottom right,#7a6ad8,#6355c7,#4e3b9c);">

        <Circle radius="140" translateX="-180" translateY="-120"
                style="-fx-fill:rgba(255,255,255,0.06);" mouseTransparent="true"/>
        <Circle radius="100" translateX="200" translateY="140"
                style="-fx-fill:rgba(255,255,255,0.04);" mouseTransparent="true"/>
        <Circle radius="60" translateX="180" translateY="-160"
                style="-fx-fill:rgba(255,255,255,0.05);" mouseTransparent="true"/>

        <VBox spacing="36" alignment="CENTER" maxWidth="400"
              style="-fx-padding:60 48 60 48;">

            <!-- Quote card -->
            <VBox spacing="16" alignment="CENTER"
                  style="-fx-background-color:rgba(255,255,255,0.12); -fx-background-radius:16;
                         -fx-padding:28 24 28 24; -fx-border-color:rgba(255,255,255,0.2);
                         -fx-border-radius:16; -fx-border-width:1;">
                <Label text="&#10077;"
                       style="-fx-font-size:32; -fx-text-fill:rgba(255,255,255,0.3);"/>
                <Label text="Rejoignez une communaute d'etudiants passionnes et progressez ensemble."
                       wrapText="true" maxWidth="320"
                       style="-fx-font-size:15; -fx-font-weight:600; -fx-text-fill:white;
                              -fx-line-spacing:4; -fx-text-alignment:center;"/>
                <VBox spacing="2" alignment="CENTER">
                    <Label text="Ahmed K."
                           style="-fx-font-size:13; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.9);"/>
                    <Label text="Developpeur Full Stack — Sfax"
                           style="-fx-font-size:11; -fx-text-fill:rgba(255,255,255,0.55);"/>
                </VBox>
            </VBox>

            <!-- Benefits -->
            <VBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Ce que vous obtenez :"
                       style="-fx-font-size:14; -fx-font-weight:700; -fx-text-fill:rgba(255,255,255,0.75);"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="&#10003;"
                           style="-fx-font-size:13; -fx-font-weight:900; -fx-text-fill:white;
                                  -fx-background-color:rgba(255,255,255,0.15);
                                  -fx-background-radius:50%; -fx-padding:3 7 3 7;"/>
                    <Label text="Acces illimite a tous les cours"
                           style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="&#10003;"
                           style="-fx-font-size:13; -fx-font-weight:900; -fx-text-fill:white;
                                  -fx-background-color:rgba(255,255,255,0.15);
                                  -fx-background-radius:50%; -fx-padding:3 7 3 7;"/>
                    <Label text="Challenges corriges par IA"
                           style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="&#10003;"
                           style="-fx-font-size:13; -fx-font-weight:900; -fx-text-fill:white;
                                  -fx-background-color:rgba(255,255,255,0.15);
                                  -fx-background-radius:50%; -fx-padding:3 7 3 7;"/>
                    <Label text="Evenements et hackathons"
                           style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="&#10003;"
                           style="-fx-font-size:13; -fx-font-weight:900; -fx-text-fill:white;
                                  -fx-background-color:rgba(255,255,255,0.15);
                                  -fx-background-radius:50%; -fx-padding:3 7 3 7;"/>
                    <Label text="Badges et certificats"
                           style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="&#10003;"
                           style="-fx-font-size:13; -fx-font-weight:900; -fx-text-fill:white;
                                  -fx-background-color:rgba(255,255,255,0.15);
                                  -fx-background-radius:50%; -fx-padding:3 7 3 7;"/>
                    <Label text="Communaute active"
                           style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
                </HBox>
            </VBox>

        </VBox>
    </StackPane>

</HBox>
