<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.esprit.controllers.RegisterController"
           maxWidth="Infinity" maxHeight="Infinity"
           style="-fx-background-color:#0a0f0d;">

    <!-- Background orbs -->
    <StackPane mouseTransparent="true">
        <StackPane prefWidth="500" prefHeight="500"
                   style="-fx-background-color:radial-gradient(center 50% 50%, radius 50%, rgba(5,150,105,0.15), transparent);"
                   translateX="-320" translateY="-200"/>
        <StackPane prefWidth="380" prefHeight="380"
                   style="-fx-background-color:radial-gradient(center 50% 50%, radius 50%, rgba(99,102,241,0.12), transparent);"
                   translateX="340" translateY="220"/>
    </StackPane>

    <!-- Glass card -->
    <VBox alignment="CENTER" spacing="0" maxWidth="720"
          style="-fx-background-color:rgba(255,255,255,0.06);
                 -fx-background-radius:24;
                 -fx-border-color:rgba(255,255,255,0.12); -fx-border-radius:24; -fx-border-width:1;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.5),40,0,0,16);
                 -fx-padding:44 52 40 52;">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8" style="-fx-padding:0 0 32 0;">
            <Label text="G"
                   style="-fx-background-color:linear-gradient(to bottom right,#34d399,#059669);
                          -fx-text-fill:white; -fx-font-size:24; -fx-font-weight:800;
                          -fx-background-radius:14; -fx-padding:10 16 10 16;
                          -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.5),10,0,0,3);"/>
            <Label text="Create Account"
                   style="-fx-font-size:24; -fx-font-weight:700; -fx-text-fill:white;"/>
            <Label text="Start your journey with AutoLearn"
                   style="-fx-font-size:13; -fx-text-fill:rgba(245,245,244,0.5);"/>
        </VBox>

        <!-- GridPane: 2 columns of label+field pairs -->
        <GridPane hgap="20" vgap="4">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>

            <!-- Row 0: Nom label | Prénom label -->
            <Label text="Nom *" GridPane.columnIndex="0" GridPane.rowIndex="0"
                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.65); -fx-padding:0 0 2 2;"/>
            <Label text="Prénom *" GridPane.columnIndex="1" GridPane.rowIndex="0"
                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.65); -fx-padding:0 0 2 2;"/>

            <!-- Row 1: Nom field | Prénom field -->
            <TextField fx:id="fieldNom" promptText="Votre nom"
                       GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"
                       style="-fx-background-color:rgba(255,255,255,0.08);
                              -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                              -fx-background-radius:10; -fx-padding:12 14 12 14;
                              -fx-font-size:13; -fx-text-fill:white;
                              -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>
            <TextField fx:id="fieldPrenom" promptText="Votre prénom"
                       GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"
                       style="-fx-background-color:rgba(255,255,255,0.08);
                              -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                              -fx-background-radius:10; -fx-padding:12 14 12 14;
                              -fx-font-size:13; -fx-text-fill:white;
                              -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>

            <!-- Row 2: errors -->
            <Label fx:id="errorNom" GridPane.columnIndex="0" GridPane.rowIndex="2"
                   style="-fx-text-fill:#f87171; -fx-font-size:11; -fx-padding:0 0 0 2;" minHeight="16"/>
            <Label fx:id="errorPrenom" GridPane.columnIndex="1" GridPane.rowIndex="2"
                   style="-fx-text-fill:#f87171; -fx-font-size:11; -fx-padding:0 0 0 2;" minHeight="16"/>

            <!-- Row 3: Email label | Type de compte label -->
            <Label text="Email *" GridPane.columnIndex="0" GridPane.rowIndex="3"
                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.65); -fx-padding:8 0 2 2;"/>
            <Label text="Type de compte *" GridPane.columnIndex="1" GridPane.rowIndex="3"
                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.65); -fx-padding:8 0 2 2;"/>

            <!-- Row 4: Email field | Role combo -->
            <TextField fx:id="fieldEmail" promptText="exemple@domaine.com"
                       GridPane.columnIndex="0" GridPane.rowIndex="4" maxWidth="Infinity"
                       style="-fx-background-color:rgba(255,255,255,0.08);
                              -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                              -fx-background-radius:10; -fx-padding:12 14 12 14;
                              -fx-font-size:13; -fx-text-fill:white;
                              -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>
            <ComboBox fx:id="comboRole" promptText="Choisir un rôle" maxWidth="Infinity"
                      GridPane.columnIndex="1" GridPane.rowIndex="4"
                      style="-fx-background-color:rgba(255,255,255,0.08);
                             -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                             -fx-background-radius:10; -fx-font-size:13; -fx-pref-height:44;"/>

            <!-- Row 5: errors -->
            <Label fx:id="errorEmail" GridPane.columnIndex="0" GridPane.rowIndex="5"
                   style="-fx-text-fill:#f87171; -fx-font-size:11; -fx-padding:0 0 0 2;" minHeight="16"/>
            <Label fx:id="errorRole" GridPane.columnIndex="1" GridPane.rowIndex="5"
                   style="-fx-text-fill:#f87171; -fx-font-size:11; -fx-padding:0 0 0 2;" minHeight="16"/>

            <!-- Row 6: Mot de passe label | Confirmer label -->
            <Label text="Mot de passe *" GridPane.columnIndex="0" GridPane.rowIndex="6"
                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.65); -fx-padding:8 0 2 2;"/>
            <Label text="Confirmer le mot de passe *" GridPane.columnIndex="1" GridPane.rowIndex="6"
                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.65); -fx-padding:8 0 2 2;"/>

            <!-- Row 7: Password | Confirm -->
            <PasswordField fx:id="fieldPassword" promptText="Minimum 8 caractères"
                           GridPane.columnIndex="0" GridPane.rowIndex="7" maxWidth="Infinity"
                           style="-fx-background-color:rgba(255,255,255,0.08);
                                  -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                  -fx-background-radius:10; -fx-padding:12 14 12 14;
                                  -fx-font-size:13; -fx-text-fill:white;
                                  -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>
            <PasswordField fx:id="fieldConfirmPassword" promptText="Répétez le mot de passe"
                           GridPane.columnIndex="1" GridPane.rowIndex="7" maxWidth="Infinity"
                           style="-fx-background-color:rgba(255,255,255,0.08);
                                  -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                                  -fx-background-radius:10; -fx-padding:12 14 12 14;
                                  -fx-font-size:13; -fx-text-fill:white;
                                  -fx-prompt-text-fill:rgba(245,245,244,0.35);"/>

            <!-- Row 8: errors -->
            <Label fx:id="errorPassword" GridPane.columnIndex="0" GridPane.rowIndex="8"
                   style="-fx-text-fill:#f87171; -fx-font-size:11; -fx-padding:0 0 0 2;" minHeight="16"/>
            <Label fx:id="errorConfirm" GridPane.columnIndex="1" GridPane.rowIndex="8"
                   style="-fx-text-fill:#f87171; -fx-font-size:11; -fx-padding:0 0 0 2;" minHeight="16"/>

            <!-- Row 9: Niveau label (half width, students only) -->
            <Label fx:id="labelNiveau" text="Niveau *" GridPane.columnIndex="0" GridPane.rowIndex="9"
                   style="-fx-font-size:12; -fx-font-weight:600; -fx-text-fill:rgba(245,245,244,0.65); -fx-padding:8 0 2 2;"
                   visible="false" managed="false"/>

            <!-- Row 10: Niveau combo -->
            <ComboBox fx:id="comboNiveau" promptText="Choisir un niveau" maxWidth="Infinity"
                      GridPane.columnIndex="0" GridPane.rowIndex="10"
                      style="-fx-background-color:rgba(255,255,255,0.08);
                             -fx-border-color:rgba(255,255,255,0.15); -fx-border-radius:10;
                             -fx-background-radius:10; -fx-font-size:13; -fx-pref-height:44;"
                      visible="false" managed="false"/>
            <Label fx:id="errorNiveau" GridPane.columnIndex="0" GridPane.rowIndex="11"
                   style="-fx-text-fill:#f87171; -fx-font-size:11;"
                   visible="false" managed="false" minHeight="16"/>
        </GridPane>

        <Label fx:id="errorGeneral" style="-fx-text-fill:#f87171; -fx-font-size:12;" minHeight="14"/>

        <Region prefHeight="14"/>

        <Button text="Create Account  →" onAction="#onRegister" maxWidth="Infinity"
                style="-fx-background-color:linear-gradient(to right,#34d399,#059669);
                       -fx-text-fill:white; -fx-font-size:14; -fx-font-weight:700;
                       -fx-padding:14 0 14 0; -fx-background-radius:12;
                       -fx-cursor:hand; -fx-border-width:0;
                       -fx-effect:dropshadow(gaussian,rgba(5,150,105,0.45),12,0,0,4);"/>

        <Region prefHeight="16"/>

        <HBox alignment="CENTER" spacing="6">
            <Label text="Already have an account?"
                   style="-fx-font-size:12; -fx-text-fill:rgba(245,245,244,0.45);"/>
            <Button text="Sign In" onAction="#onGoToLogin"
                    style="-fx-background-color:transparent; -fx-text-fill:#34d399;
                           -fx-font-size:12; -fx-font-weight:600;
                           -fx-cursor:hand; -fx-padding:0; -fx-border-width:0;"/>
        </HBox>
    </VBox>
</StackPane>
