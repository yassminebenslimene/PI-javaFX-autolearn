<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="tn.esprit.controllers.ResetPasswordController"
      maxWidth="Infinity" maxHeight="Infinity">

    <!-- LEFT: violet brand panel -->
    <VBox spacing="28" alignment="CENTER_LEFT" prefWidth="480" minWidth="380"
          style="-fx-background-color:#7a6ad8; -fx-padding:64 56 64 64;">
        <VBox spacing="6">
            <Label text="AutoLearn"
                   style="-fx-font-size:28; -fx-font-weight:900; -fx-text-fill:white;"/>
            <Label text="Votre plateforme d'apprentissage"
                   style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.7);"/>
        </VBox>
        <VBox spacing="12">
            <Label text="Reinitialisation du mot de passe"
                   style="-fx-font-size:20; -fx-font-weight:800; -fx-text-fill:white;" wrapText="true"/>
            <Label text="Entrez votre email pour recevoir un code de verification a 6 chiffres."
                   wrapText="true"
                   style="-fx-font-size:14; -fx-text-fill:rgba(255,255,255,0.75); -fx-line-spacing:4; -fx-max-width:340;"/>
        </VBox>
        <VBox spacing="10">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="1" style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                              -fx-background-color:white; -fx-background-radius:50%;
                              -fx-padding:3 8 3 8;"/>
                <Label text="Entrez votre adresse email"
                       style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="2" style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                              -fx-background-color:white; -fx-background-radius:50%;
                              -fx-padding:3 8 3 8;"/>
                <Label text="Recevez le code par email"
                       style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="3" style="-fx-font-size:12; -fx-font-weight:700; -fx-text-fill:#7a6ad8;
                              -fx-background-color:white; -fx-background-radius:50%;
                              -fx-padding:3 8 3 8;"/>
                <Label text="Definissez votre nouveau mot de passe"
                       style="-fx-font-size:13; -fx-text-fill:rgba(255,255,255,0.85);"/>
            </HBox>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="← Retour a la connexion" onAction="#onBackToLogin"
                style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;
                       -fx-font-size:13; -fx-font-weight:600; -fx-cursor:hand;
                       -fx-border-width:0; -fx-padding:10 20 10 20; -fx-background-radius:8;"/>
    </VBox>

    <!-- RIGHT: form panel -->
    <VBox spacing="0" alignment="CENTER" HBox.hgrow="ALWAYS"
          style="-fx-background-color:white; -fx-padding:64 80 64 80;">
        <VBox spacing="28" maxWidth="400">

            <Label fx:id="successLabel" text="" wrapText="true" maxWidth="400"
                   style="-fx-font-size:13;" visible="true" managed="true"/>

            <!-- STEP 1: Email entry -->
            <VBox fx:id="stepEmail" spacing="20">
                <VBox spacing="6">
                    <Label text="Mot de passe oublie ?"
                           style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"/>
                    <Label text="Entrez votre email pour recevoir un code"
                           style="-fx-font-size:13; -fx-text-fill:#888;"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Adresse email"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151;"/>
                    <TextField fx:id="fieldEmail" promptText="exemple@domaine.com"
                               style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                      -fx-border-radius:8; -fx-background-radius:8;
                                      -fx-padding:12 14 12 14; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
                    <Label fx:id="errorEmail"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>
                </VBox>
                <Button text="Envoyer le code" onAction="#onSendCode" maxWidth="Infinity"
                        style="-fx-background-color:#7a6ad8; -fx-text-fill:white;
                               -fx-font-size:14; -fx-font-weight:700;
                               -fx-padding:14 0 14 0; -fx-background-radius:8;
                               -fx-cursor:hand; -fx-border-width:0;"/>
            </VBox>

            <!-- STEP 2: Code + new password -->
            <VBox fx:id="stepReset" spacing="20" visible="false" managed="false">
                <VBox spacing="6">
                    <Label text="Verifiez votre email"
                           style="-fx-font-size:26; -fx-font-weight:900; -fx-text-fill:#1a1a2e;"/>
                    <Label text="Entrez le code recu et votre nouveau mot de passe"
                           style="-fx-font-size:13; -fx-text-fill:#888;"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Code de verification (6 chiffres)"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151;"/>
                    <TextField fx:id="fieldCode" promptText="123456"
                               style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                      -fx-border-radius:8; -fx-background-radius:8;
                                      -fx-padding:12 14 12 14; -fx-font-size:20; -fx-font-weight:700;
                                      -fx-text-fill:#7a6ad8; -fx-alignment:CENTER;"/>
                    <Label fx:id="errorCode"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Nouveau mot de passe"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151;"/>
                    <PasswordField fx:id="fieldNewPassword" promptText="Minimum 6 caracteres"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:8; -fx-background-radius:8;
                                          -fx-padding:12 14 12 14; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
                    <Label fx:id="errorPassword"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Confirmer le mot de passe"
                           style="-fx-font-size:13; -fx-font-weight:600; -fx-text-fill:#374151;"/>
                    <PasswordField fx:id="fieldConfirmPassword" promptText="Repetez le mot de passe"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:8; -fx-background-radius:8;
                                          -fx-padding:12 14 12 14; -fx-font-size:13; -fx-text-fill:#1a1a2e;"/>
                    <Label fx:id="errorConfirm"
                           style="-fx-text-fill:#dc2626; -fx-font-size:11;" minHeight="14"/>
                </VBox>
                <Button text="Reinitialiser le mot de passe" onAction="#onReset" maxWidth="Infinity"
                        style="-fx-background-color:#7a6ad8; -fx-text-fill:white;
                               -fx-font-size:14; -fx-font-weight:700;
                               -fx-padding:14 0 14 0; -fx-background-radius:8;
                               -fx-cursor:hand; -fx-border-width:0;"/>
            </VBox>

        </VBox>
    </VBox>

</HBox>

